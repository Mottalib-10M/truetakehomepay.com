---
import CalculatorLayout from '../../layouts/CalculatorLayout.astro';
import PaycheckCalculator from '../../components/calculators/PaycheckCalculator';
import { TAX_YEAR, SITE_URL } from '../../lib/constants';
import { TOP_10_STATES, STATE_SALARY_AMOUNTS, STATES, NO_INCOME_TAX_STATES } from '../../data/state-meta';
import { formatCurrencyRound } from '../../lib/format-us';
import { getStateTaxConfig } from '../../data/income-tax-2026/index';
import { formatPercent } from '../../lib/format-us';

export function getStaticPaths() {
  const paths: {
    params: { state: string; amount: string };
    props: { stateCode: string; stateName: string; stateSlug: string; amount: number };
  }[] = [];
  for (const stateCode of TOP_10_STATES) {
    const state = STATES[stateCode];
    for (const amount of STATE_SALARY_AMOUNTS) {
      paths.push({
        params: { state: state.slug, amount: amount.toString() },
        props: { stateCode, stateName: state.name, stateSlug: state.slug, amount },
      });
    }
  }
  return paths;
}

const { stateCode, stateName, stateSlug, amount } = Astro.props;
const formatted = formatCurrencyRound(amount);
const isNoTax = NO_INCOME_TAX_STATES.includes(stateCode);
const stateConfig = getStateTaxConfig(stateCode);

// ─── Title & Meta ────────────────────────────────────────────────────
// Title: 50-60 chars — adapted to state name + amount length
const _tFull = `${formatted} After Taxes in ${stateName} — ${TAX_YEAR} Take-Home Pay`;
const _tShort = `${formatted} After Taxes in ${stateName} ${TAX_YEAR}`;
const title = _tFull.length <= 60 ? _tFull : _tShort.length <= 60 ? _tShort : `${formatted} After Tax in ${stateName} ${TAX_YEAR}`;

// Description: 150-160 chars — use state name once for long names
const description = stateName.length <= 8
  ? `How much is ${formatted} after taxes in ${stateName}? Calculate your ${TAX_YEAR} take-home pay with federal income tax, ${stateName} state tax, FICA, and deductions.`
  : `How much is ${formatted} after taxes in ${stateName}? Calculate your ${TAX_YEAR} take-home pay with federal, state income tax, FICA, and deductions breakdown.`;

// ─── State tax summary ──────────────────────────────────────────────
let stateTaxNote: string;
if (isNoTax) {
  stateTaxNote = `${stateName} has no state income tax, so you keep more of your ${formatted} salary. Your only deductions are federal income tax and FICA.`;
} else if (stateConfig?.flatRate) {
  stateTaxNote = `${stateName} has a flat state income tax rate of ${formatPercent(stateConfig.flatRate * 100)}. On a ${formatted} salary, that's approximately ${formatCurrencyRound(amount * stateConfig.flatRate)} in state tax before deductions.`;
} else {
  const topRate = stateConfig?.brackets?.single?.at(-1)?.rate;
  stateTaxNote = `${stateName} has a progressive state income tax with rates up to ${topRate ? formatPercent(topRate * 100) : 'the top bracket'}. Your effective state tax rate on ${formatted} depends on your filing status and deductions.`;
}

// ─── Intro ───────────────────────────────────────────────────────────
const intro = `How much is ${formatted} after taxes in ${stateName}? Use this free ${TAX_YEAR} calculator to find your exact take-home pay after federal income tax, ${isNoTax ? 'FICA' : stateName + ' state tax, FICA'}, and deductions.`;

// ─── Neighboring state comparisons ──────────────────────────────────
const neighbors = STATES[stateCode].neighbors
  .map((n) => ({ code: n, ...STATES[n] }))
  .filter(Boolean)
  .slice(0, 4);

// ─── Related salary amounts for this state ──────────────────────────
const otherAmounts = STATE_SALARY_AMOUNTS.filter((a) => a !== amount);

// ─── Other states for this amount ───────────────────────────────────
const otherStates = TOP_10_STATES.filter((c) => c !== stateCode).map((c) => ({
  code: c,
  name: STATES[c].name,
  slug: STATES[c].slug,
}));

// ─── FAQs ────────────────────────────────────────────────────────────
const faqs = [
  {
    question: `How much is ${formatted} after taxes in ${stateName}?`,
    answer: isNoTax
      ? `In ${stateName}, which has no state income tax, a single filer earning ${formatted} takes home approximately ${formatCurrencyRound(amount * 0.80)} to ${formatCurrencyRound(amount * 0.85)} after federal income tax and FICA. Your exact take-home depends on filing status, deductions, and pre-tax contributions like 401(k).`
      : `In ${stateName}, a single filer earning ${formatted} takes home approximately ${formatCurrencyRound(amount * 0.70)} to ${formatCurrencyRound(amount * 0.78)} after federal income tax, ${stateName} state tax, and FICA. Your exact amount depends on filing status and deductions. Use the calculator above for a precise estimate.`,
  },
  {
    question: `What is the ${stateName} tax rate on ${formatted}?`,
    answer: isNoTax
      ? `${stateName} has no state income tax on wages, so the state tax rate on your ${formatted} salary is 0%. You'll still pay federal income tax (10%-37% based on bracket) and FICA taxes (7.65%).`
      : stateConfig?.flatRate
        ? `${stateName} has a flat state income tax rate of ${formatPercent(stateConfig.flatRate * 100)}. This rate applies to all taxable income regardless of amount. On ${formatted}, your approximate state tax is ${formatCurrencyRound(amount * stateConfig.flatRate)} before the state standard deduction.`
        : `${stateName} uses progressive tax brackets. On a ${formatted} salary, your effective state tax rate is typically between ${formatPercent((stateConfig?.brackets?.single?.[0]?.rate ?? 0.02) * 100)} and ${formatPercent((stateConfig?.brackets?.single?.at(-1)?.rate ?? 0.10) * 100)}, depending on your deductions and filing status.`,
  },
  {
    question: `How much is ${formatted} per paycheck in ${stateName}?`,
    answer: `Before taxes, ${formatted} equals ${formatCurrencyRound(amount / 26)} per bi-weekly paycheck. After federal tax, ${isNoTax ? '' : stateName + ' state tax, '}and FICA deductions, your bi-weekly take-home pay will be approximately ${formatCurrencyRound((amount * (isNoTax ? 0.82 : 0.74)) / 26)} to ${formatCurrencyRound((amount * (isNoTax ? 0.85 : 0.78)) / 26)} for a single filer.`,
  },
  {
    question: `Is ${formatted} a good salary in ${stateName}?`,
    answer: amount <= 50000
      ? `A ${formatted} salary is below the median household income in ${stateName}. ${isNoTax ? 'The lack of state income tax helps stretch your dollar further.' : 'After state and federal taxes, budgeting carefully for housing and essentials is important.'} Cost of living varies significantly within ${stateName} — rural areas are typically much more affordable than major metro areas.`
      : amount <= 100000
        ? `A ${formatted} salary is at or above the national median in ${stateName}. ${isNoTax ? 'With no state income tax, your take-home pay is higher than in most states.' : 'After taxes, you can comfortably afford housing and living expenses in most parts of ' + stateName + '.'} In high-cost metro areas, it provides a middle-class lifestyle.`
        : `A ${formatted} salary is well above the median household income in ${stateName}. ${isNoTax ? 'Combined with no state income tax, your purchasing power is excellent.' : 'Even after state and federal taxes, this provides a comfortable lifestyle in most areas of ' + stateName + '.'} At this income level, maximizing tax-advantaged retirement accounts can significantly boost your long-term wealth.`,
  },
];

// ─── Related Calculators ─────────────────────────────────────────────
const relatedCalculators = [
  {
    title: `${stateName} Paycheck Calc`,
    href: `/paycheck-calculator/${stateSlug}/`,
    desc: `Full ${stateName} calculator`,
  },
  {
    title: `${formatted} (National)`,
    href: `/${amount}-after-taxes/`,
    desc: 'All 50 states comparison',
  },
  ...otherAmounts.slice(0, 1).map((a) => ({
    title: `${formatCurrencyRound(a)} in ${stateName}`,
    href: `/${stateSlug}/${a}-after-taxes/`,
    desc: `${stateName} take-home pay`,
  })),
  {
    title: 'Take-Home Comparison',
    href: '/take-home-comparison/',
    desc: 'Compare states side-by-side',
  },
];

// ─── Schema.org ──────────────────────────────────────────────────────
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
};

const webAppSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: `${formatted} After Taxes in ${stateName} ${TAX_YEAR}`,
  description,
  url: `${SITE_URL}/${stateSlug}/${amount}-after-taxes`,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'Any',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  inLanguage: 'en-US',
};

const schema = [faqSchema, webAppSchema];
---

<CalculatorLayout
  title={title}
  description={description}
  h1={`${formatted} After Taxes in ${stateName} (${TAX_YEAR})`}
  intro={intro}
  faqs={faqs}
  relatedCalculators={relatedCalculators}
  schema={schema}
  sources={`IRS Rev. Proc. 2025-11 (federal brackets), ${stateName} Department of Revenue (state tax rates), SSA.gov (Social Security wage base). Last updated for tax year ${TAX_YEAR}.`}
  canonical={`${SITE_URL}/${stateSlug}/${amount}-after-taxes`}
>
  <PaycheckCalculator
    client:load
    defaultState={stateCode}
    defaultGross={amount}
  />

  <Fragment slot="content">
    <!-- In-depth SEO content section -->
    <section class="border-t border-slate-200 px-4 py-16 dark:border-slate-800 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <div class="prose prose-slate dark:prose-invert max-w-none">

          <h2 id="what-salary-means-in-state" class="text-2xl font-bold text-slate-900 dark:text-white">
            What a {formatted} Salary Means in {stateName}
          </h2>

          <p>
            Earning {formatted} per year in {stateName} places you in a specific economic context that varies considerably depending on where within the state you choose to live and work. Across the United States, the median household income hovers near $80,000, which means that a {formatted} salary {amount < 80000 ? 'falls below the national median and requires careful budgeting to maintain financial stability' : amount <= 120000 ? 'meets or exceeds the national median and provides a solid financial foundation for most households' : 'substantially exceeds the national median and affords a comfortable standard of living in the vast majority of communities'}. However, raw salary figures only tell part of the story. The true purchasing power of your {formatted} income depends on the cost of housing, groceries, transportation, healthcare, and other essentials specific to {stateName}.
          </p>

          {amount <= 50000 && (
            <p>
              At the {formatted} income level, every dollar of take-home pay matters. In {stateName}, workers at this salary level often find that housing costs consume the largest share of their monthly budget. Financial advisors generally recommend spending no more than 30 percent of gross income on housing, which translates to roughly {formatCurrencyRound(amount * 0.30 / 12)} per month for someone earning {formatted}. In metropolitan areas of {stateName}, this budget may limit your options to shared housing or apartments farther from city centers, while in rural parts of the state, this amount can comfortably cover a mortgage payment on a modest home. Understanding your true take-home pay after all taxes and deductions is essential at this income level because even a small increase in deductions or a well-timed tax credit can make a meaningful difference in your monthly cash flow.
            </p>
          )}

          {amount > 50000 && amount <= 100000 && (
            <p>
              With a {formatted} salary in {stateName}, you are positioned within the broad middle class of American earners. This income level typically provides enough after-tax income to cover essential expenses, build an emergency fund, and begin saving for retirement. In {stateName}, the cost of living varies significantly by region. Metropolitan areas tend to have higher housing and transportation costs, which can eat into your take-home pay, while suburban and rural communities often offer more affordable living. At {formatted}, your monthly gross income of {formatCurrencyRound(amount / 12)} translates to a take-home figure that depends heavily on whether {stateName} imposes a state income tax and how aggressively you use pre-tax deductions like retirement contributions and health savings accounts.
            </p>
          )}

          {amount > 100000 && amount <= 200000 && (
            <p>
              A {formatted} salary in {stateName} places you well above the national median household income, providing a level of financial comfort that allows for both current lifestyle spending and meaningful long-term wealth building. At this income level, you have the capacity to maximize contributions to tax-advantaged retirement accounts, build a robust emergency fund, and invest in taxable brokerage accounts. However, higher earners also face higher marginal tax rates at both the federal and state level, making tax planning an essential component of your overall financial strategy. In {stateName}, the interplay between federal brackets, state tax policy, and local cost of living determines how much of your {formatted} gross salary actually reaches your bank account each pay period.
            </p>
          )}

          {amount > 200000 && (
            <p>
              Earning {formatted} annually in {stateName} places you among the top earners in the country. At this income level, you are subject to the highest federal marginal tax rates, and if {stateName} levies a state income tax, the combined burden can claim a substantial portion of each additional dollar earned. However, {formatted} also provides access to sophisticated financial planning strategies, including maximizing all available tax-advantaged accounts, implementing backdoor Roth IRA contributions, and potentially benefiting from tax-loss harvesting in investment portfolios. In {stateName}, the difference between strategic and passive tax planning at this income level can amount to tens of thousands of dollars in annual savings.
            </p>
          )}

          <h2 id="federal-tax-breakdown" class="text-2xl font-bold text-slate-900 dark:text-white">
            How Federal Income Taxes Apply to a {formatted} Salary
          </h2>

          <p>
            The United States uses a progressive federal income tax system, meaning that different portions of your income are taxed at different rates as they pass through successive brackets. For {TAX_YEAR}, a single filer earning {formatted} first benefits from the standard deduction of $15,700, which reduces the amount of income subject to federal tax. This means that your federal taxable income is approximately {formatCurrencyRound(Math.max(amount - 15700, 0))}, not the full {formatted}. Understanding this distinction is critical because many people mistakenly believe that their entire salary is taxed at their highest marginal rate, when in reality only the income within each bracket is taxed at that bracket's rate.
          </p>

          {amount <= 60000 && (
            <p>
              On a {formatted} salary with the standard deduction applied, most of your federal taxable income falls within the 10 percent and 12 percent brackets. The first $11,925 of taxable income is taxed at just 10 percent, resulting in approximately {formatCurrencyRound(11925 * 0.10)} in federal tax on that portion. Income between $11,925 and $48,475 is taxed at 12 percent. Because your taxable income of roughly {formatCurrencyRound(Math.max(amount - 15700, 0))} falls {amount - 15700 <= 48475 ? 'entirely within these two lowest brackets' : 'primarily within the lower brackets with only a small portion reaching the 22 percent bracket'}, your effective federal income tax rate is significantly lower than your marginal rate. This means you keep a larger share of each dollar earned compared to higher-income taxpayers, though FICA taxes still apply to every dollar of your gross wages.
            </p>
          )}

          {amount > 60000 && amount <= 110000 && (
            <p>
              With a {formatted} salary and the standard deduction, your federal taxable income of approximately {formatCurrencyRound(Math.max(amount - 15700, 0))} moves through the 10 percent bracket on the first $11,925, the 12 percent bracket on income up to $48,475, and the 22 percent bracket on income up to $103,350. Your effective federal income tax rate at this income level typically falls between 12 and 16 percent, which means you pay roughly {formatCurrencyRound(amount * 0.13)} to {formatCurrencyRound(amount * 0.16)} in federal income tax before accounting for any credits or additional deductions. The 22 percent bracket is where many middle-income earners find the majority of their marginal dollars being taxed, and it represents the bracket where strategic use of pre-tax retirement contributions and HSA contributions can produce the most immediate tax savings.
            </p>
          )}

          {amount > 110000 && amount <= 200000 && (
            <p>
              At {formatted}, your federal taxable income of approximately {formatCurrencyRound(Math.max(amount - 15700, 0))} passes through several brackets. You pay 10 percent on the first $11,925, 12 percent on income up to $48,475, 22 percent on income up to $103,350, and 24 percent on income up to $197,300. Your effective federal tax rate at this level is typically between 16 and 21 percent, resulting in approximately {formatCurrencyRound(amount * 0.17)} to {formatCurrencyRound(amount * 0.21)} in federal income tax. The transition from the 22 percent to the 24 percent bracket is meaningful because each additional dollar of taxable income above $103,350 is taxed at the higher rate, making pre-tax deductions like a traditional 401(k) contribution particularly valuable for reducing your federal tax obligation.
            </p>
          )}

          {amount > 200000 && (
            <p>
              A {formatted} salary results in federal taxable income of approximately {formatCurrencyRound(Math.max(amount - 15700, 0))} after the standard deduction. This amount passes through every bracket from 10 percent through at least 32 percent, and {amount > 250000 ? 'potentially into the 35 percent bracket for income above $250,525' : 'approaches the threshold for the 35 percent bracket'}. Your effective federal income tax rate is typically between 22 and 28 percent, which translates to approximately {formatCurrencyRound(amount * 0.23)} to {formatCurrencyRound(amount * 0.28)} in federal income tax. At this income level, the difference between your marginal rate and your effective rate is substantial, and understanding this gap is essential for making informed decisions about additional income, bonuses, and investment strategies.
            </p>
          )}

          <h2 id="state-tax-analysis" class="text-2xl font-bold text-slate-900 dark:text-white">
            How {stateName} State Taxes Apply to {formatted}
          </h2>

          {isNoTax && (
            <p>
              One of the most significant financial advantages of earning {formatted} in {stateName} is that the state imposes no income tax on wages and salaries. This means that unlike workers in states with income tax, you do not face any state-level withholding on your paychecks. The absence of state income tax in {stateName} can translate to thousands of dollars in additional take-home pay each year compared to earning the same {formatted} salary in a state with moderate or high income tax rates. For perspective, a worker earning {formatted} in a state with a 5 percent income tax rate would pay approximately {formatCurrencyRound(amount * 0.05)} in state taxes, while you pay nothing. This advantage is particularly meaningful at the {formatted} salary level because it effectively raises your after-tax income without requiring any additional work or negotiation. However, it is worth noting that {stateName} may compensate for the lack of income tax through higher property taxes, sales taxes, or other fees that affect your overall cost of living.
            </p>
          )}

          {!isNoTax && stateConfig?.flatRate && (
            <p>
              {stateName} applies a flat income tax rate of {formatPercent(stateConfig.flatRate * 100)} to all taxable income, regardless of how much you earn. On your {formatted} salary, this flat rate results in an approximate state income tax of {formatCurrencyRound(amount * stateConfig.flatRate)} before accounting for any state-level standard deduction or personal exemptions that {stateName} may offer. The flat tax structure in {stateName} means that every dollar of taxable income is treated equally, whether it is your first dollar or your last. This simplifies tax planning considerably because your marginal state tax rate is always the same as your effective state tax rate. For someone earning {formatted}, the flat tax approach means you pay {formatCurrencyRound(amount * stateConfig.flatRate / 12)} per month in state income tax, or roughly {formatCurrencyRound(amount * stateConfig.flatRate / 26)} per biweekly paycheck. While a flat tax system may seem less burdensome than a progressive system for higher earners, it also means that lower-income workers in {stateName} pay the same rate on their first dollars of income.
            </p>
          )}

          {!isNoTax && !stateConfig?.flatRate && (
            <p>
              {stateName} uses a progressive state income tax system, meaning that different portions of your income are taxed at increasing rates as your earnings rise through the state's bracket structure. On a {formatted} salary, your state tax obligation depends on where your income falls within these brackets. The lowest bracket in {stateName} starts at a rate of {stateConfig?.brackets?.single?.[0]?.rate ? formatPercent(stateConfig.brackets.single[0].rate * 100) : 'a modest percentage'}, while the top marginal rate reaches {stateConfig?.brackets?.single?.at(-1)?.rate ? formatPercent(stateConfig.brackets.single.at(-1)!.rate * 100) : 'the highest bracket'}. Just like the federal system, your effective state tax rate on {formatted} is lower than your marginal rate because only the income within each bracket is taxed at that bracket's rate. For a single filer earning {formatted} in {stateName}, the effective state income tax rate typically falls below the top marginal rate, resulting in a state tax bill that may be somewhat less than what a simple multiplication by the top rate would suggest. This progressive structure means that any pre-tax deductions you claim, such as retirement contributions or health savings account deposits, reduce your income from the top bracket down, saving you money at your highest marginal state rate.
            </p>
          )}

          <h2 id="fica-breakdown" class="text-2xl font-bold text-slate-900 dark:text-white">
            FICA Tax Breakdown on {formatted}
          </h2>

          <p>
            In addition to federal and state income taxes, every W-2 employee in the United States is subject to FICA taxes, which fund Social Security and Medicare. These payroll taxes are calculated on your gross wages before any income tax deductions are applied. The Social Security portion of FICA is 6.2 percent of your wages up to the {TAX_YEAR} wage base of $176,100, and the Medicare portion is 1.45 percent on all wages with no cap. On a {formatted} salary, your total FICA obligation is {amount <= 176100 ? `approximately ${formatCurrencyRound(amount * 0.0765)}, consisting of ${formatCurrencyRound(amount * 0.062)} for Social Security and ${formatCurrencyRound(amount * 0.0145)} for Medicare` : `approximately ${formatCurrencyRound(176100 * 0.062 + amount * 0.0145)}, consisting of ${formatCurrencyRound(176100 * 0.062)} for Social Security (capped at the $176,100 wage base) and ${formatCurrencyRound(amount * 0.0145)} for Medicare`}. Your employer pays an equal amount in FICA taxes on your behalf, which does not come out of your paycheck but does represent a real cost of your employment.
          </p>

          {amount > 200000 && (
            <p>
              Because your {formatted} salary exceeds $200,000, you are also subject to the Additional Medicare Tax of 0.9 percent on wages above that threshold. This means that on the {formatCurrencyRound(amount - 200000)} of income above $200,000, you pay an extra {formatCurrencyRound((amount - 200000) * 0.009)} in Medicare surtax, bringing your total Medicare tax to {formatCurrencyRound(amount * 0.0145 + (amount - 200000) * 0.009)}. Unlike the standard Medicare tax, your employer does not match the Additional Medicare Tax, so this is an expense borne entirely by you. This additional tax is withheld automatically from your paycheck once your year-to-date wages exceed $200,000, which typically occurs partway through the calendar year for someone earning {formatted}.
            </p>
          )}

          <p>
            FICA taxes are often overlooked when employees think about their tax burden, but they represent a significant portion of the gap between gross pay and take-home pay. On a {formatted} salary in {stateName}, your combined FICA taxes of {amount <= 176100 ? formatCurrencyRound(amount * 0.0765) : formatCurrencyRound(176100 * 0.062 + amount * 0.0145 + (amount > 200000 ? (amount - 200000) * 0.009 : 0))} are deducted from every paycheck throughout the year, reducing your biweekly take-home pay by approximately {amount <= 176100 ? formatCurrencyRound(amount * 0.0765 / 26) : formatCurrencyRound((176100 * 0.062 + amount * 0.0145 + (amount > 200000 ? (amount - 200000) * 0.009 : 0)) / 26)} per pay period. Unlike federal and state income taxes, FICA taxes cannot be reduced through deductions or credits on your tax return. The only exception is that certain pre-tax deductions, such as employer-sponsored health insurance premiums and flexible spending account contributions, may reduce your FICA-taxable wages if they are structured as Section 125 cafeteria plan deductions.
          </p>

          <h2 id="maximize-take-home-pay" class="text-2xl font-bold text-slate-900 dark:text-white">
            Strategies to Maximize Take-Home Pay on {formatted} in {stateName}
          </h2>

          <p>
            Maximizing your take-home pay on a {formatted} salary in {stateName} requires a thoughtful approach to pre-tax deductions, retirement contributions, and tax-advantaged accounts. The most impactful strategy for most W-2 employees is contributing to a traditional 401(k) or 403(b) plan, which reduces your federal taxable income dollar for dollar. In {TAX_YEAR}, the contribution limit for employees under 50 is $23,500 per year. If you contribute the maximum, your federal taxable income drops from approximately {formatCurrencyRound(Math.max(amount - 15700, 0))} to {formatCurrencyRound(Math.max(amount - 15700 - 23500, 0))}, which {amount > 100000 ? 'could move a significant portion of your income out of a higher tax bracket' : 'reduces the amount of income subject to your highest marginal rate'}. {!isNoTax ? `In ${stateName}, traditional 401(k) contributions also reduce your state taxable income, providing a dual tax benefit that makes each dollar contributed effectively cost less than a dollar of after-tax income.` : `While ${stateName} has no state income tax, the federal tax savings from a traditional 401(k) still make this one of the most powerful tools for increasing your effective take-home pay over time.`}
          </p>

          <p>
            A Health Savings Account is another powerful tool if you are enrolled in a high-deductible health plan. The {TAX_YEAR} HSA contribution limit is $4,300 for individual coverage and $8,550 for family coverage. HSA contributions reduce your federal taxable income, and in most states including {stateName}, they also reduce your state taxable income. Beyond the immediate tax savings, HSA funds grow tax-free and can be withdrawn tax-free for qualified medical expenses at any time, making the HSA a uniquely triple-tax-advantaged account. For a {formatted} earner in {stateName}, combining a maximum 401(k) contribution with a maximum HSA contribution could reduce your taxable income by over {formatCurrencyRound(23500 + 4300)}, producing substantial tax savings while simultaneously building retirement and healthcare reserves.
          </p>

          {amount <= 75000 && (
            <p>
              At the {formatted} income level, you may also qualify for the Saver's Credit, which provides a tax credit of up to $1,000 for single filers (or $2,000 for married filing jointly) who contribute to a retirement account. This credit directly reduces your federal tax bill rather than just reducing taxable income, making it especially valuable for workers in your income range. Additionally, if you have dependent children, the Child Tax Credit and the Earned Income Tax Credit may further reduce your federal tax liability. These credits, combined with strategic use of pre-tax deductions, can meaningfully increase the portion of your {formatted} salary that arrives in your bank account each pay period.
            </p>
          )}

          {amount > 75000 && (
            <p>
              At the {formatted} income level in {stateName}, you should also consider the timing and structure of any additional income sources, such as bonuses, stock compensation, or freelance work. Federal supplemental income is typically withheld at a flat 22 percent rate (or 37 percent for amounts over $1 million), which may differ from your actual marginal rate. If your employer offers a Flexible Spending Account for dependent care or healthcare expenses, contributing to these accounts further reduces your taxable income. For earners at this level, the cumulative effect of maximizing all available pre-tax deductions can reduce your annual tax bill by {formatCurrencyRound(amount * 0.05)} to {formatCurrencyRound(amount * 0.10)}, translating to noticeably higher take-home pay on every paycheck throughout the year.
            </p>
          )}

          <h2 id="compare-across-states" class="text-2xl font-bold text-slate-900 dark:text-white">
            How {formatted} Compares Across States
          </h2>

          <p>
            The amount of take-home pay you receive on a {formatted} salary varies significantly depending on which state you call home. States without an income tax, such as Texas, Florida, Washington, Wyoming, Tennessee, Nevada, South Dakota, Alaska, and New Hampshire, allow workers to keep more of their gross pay, since no state-level withholding is applied to wages. On the other end of the spectrum, states like California, New York, and Oregon impose progressive income tax rates that can claim a meaningful percentage of your earnings at the {formatted} level. {isNoTax ? `Because ${stateName} is one of the states with no income tax, your take-home pay on ${formatted} is among the highest in the nation, all else being equal.` : `In ${stateName}, your state income tax on ${formatted} falls ${stateConfig?.flatRate ? `at a flat rate of ${formatPercent(stateConfig.flatRate * 100)}, which is relatively straightforward to plan around` : `within a progressive bracket system that determines your effective rate based on the full structure of the state's tax code`}.`}
          </p>

          <p>
            To illustrate the impact, consider that a single filer earning {formatted} in a state with no income tax might take home approximately {formatCurrencyRound(amount * 0.82)} to {formatCurrencyRound(amount * 0.85)} per year after federal taxes and FICA. That same {formatted} salary in a high-tax state could yield take-home pay closer to {formatCurrencyRound(amount * 0.70)} to {formatCurrencyRound(amount * 0.75)}, a difference of {formatCurrencyRound(amount * 0.08)} to {formatCurrencyRound(amount * 0.12)} annually. This gap translates to {formatCurrencyRound(amount * 0.08 / 12)} to {formatCurrencyRound(amount * 0.12 / 12)} per month in additional disposable income. Of course, states without income taxes often fund public services through higher property taxes, sales taxes, or excise taxes, so the total tax burden may be closer than the income tax comparison alone suggests. When evaluating whether to live and work in {stateName} versus another state, it is important to consider the full picture of taxation, cost of living, quality of public services, and career opportunities rather than focusing solely on the state income tax rate.
          </p>

          {neighbors.length > 0 && (
            <p>
              Comparing {stateName} to its neighboring states provides additional context for understanding your {formatted} salary. {neighbors.length >= 2 ? `Nearby states like ${neighbors[0].name} and ${neighbors[1].name} each have their own tax structures that may result in more or less take-home pay on the same gross salary.` : `The neighboring state of ${neighbors[0].name} has its own tax structure that may result in different take-home pay on the same gross salary.`} Workers who live near state borders sometimes have the opportunity to choose where they reside based partly on tax considerations, though commuting costs, housing prices, and quality of life should also factor into that decision. If you are considering a move from {stateName} to a neighboring state or vice versa, using the calculator at the top of this page alongside the calculators for those neighboring states will give you a precise comparison of how much of your {formatted} salary you would take home in each location.
            </p>
          )}

        </div>
      </div>
    </section>

    <!-- State tax note -->
    <section class="border-t border-slate-200 px-4 py-16 dark:border-slate-800 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <h2 class="mb-4 text-2xl font-bold text-slate-900 dark:text-white">
          {stateName} Taxes on a {formatted} Salary
        </h2>
        <div class="prose prose-slate dark:prose-invert max-w-none">
          <p>{stateTaxNote}</p>
          <p>
            In addition to {isNoTax ? 'federal income tax' : 'federal and state income tax'}, you'll pay FICA taxes:
            Social Security at 6.2% (up to $176,100 in {TAX_YEAR}) and Medicare at 1.45% on all wages.
            {amount > 200000 ? ' The Additional Medicare Tax of 0.9% applies to wages over $200,000 for single filers.' : ''}
          </p>
        </div>
      </div>
    </section>

    <!-- Paycheck breakdown table -->
    <section class="border-t border-slate-200 bg-slate-50 px-4 py-12 dark:border-slate-800 dark:bg-slate-900 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <h2 class="mb-6 text-xl font-bold text-slate-900 dark:text-white">
          {formatted} Gross Pay by Period
        </h2>
        <div class="overflow-hidden rounded-xl border border-slate-200 dark:border-slate-700">
          <table class="tabular-nums w-full text-sm">
            <thead>
              <tr class="border-b border-slate-200 bg-slate-50 dark:border-slate-700 dark:bg-slate-800/50">
                <th class="px-4 py-3 text-left font-medium text-slate-600 dark:text-slate-400">Pay Period</th>
                <th class="px-4 py-3 text-right font-medium text-slate-600 dark:text-slate-400">Gross Pay</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
              <tr>
                <td class="px-4 py-2.5 text-slate-700 dark:text-slate-300">Annual</td>
                <td class="px-4 py-2.5 text-right font-medium text-slate-900 dark:text-white">{formatted}</td>
              </tr>
              <tr>
                <td class="px-4 py-2.5 text-slate-700 dark:text-slate-300">Monthly</td>
                <td class="px-4 py-2.5 text-right font-medium text-slate-900 dark:text-white">{formatCurrencyRound(amount / 12)}</td>
              </tr>
              <tr>
                <td class="px-4 py-2.5 text-slate-700 dark:text-slate-300">Bi-Weekly</td>
                <td class="px-4 py-2.5 text-right font-medium text-slate-900 dark:text-white">{formatCurrencyRound(amount / 26)}</td>
              </tr>
              <tr>
                <td class="px-4 py-2.5 text-slate-700 dark:text-slate-300">Weekly</td>
                <td class="px-4 py-2.5 text-right font-medium text-slate-900 dark:text-white">{formatCurrencyRound(amount / 52)}</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- Compare with neighboring states -->
    {neighbors.length > 0 && (
      <section class="border-t border-slate-200 px-4 py-12 dark:border-slate-800 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-3xl">
          <h2 class="mb-6 text-xl font-bold text-slate-900 dark:text-white">
            Compare {formatted} in Neighboring States
          </h2>
          <div class="grid grid-cols-2 gap-3 sm:grid-cols-4">
            {neighbors.map((n) => (
              <a
                href={TOP_10_STATES.includes(n.code)
                  ? `/${n.slug}/${amount}-after-taxes/`
                  : `/paycheck-calculator/${n.slug}/`}
                class="rounded-lg border border-slate-200 bg-white p-4 text-center transition-all hover:border-navy-300 hover:shadow-md dark:border-slate-700 dark:bg-slate-800 dark:hover:border-navy-600"
              >
                <span class="block font-semibold text-navy-700 dark:text-navy-400">{n.name}</span>
                <span class="mt-1 block text-xs text-slate-500 dark:text-slate-400">
                  {NO_INCOME_TAX_STATES.includes(n.code) ? 'No income tax' : 'View calculator'}
                </span>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Other salary amounts in this state -->
    <section class="border-t border-slate-200 bg-slate-50 px-4 py-12 dark:border-slate-800 dark:bg-slate-900 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <h2 class="mb-6 text-xl font-bold text-slate-900 dark:text-white">
          Other Salaries in {stateName}
        </h2>
        <div class="grid grid-cols-3 gap-2 sm:grid-cols-4">
          {otherAmounts.map((a) => (
            <a
              href={`/${stateSlug}/${a}-after-taxes/`}
              class="rounded-lg border border-slate-200 bg-white px-3 py-2 text-center text-sm transition-colors hover:border-navy-300 dark:border-slate-700 dark:bg-slate-800 dark:hover:border-navy-600"
            >
              <span class="tabular-nums font-semibold text-navy-700 dark:text-navy-400">
                {formatCurrencyRound(a)}
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Same amount in other top states -->
    <section class="border-t border-slate-200 px-4 py-12 dark:border-slate-800 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <h2 class="mb-6 text-xl font-bold text-slate-900 dark:text-white">
          {formatted} After Taxes in Other States
        </h2>
        <div class="grid grid-cols-3 gap-2 sm:grid-cols-3 md:grid-cols-5">
          {otherStates.map((s) => (
            <a
              href={`/${s.slug}/${amount}-after-taxes/`}
              class="rounded-lg border border-slate-200 bg-white px-3 py-2 text-center text-sm transition-colors hover:border-navy-300 dark:border-slate-700 dark:bg-slate-800 dark:hover:border-navy-600"
            >
              <span class="font-semibold text-navy-700 dark:text-navy-400">{s.name}</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  </Fragment>
</CalculatorLayout>
