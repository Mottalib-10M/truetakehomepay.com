---
import Layout from '../layouts/Layout.astro';
import PaycheckCalculator from '../components/calculators/PaycheckCalculator';
import FAQAccordion from '../components/ui/FAQAccordion.astro';
import { TAX_YEAR, DISCLAIMER } from '../lib/constants';
import { getStatesArray, NO_INCOME_TAX_STATES } from '../data/state-meta';

const title = `Paycheck Calculator ${TAX_YEAR}: Federal + State Take-Home Pay`;
const description = `Free ${TAX_YEAR} paycheck calculator. Calculate your net take-home pay after federal and state taxes, FICA, 401(k), and deductions. All 50 US states supported.`;

const states = getStatesArray();

const faqs = [
  {
    question: 'How is my paycheck calculated?',
    answer: `Your paycheck is calculated by starting with your gross (pre-tax) salary, then subtracting federal income tax, state income tax (if applicable), Social Security tax (6.2%), Medicare tax (1.45%), and any pre-tax deductions like 401(k) contributions or health insurance premiums. The remaining amount is your net (take-home) pay.`,
  },
  {
    question: 'What is FICA and why is it on my paycheck?',
    answer: `FICA stands for the Federal Insurance Contributions Act. It funds Social Security (6.2% of wages up to $${(176100).toLocaleString()}) and Medicare (1.45% of all wages). If you earn over $200,000 (single), you also pay an Additional Medicare Tax of 0.9%. FICA is mandatory — you can't opt out, and your employer pays a matching amount.`,
  },
  {
    question: 'Which states have no income tax?',
    answer: `Nine states have no state income tax on wages: Alaska, Florida, Nevada, New Hampshire, South Dakota, Tennessee, Texas, Washington, and Wyoming. If you live in one of these states, your paycheck won't have a state income tax deduction, meaning more take-home pay.`,
  },
  {
    question: 'How does my filing status affect my paycheck?',
    answer: `Your filing status (Single, Married Filing Jointly, Married Filing Separately, or Head of Household) determines your tax brackets and standard deduction. Married Filing Jointly typically results in the lowest tax rate because the brackets are roughly double those of Single filers, and the standard deduction is larger ($31,400 vs $15,700 for ${TAX_YEAR}).`,
  },
  {
    question: 'Does a 401(k) contribution reduce my taxes?',
    answer: `Traditional 401(k) contributions reduce your federal and state income tax because they lower your taxable income. However, they do <strong>not</strong> reduce your FICA taxes (Social Security and Medicare). Roth 401(k) contributions are made after tax, so they don't reduce any taxes now — but withdrawals in retirement are tax-free.`,
  },
  {
    question: `What are the ${TAX_YEAR} federal tax brackets?`,
    answer: `For ${TAX_YEAR}, the federal tax brackets for Single filers are: 10% on income up to $11,925; 12% up to $48,475; 22% up to $103,350; 24% up to $197,300; 32% up to $250,525; 35% up to $626,350; and 37% on income above $626,350. These brackets apply to <em>taxable</em> income (after the standard deduction of $15,700).`,
  },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: `Paycheck Calculator ${TAX_YEAR}`,
  description,
  url: 'https://truetakehomepay.com/',
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'Any',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
  inLanguage: 'en-US',
};
---

<Layout title={title} description={description} schema={schema}>
  <!-- Hero Section -->
  <section class="bg-gradient-to-b from-navy-50 to-white px-4 pb-12 pt-10 dark:from-slate-900 dark:to-slate-950 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="text-center">
        <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl lg:text-5xl dark:text-white">
          Paycheck Calculator {TAX_YEAR}
        </h1>
        <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-600 dark:text-slate-400">
          Calculate your take-home pay after federal and state taxes. Free, accurate, and updated for {TAX_YEAR} tax brackets. All 50 states + DC supported.
        </p>
        <p class="mt-2 text-sm text-slate-500 dark:text-slate-500">
          Updated for tax year {TAX_YEAR} &middot; Bi-weekly pay default &middot; Includes FICA, state tax, 401(k), and more
        </p>
      </div>
    </div>
  </section>

  <!-- Calculator Section -->
  <section class="px-4 pb-16 sm:px-6 lg:px-8" id="calculator">
    <div class="mx-auto max-w-7xl">
      <PaycheckCalculator client:load />
    </div>
  </section>

  <!-- State Links Grid -->
  <section class="border-t border-slate-200 bg-slate-50 px-4 py-16 dark:border-slate-800 dark:bg-slate-900 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <h2 id="calculator-by-state" class="mb-8 text-center text-2xl font-bold text-slate-900 dark:text-white">
        Paycheck Calculator by State
      </h2>
      <div class="grid grid-cols-2 gap-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6">
        {states.map((state) => (
          <a
            href={`/paycheck-calculator/${state.slug}/`}
            class="rounded-lg border border-slate-200 bg-white px-3 py-2 text-center text-sm text-slate-700 transition-colors hover:border-navy-300 hover:bg-navy-50 hover:text-navy-700 dark:border-slate-700 dark:bg-slate-800 dark:text-slate-300 dark:hover:border-navy-600 dark:hover:bg-navy-900/30 dark:hover:text-navy-300"
          >
            <span class="font-medium">{state.name}</span>
            {NO_INCOME_TAX_STATES.includes(state.code) && (
              <span class="ml-1 text-xs text-success-700 dark:text-success-500">No tax</span>
            )}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Popular Salary Amounts -->
  <section class="px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <h2 id="popular-salaries" class="mb-8 text-center text-2xl font-bold text-slate-900 dark:text-white">
        Popular Salary After Taxes
      </h2>
      <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 md:grid-cols-5">
        {[30000, 40000, 50000, 60000, 70000, 75000, 80000, 90000, 100000, 120000, 150000, 200000, 250000, 500000].map((amount) => (
          <a
            href={`/${amount}-after-taxes/`}
            class="rounded-xl border border-slate-200 bg-white p-4 text-center transition-all hover:border-navy-300 hover:shadow-md dark:border-slate-700 dark:bg-slate-800 dark:hover:border-navy-600"
          >
            <span class="tabular-nums text-lg font-bold text-navy-700 dark:text-navy-400">
              ${amount.toLocaleString()}
            </span>
            <span class="mt-1 block text-xs text-slate-500 dark:text-slate-400">after taxes</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- How It's Calculated -->
  <section class="border-t border-slate-200 px-4 py-16 dark:border-slate-800 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl">
      <h2 id="how-paycheck-is-calculated" class="mb-6 text-2xl font-bold text-slate-900 dark:text-white">
        How Your Paycheck Is Calculated
      </h2>
      <div class="prose prose-slate dark:prose-invert max-w-none text-slate-600 dark:text-slate-400">
        <p>
          Your paycheck starts with your gross salary — the total amount your employer pays you before any deductions. From there, several mandatory and optional deductions are subtracted to arrive at your net (take-home) pay.
        </p>

        <h3 id="federal-income-tax">Federal Income Tax</h3>
        <p>
          The US uses a progressive federal income tax system with seven brackets ranging from 10% to 37%. Your filing status (Single, Married Filing Jointly, etc.) determines which brackets apply. Only the income within each bracket is taxed at that rate — not your entire salary. After accounting for the standard deduction ($15,700 for single filers in {TAX_YEAR}), your remaining taxable income flows through each bracket.
        </p>

        <h3 id="fica-taxes">FICA Taxes (Social Security + Medicare)</h3>
        <p>
          FICA taxes are flat-rate payroll taxes. Social Security tax is 6.2% of your wages up to ${(176100).toLocaleString()} (the {TAX_YEAR} wage base). Medicare tax is 1.45% on all wages, with an additional 0.9% on wages above $200,000 for single filers. Your employer pays a matching amount for both.
        </p>

        <h3 id="state-income-tax">State Income Tax</h3>
        <p>
          {NO_INCOME_TAX_STATES.length} states (Alaska, Florida, Nevada, New Hampshire, South Dakota, Tennessee, Texas, Washington, and Wyoming) have no state income tax on wages. The remaining states have either flat rates (like Illinois at 4.95% or Pennsylvania at 3.07%) or progressive bracket systems (like California's 1%-13.3% range). State tax is the biggest variable in your take-home pay depending on where you live.
        </p>

        <h3 id="pre-tax-deductions">Pre-Tax Deductions</h3>
        <p>
          Traditional 401(k) contributions, HSA contributions, and employer-sponsored health insurance premiums are subtracted <em>before</em> taxes are calculated, reducing your taxable income. HSA and FSA contributions also reduce your FICA taxes, while 401(k) contributions only reduce income taxes.
        </p>
      </div>
    </div>
  </section>

  <!-- Understanding Your Paycheck -->
  <section class="border-t border-slate-200 px-4 py-16 dark:border-slate-800 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl">
      <div class="prose prose-slate dark:prose-invert max-w-none text-slate-600 dark:text-slate-400">
        <h2 id="understanding-your-paycheck" class="text-2xl font-bold text-slate-900 dark:text-white">Understanding Your Paycheck in America</h2>
        <p>
          Every two weeks, roughly 150 million American workers receive a paycheck, and a surprising number of them have never taken the time to truly understand what happens between their gross salary and the money that lands in their bank account. The gap between what you earn on paper and what you actually take home is one of the most important financial realities of working life in the United States, yet it remains poorly understood by the very people it affects most. Whether you are a recent college graduate receiving your first real paycheck or a seasoned professional who has been in the workforce for decades, knowing exactly where your money goes before it reaches you is foundational to every financial decision you will ever make.
        </p>
        <p>
          The American payroll system is unlike most countries in the world. Rather than receiving your full salary and paying taxes at the end of the year, the federal government requires employers to withhold estimated taxes from every single paycheck throughout the year. This pay-as-you-go system, which dates back to World War II, means your employer acts as an intermediary between you and the IRS. Your W-4 form tells your employer how much to withhold, and if those withholdings are not calibrated correctly, you could end up owing thousands at tax time or, conversely, giving the government an interest-free loan all year long only to receive it back as a refund.
        </p>

        <h2 id="why-take-home-pay-varies" class="text-2xl font-bold text-slate-900 dark:text-white">Why Take-Home Pay Varies So Much Across the Country</h2>
        <p>
          One of the most striking aspects of the American compensation landscape is how dramatically your take-home pay can differ depending on where you live. Two workers earning identical salaries of $75,000 per year can have vastly different financial realities based purely on geography. A software engineer in Austin, Texas, takes home significantly more than a software engineer earning the same salary in Portland, Oregon, because Texas levies no state income tax while Oregon imposes one of the highest top marginal rates in the nation at 9.9 percent. When you layer in local taxes, which exist in cities like New York, Philadelphia, and dozens of municipalities across Ohio and Pennsylvania, the disparity becomes even more pronounced.
        </p>
        <p>
          This geographic variation in take-home pay is not merely an academic curiosity. It has real consequences for job seekers evaluating offers in different cities, for remote workers choosing where to establish residency, and for families deciding where to put down roots. Our <a href="/take-home-comparison/">take-home comparison tool</a> lets you see these differences side by side, which can be genuinely eye-opening. A $100,000 salary in Nashville, Tennessee, can net you more than a $110,000 salary in Sacramento, California, once you account for state tax differences. Understanding this dynamic is essential for anyone navigating career moves or negotiating compensation packages that span state lines.
        </p>

        <h3 id="hidden-deductions" class="text-xl font-bold text-slate-900 dark:text-white">The Hidden Deductions Most Workers Overlook</h3>
        <p>
          When people think about paycheck deductions, federal and state income taxes immediately come to mind. But for many workers, those are not the largest deductions on their pay stubs. FICA taxes, which fund Social Security and Medicare, consume 7.65 percent of every dollar you earn up to the Social Security wage base, and there is no standard deduction or personal exemption to reduce them. For a worker earning $60,000, that amounts to $4,590 per year just in FICA, and your employer pays an identical amount on top of that. If you are self-employed, you bear the full 15.3 percent burden yourself, which is why our <a href="/self-employment-tax-calculator/">self-employment tax calculator</a> is one of the most visited tools on the site.
        </p>
        <p>
          Beyond taxes, many workers see deductions for employer-sponsored health insurance premiums, which have risen dramatically over the past two decades. The average employee contribution for family coverage now exceeds $6,000 per year, and that amount comes directly out of your paycheck before you ever see it. Dental and vision insurance, life insurance, disability insurance, and flexible spending account contributions can add hundreds more per month in deductions. When workers express frustration that their raise did not seem to change their paycheck much, the answer often lies in these non-tax deductions that quietly consume an increasing share of gross pay each year.
        </p>

        <h2 id="federal-state-tax-interaction" class="text-2xl font-bold text-slate-900 dark:text-white">How Federal and State Taxes Interact</h2>
        <p>
          The relationship between federal and state income taxes is more nuanced than most people realize. These are not simply two separate bites from the same apple. In most states, your state taxable income starts with your federal adjusted gross income and then applies state-specific modifications. This means that contributing to a traditional 401(k) or HSA reduces both your federal and state tax liability simultaneously, creating a powerful double benefit. However, the magnitude of the state-level benefit varies widely. If you live in a state with a flat tax rate of 3 percent, the state tax savings from a $10,000 401(k) contribution is $300. But in California, where top earners face a 13.3 percent marginal rate, that same contribution could save $1,330 in state taxes alone.
        </p>
        <p>
          There is also the matter of the state and local tax (SALT) deduction on your federal return, which was capped at $10,000 by the Tax Cuts and Jobs Act of 2017. Before that cap, high earners in high-tax states could deduct their entire state income tax payment from their federal taxable income, effectively reducing the sting of high state rates. With the cap in place, many residents of states like New York, New Jersey, and California no longer receive a federal offset for their substantial state tax bills, which has materially changed the calculus of living in high-tax states. This interaction between federal and state policy is precisely why our <a href="/income-tax-calculator/">income tax calculator</a> models both levels simultaneously rather than treating them in isolation.
        </p>

        <h3 id="true-compensation" class="text-xl font-bold text-slate-900 dark:text-white">The Importance of Understanding Your True Compensation</h3>
        <p>
          Your paycheck tells only part of the compensation story. Total compensation includes employer contributions to your retirement plan, the employer portion of your health insurance premiums, employer-paid payroll taxes, and any other benefits like tuition reimbursement, stock options, or restricted stock units. For many mid-career professionals, the value of benefits adds 20 to 40 percent on top of their base salary. A worker earning $80,000 in base pay might actually receive $105,000 or more in total compensation once employer 401(k) matching, insurance contributions, and payroll taxes are factored in.
        </p>
        <p>
          This distinction matters enormously when comparing job offers. A position offering $90,000 with no 401(k) match and expensive insurance premiums might actually be less valuable than a position offering $82,000 with a generous match and fully paid health coverage. Our <a href="/salary-calculator/">salary calculator</a> helps you break down annual compensation into meaningful per-paycheck figures, making it easier to understand the real value of each offer you receive. Too many workers focus exclusively on the gross salary number without recognizing that the path from gross pay to net pay is where the actual financial picture comes into focus.
        </p>

        <h2 id="how-tax-brackets-work" class="text-2xl font-bold text-slate-900 dark:text-white">How Tax Brackets Really Work in Practice</h2>
        <p>
          Perhaps no aspect of the American tax system is more widely misunderstood than how marginal tax brackets operate. A persistent myth holds that earning more money can actually leave you worse off because moving into a higher tax bracket means all of your income gets taxed at the higher rate. This is categorically false, and understanding why is essential to making sound financial decisions. The federal income tax system is progressive, meaning each bracket applies only to the income within that bracket's range, not to your entire income.
        </p>
        <p>
          Consider a single filer earning $60,000 in 2025. After the standard deduction of $15,700, their taxable income is $44,300. The first $11,925 is taxed at 10 percent, yielding $1,192.50 in tax. The next $36,550 (from $11,925 to $48,475) is taxed at 12 percent, yielding $4,386. The remaining income does not reach the 22 percent bracket. The total federal income tax is approximately $5,578, which works out to an effective tax rate of about 9.3 percent on gross income, far lower than the 12 percent marginal rate that applies to the last dollar earned. This distinction between marginal and effective tax rates is crucial, and it is one of the core concepts that our paycheck calculator makes tangible by showing you exactly how your income flows through each bracket.
        </p>
        <p>
          The practical implication is that you should never turn down a raise, a bonus, or overtime pay out of fear of "moving into a higher tax bracket." Yes, the additional income will be taxed at a higher marginal rate, but you will always take home more money after taxes when you earn more money before taxes. A $5,000 raise for someone in the 22 percent bracket means roughly $3,900 more in annual take-home pay after federal taxes, not less. Use our <a href="/bonus-tax-calculator/">bonus tax calculator</a> to see exactly how supplemental income is treated.
        </p>

        <h3 id="planning-your-financial-year" class="text-xl font-bold text-slate-900 dark:text-white">Planning Your Financial Year with Accurate Paycheck Knowledge</h3>
        <p>
          Knowing your exact take-home pay is the cornerstone of every meaningful financial plan. You cannot build a realistic budget, set appropriate savings goals, or determine how much house you can afford without first understanding the precise amount that will hit your bank account each pay period. Too many people build financial plans around their gross salary and then find themselves short when the realities of withholding, deductions, and FICA reduce that number by 25 to 35 percent or more.
        </p>
        <p>
          A disciplined approach to financial planning starts with running your paycheck through a calculator like ours at the beginning of each year, especially after any life changes that affect your tax situation. Getting married, having a child, buying a home, or starting a side business can all change your withholding requirements and, consequently, your take-home pay. Similarly, adjusting your 401(k) contribution rate, switching health insurance plans during open enrollment, or contributing to an HSA will all alter the net amount you receive. Our <a href="/401k-calculator/">401(k) calculator</a> and <a href="/hourly-paycheck-calculator/">hourly paycheck calculator</a> provide additional perspectives that complement the core paycheck analysis.
        </p>
        <p>
          The workers who achieve the greatest financial stability are those who treat their paycheck not as a static number but as a dynamic tool that can be optimized. By understanding each component, from federal withholding to state taxes to pre-tax deductions, you gain the ability to make strategic decisions that increase your take-home pay without necessarily increasing your gross salary. Maximizing employer 401(k) matches, choosing the right health plan, contributing to tax-advantaged accounts, and living in a tax-efficient state are all levers that sophisticated earners pull to keep more of what they make. Our <a href="/paycheck-calculator/">state-by-state paycheck calculator</a> is designed to make these comparisons easy and actionable for every American worker.
        </p>
      </div>
    </div>
  </section>

  <!-- FAQs -->
  <section class="border-t border-slate-200 px-4 py-16 dark:border-slate-800 sm:px-6 lg:px-8">
    <FAQAccordion faqs={faqs} />
  </section>

  <!-- Related Calculators -->
  <section class="border-t border-slate-200 bg-slate-50 px-4 py-16 dark:border-slate-800 dark:bg-slate-900 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <h2 id="related-calculators" class="mb-8 text-center text-2xl font-bold text-slate-900 dark:text-white">
        Related Calculators
      </h2>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {[
          { title: 'Salary Calculator', href: '/salary-calculator/', desc: 'Annual salary breakdown' },
          { title: 'Hourly Pay Calculator', href: '/hourly-paycheck-calculator/', desc: 'Convert hourly rate to annual' },
          { title: 'Income Tax Calculator', href: '/income-tax-calculator/', desc: 'Federal + state tax estimate' },
          { title: '401(k) Calculator', href: '/401k-calculator/', desc: 'Retirement savings projection' },
          { title: 'Self-Employment Tax', href: '/self-employment-tax-calculator/', desc: '1099 / freelancer tax' },
          { title: 'Bonus Tax Calculator', href: '/bonus-tax-calculator/', desc: 'Bonus withholding estimate' },
          { title: 'Take-Home Comparison', href: '/take-home-comparison/', desc: 'Compare states side-by-side' },
          { title: 'Mortgage Calculator', href: '/mortgage-calculator/', desc: 'Monthly payment estimator' },
        ].map((calc) => (
          <a
            href={calc.href}
            class="rounded-xl border border-slate-200 bg-white p-5 transition-all hover:border-navy-300 hover:shadow-md dark:border-slate-700 dark:bg-slate-800 dark:hover:border-navy-600"
          >
            <h3 class="font-semibold text-navy-700 dark:text-navy-400">{calc.title}</h3>
            <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">{calc.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Sources -->
  <section class="border-t border-slate-200 px-4 py-8 dark:border-slate-800 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl">
      <p class="text-xs text-slate-500 dark:text-slate-400">
        <strong>Sources:</strong> IRS Rev. Proc. 2025-11 (federal brackets), SSA.gov (Social Security wage base), individual state revenue departments (state tax rates). Last updated for tax year {TAX_YEAR}.
      </p>
      <p class="mt-2 text-xs text-slate-500 dark:text-slate-400">
        {DISCLAIMER}
      </p>
    </div>
  </section>
</Layout>
