---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import PayrollTaxCalculator from '../components/calculators/PayrollTaxCalculator';
import { TAX_YEAR } from '../lib/constants';

const title = `Payroll Tax Calculator ${TAX_YEAR}: FICA & SS Medicare Tax`;
const description = `Calculate your ${TAX_YEAR} payroll taxes: Social Security (6.2%), Medicare (1.45%), and Additional Medicare Tax (0.9%). See employee and employer FICA contributions.`;

const faqs = [
  {
    question: 'What are payroll taxes and how much do they cost?',
    answer: `Payroll taxes (FICA) fund Social Security and Medicare. Employees pay 7.65% of gross wages: 6.2% for Social Security (up to the $176,100 wage base in ${TAX_YEAR}) and 1.45% for Medicare (no cap). Employers match this amount, for a combined 15.3%. High earners also pay a 0.9% Additional Medicare Tax on wages above $200,000 (single) or $250,000 (married filing jointly).`,
  },
  {
    question: `What is the Social Security wage base for ${TAX_YEAR}?`,
    answer: `The Social Security taxable wage base for ${TAX_YEAR} is $176,100. You only pay the 6.2% Social Security tax on earnings up to this amount. Once your year-to-date earnings exceed $176,100, Social Security tax stops — your paychecks get bigger for the rest of the year. Medicare has no wage base limit; all earnings are subject to the 1.45% tax.`,
  },
  {
    question: 'What is the difference between payroll tax and income tax?',
    answer: `Payroll taxes (FICA) are flat-rate taxes that fund Social Security and Medicare — everyone pays the same percentage regardless of income (up to the wage base). Income tax uses progressive brackets where higher earners pay higher rates. Payroll taxes are withheld separately from income tax. You cannot reduce payroll taxes with deductions, unlike income tax.`,
  },
  {
    question: 'Do employers pay payroll taxes too?',
    answer: `Yes. Employers pay a matching 7.65% FICA tax on each employee's wages (6.2% Social Security + 1.45% Medicare). Employers also pay Federal Unemployment Tax (FUTA) of 6% on the first $7,000 per employee (usually reduced to 0.6% with state credits) and State Unemployment Tax (SUTA) at varying rates. The employer's cost is roughly 8-10% above your salary.`,
  },
];

const relatedCalculators = [
  { title: 'Paycheck Calculator', href: '/', desc: 'Full paycheck breakdown' },
  { title: 'Self-Employment Tax', href: '/self-employment-tax-calculator/', desc: 'SE tax at 15.3%' },
  { title: 'Social Security Tax', href: '/social-security-tax-calculator/', desc: 'SS wage base analysis' },
  { title: 'Medicare Surtax', href: '/medicare-surtax-calculator/', desc: 'Additional Medicare Tax' },
  { title: 'Income Tax Calculator', href: '/income-tax-calculator/', desc: 'Federal + state taxes' },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: `Payroll Tax Calculator ${TAX_YEAR}`,
  description,
  url: 'https://truetakehomepay.com/payroll-tax-calculator',
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'Any',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  inLanguage: 'en-US',
};
---

<CalculatorLayout
  title={title}
  description={description}
  h1={`Payroll Tax Calculator ${TAX_YEAR}`}
  intro={`Calculate your FICA payroll taxes for ${TAX_YEAR}: Social Security (6.2%), Medicare (1.45%), and the Additional Medicare Tax (0.9%). See both employee and employer contributions and understand when Social Security tax stops.`}
  faqs={faqs}
  relatedCalculators={relatedCalculators}
  schema={schema}
  sources={`SSA.gov (${TAX_YEAR} wage base and FICA rates), IRS Publication 15 (Employer's Tax Guide), IRS Publication 15-T (Federal Income Tax Withholding Methods), IRC Section 3101-3128. Last updated for tax year ${TAX_YEAR}.`}
>
  <PayrollTaxCalculator client:load />
</CalculatorLayout>
