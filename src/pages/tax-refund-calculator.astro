---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import PaycheckCalculator from '../components/calculators/PaycheckCalculator';
import { TAX_YEAR } from '../lib/constants';

const title = `Tax Refund Calculator ${TAX_YEAR}: Estimate Your IRS Refund`;
const description = `Estimate your ${TAX_YEAR} federal tax refund or amount owed. Enter your income, withholdings, and deductions to see if you'll get money back from the IRS.`;

const faqs = [
  {
    question: 'How is my tax refund calculated?',
    answer: `Your refund equals the total tax you've already paid (through paycheck withholdings and estimated payments) minus your actual tax liability. If you've overpaid, you get a refund. If you've underpaid, you owe the IRS the difference.`,
  },
  {
    question: 'When will I receive my IRS refund?',
    answer: `Most e-filed returns with direct deposit are processed within 21 days. Paper returns can take 6-8 weeks. You can track your refund status using the IRS "Where's My Refund?" tool at irs.gov/refunds.`,
  },
  {
    question: 'Why is my refund smaller than last year?',
    answer: `Common reasons include: your income increased and pushed you into a higher bracket, you had fewer withholdings, tax credits you claimed last year expired, or your filing status changed. Changes in the standard deduction amount year-over-year can also affect your refund.`,
  },
  {
    question: 'Should I aim for a large refund or break-even?',
    answer: `Financial experts generally recommend adjusting your W-4 withholdings so you break even or get a small refund. A large refund means you've been giving the IRS an interest-free loan all year. That money could have been earning interest in a savings account or invested instead.`,
  },
];

const relatedCalculators = [
  { title: 'Paycheck Calculator', href: '/', desc: 'Calculate take-home pay' },
  { title: 'Income Tax Calculator', href: '/income-tax-calculator', desc: 'Federal + state tax estimate' },
  { title: 'Capital Gains Tax', href: '/capital-gains-tax-calculator', desc: 'Investment tax estimate' },
  { title: 'Self-Employment Tax', href: '/self-employment-tax-calculator', desc: '1099 / freelancer tax' },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: `Tax Refund Calculator ${TAX_YEAR}`,
  description,
  url: 'https://uspaycheck.com/tax-refund-calculator',
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'Any',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  inLanguage: 'en-US',
};
---

<CalculatorLayout
  title={title}
  description={description}
  h1={`Tax Refund Calculator ${TAX_YEAR}`}
  intro={`Estimate your federal tax refund or balance due for ${TAX_YEAR}. Enter your income, withholdings, credits, and deductions to see whether the IRS owes you money or you owe them.`}
  faqs={faqs}
  relatedCalculators={relatedCalculators}
  schema={schema}
  sources={`IRS Rev. Proc. 2025-11 (${TAX_YEAR} federal brackets and standard deductions), IRS Publication 17, IRS.gov/refunds. Last updated for tax year ${TAX_YEAR}.`}
>
  <PaycheckCalculator client:load />
</CalculatorLayout>
