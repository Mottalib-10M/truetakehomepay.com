---
import Layout from '../layouts/Layout.astro';
import { SITE_NAME, SITE_URL } from '../lib/constants';

const title = 'Free Paycheck Calculator Widget for Your Website';
const description = `Embed the ${SITE_NAME} paycheck calculator on your website for free. Copy the embed code and give your visitors an instant take-home pay calculator.`;

const embedCode = `<iframe
  src="${SITE_URL}/embed/"
  width="100%"
  height="700"
  style="border:none;max-width:800px;"
  loading="lazy"
  title="Paycheck Calculator — ${SITE_NAME}"
  allow="clipboard-write"
></iframe>`;
---

<Layout title={title} description={description} noIndex={true}>
  <section class="bg-gradient-to-b from-navy-50 to-white px-4 pb-8 pt-10 dark:from-slate-900 dark:to-slate-950 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl text-center">
      <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl dark:text-white">
        Free Paycheck Calculator Widget
      </h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-600 dark:text-slate-400">
        Add a professional paycheck calculator to your website, blog, or HR portal. Free, no sign-up required.
      </p>
    </div>
  </section>

  <section class="px-4 pb-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl">

      <!-- Embed code -->
      <div class="rounded-xl border border-slate-200 bg-white p-6 dark:border-slate-700 dark:bg-slate-800">
        <h2 class="text-lg font-semibold text-slate-900 dark:text-white">Embed Code</h2>
        <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">
          Copy and paste this code into your website's HTML where you want the calculator to appear.
        </p>
        <div class="relative mt-4">
          <pre class="overflow-x-auto rounded-lg bg-slate-900 p-4 text-sm text-green-400"><code>{embedCode}</code></pre>
          <button
            id="copy-embed"
            class="absolute right-2 top-2 rounded-lg bg-slate-700 px-3 py-1.5 text-xs font-medium text-white transition-colors hover:bg-slate-600"
            data-code={embedCode}
          >
            Copy
          </button>
        </div>
      </div>

      <!-- Features -->
      <div class="mt-10 grid gap-6 sm:grid-cols-3">
        <div class="rounded-xl border border-slate-200 p-5 dark:border-slate-700">
          <h3 class="font-semibold text-slate-900 dark:text-white">Responsive</h3>
          <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">
            Adapts to any container width. Works on desktop, tablet, and mobile.
          </p>
        </div>
        <div class="rounded-xl border border-slate-200 p-5 dark:border-slate-700">
          <h3 class="font-semibold text-slate-900 dark:text-white">Always Updated</h3>
          <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">
            Tax rates update automatically. No maintenance required on your end.
          </p>
        </div>
        <div class="rounded-xl border border-slate-200 p-5 dark:border-slate-700">
          <h3 class="font-semibold text-slate-900 dark:text-white">Privacy-First</h3>
          <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">
            All calculations run in the browser. No user data is collected or transmitted.
          </p>
        </div>
      </div>

      <!-- Preview -->
      <div class="mt-10">
        <h2 class="mb-4 text-lg font-semibold text-slate-900 dark:text-white">Live Preview</h2>
        <div class="overflow-hidden rounded-xl border border-slate-200 dark:border-slate-700">
          <iframe
            src="/embed/"
            width="100%"
            height="700"
            style="border:none;"
            loading="lazy"
            title="Paycheck Calculator Widget Preview"
          ></iframe>
        </div>
      </div>

      <!-- Terms -->
      <div class="mt-8 rounded-lg bg-slate-50 p-4 dark:bg-slate-900">
        <p class="text-xs text-slate-500 dark:text-slate-400">
          By embedding this widget you agree to our <a href="/terms-of-service/" class="text-navy-600 underline dark:text-navy-400">Terms of Service</a>.
          The "Powered by {SITE_NAME}" attribution must remain visible. For custom integrations, contact
          <a href="mailto:contact@truetakehomepay.com" class="text-navy-600 underline dark:text-navy-400">contact@truetakehomepay.com</a>.
        </p>
      </div>
    </div>
  </section>
</Layout>

<script>
  const btn = document.getElementById('copy-embed');
  btn?.addEventListener('click', async () => {
    const code = btn.getAttribute('data-code') || '';
    await navigator.clipboard.writeText(code);
    btn.textContent = 'Copied!';
    setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
  });
</script>
