---
import Layout from '../../layouts/Layout.astro';
import { TAX_YEAR } from '../../lib/constants';

const title = `Tax & Finance Guides ${TAX_YEAR}: How US Taxes Work`;
const description = `Comprehensive guides to understanding US taxes, paychecks, retirement accounts, and personal finance. Updated for ${TAX_YEAR}.`;

const guides = [
  {
    title: 'How Paychecks Work in the US',
    href: '/guides/how-paychecks-work-in-the-us',
    desc: 'A complete breakdown of every deduction on your pay stub, from federal tax to FICA to 401(k).',
    category: 'Basics',
  },
  {
    title: `Federal Tax Brackets ${TAX_YEAR}`,
    href: '/guides/federal-tax-brackets-2026',
    desc: 'The seven federal income tax brackets for all filing statuses, with examples and effective rate calculations.',
    category: 'Federal Tax',
  },
  {
    title: 'State Tax Comparison',
    href: '/guides/state-tax-comparison',
    desc: 'Compare income tax rates across all 50 states. See which states have no tax, flat tax, and the highest rates.',
    category: 'State Tax',
  },
  {
    title: '401(k) vs Roth IRA',
    href: '/guides/401k-vs-roth-ira',
    desc: 'Traditional 401(k) vs Roth IRA: tax treatment, contribution limits, employer match, and which is right for you.',
    category: 'Retirement',
  },
  {
    title: 'W-4 Form Explained',
    href: '/guides/w-4-explained',
    desc: 'How to fill out the post-2020 W-4 form correctly. Steps 1-4, dependents, multiple jobs, and common mistakes.',
    category: 'Federal Tax',
  },
  {
    title: 'Self-Employment Tax Explained',
    href: '/guides/self-employment-tax-explained',
    desc: '1099 workers and freelancers: how SE tax works, the 15.3% rate, quarterly payments, and deductions.',
    category: 'Self-Employment',
  },
  {
    title: 'Moving to a No-Income-Tax State',
    href: '/guides/moving-to-a-no-income-tax-state',
    desc: 'Is moving to Texas, Florida, or another no-tax state worth it? Total tax burden analysis beyond income tax.',
    category: 'State Tax',
  },
  {
    title: `Maximum 401(k) Contribution ${TAX_YEAR}`,
    href: '/guides/maximum-401k-contribution-2026',
    desc: 'Contribution limits for 401(k), 403(b), and 457(b) plans. Employee, employer, and catch-up limits.',
    category: 'Retirement',
  },
  {
    title: 'Understanding Property Tax',
    href: '/guides/understanding-property-tax',
    desc: 'How property tax is calculated, assessment ratios, homestead exemptions, and appealing your assessment.',
    category: 'Property Tax',
  },
  {
    title: 'Sales Tax Explained',
    href: '/guides/sales-tax-explained',
    desc: 'State and local sales tax rates, exemptions for groceries and clothing, and sales tax holidays.',
    category: 'Sales Tax',
  },
  {
    title: 'Tax Deductions vs Credits',
    href: '/guides/tax-deductions-vs-credits',
    desc: 'The fundamental difference between deductions and credits, and why a $1,000 credit is worth more than a $1,000 deduction.',
    category: 'Federal Tax',
  },
  {
    title: `Tax Season Checklist ${TAX_YEAR}`,
    href: '/guides/tax-season-checklist-2026',
    desc: 'Everything you need to file your taxes: documents, deadlines, common deductions, and step-by-step preparation.',
    category: 'Tax Season',
  },
];
---

<Layout title={title} description={description}>
  <section class="bg-gradient-to-b from-navy-50 to-white px-4 pb-12 pt-10 dark:from-slate-900 dark:to-slate-950 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl text-center">
      <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl dark:text-white">
        Tax &amp; Finance Guides
      </h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-600 dark:text-slate-400">
        Clear, practical guides to understanding US taxes, paychecks, and personal finance. No jargon, no fluff.
      </p>
    </div>
  </section>

  <section class="px-4 pb-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl">
      <div class="grid gap-6 sm:grid-cols-2">
        {guides.map((guide) => (
          <a
            href={guide.href}
            class="group rounded-xl border border-slate-200 bg-white p-6 transition-all hover:border-navy-300 hover:shadow-md dark:border-slate-700 dark:bg-slate-800 dark:hover:border-navy-600"
          >
            <span class="inline-block rounded-full bg-navy-50 px-3 py-1 text-xs font-medium text-navy-700 dark:bg-navy-900/30 dark:text-navy-300">
              {guide.category}
            </span>
            <h2 class="mt-3 text-lg font-semibold text-slate-900 group-hover:text-navy-700 dark:text-white dark:group-hover:text-navy-400">
              {guide.title}
            </h2>
            <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">
              {guide.desc}
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
