---
import Layout from '../../layouts/Layout.astro';
import { TAX_YEAR, SITE_NAME } from '../../lib/constants';

const title = `How Paychecks Work in the US: Every Deduction Explained`;
const description = `Understand every line on your pay stub. Learn how federal tax, FICA, state tax, 401(k), and other common deductions reduce your gross pay to take-home pay.`;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  author: { '@type': 'Organization', name: SITE_NAME },
  publisher: { '@type': 'Organization', name: SITE_NAME },
  datePublished: '2026-01-01',
  dateModified: '2026-01-15',
