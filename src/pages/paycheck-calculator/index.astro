---
import Layout from '../../layouts/Layout.astro';
import { TAX_YEAR } from '../../lib/constants';
import { STATES, NO_INCOME_TAX_STATES } from '../../data/state-meta';

const title = `Paycheck Calculator by State ${TAX_YEAR}: All 50 States + DC`;
const description = `Choose your state and instantly calculate your ${TAX_YEAR} paycheck. See net pay after federal and state taxes, FICA, and 401(k) for all 50 states and Washington DC.`;

const stateEntries = Object.entries(STATES)
  .map(([code, s]) => ({ code, ...s }))
  .sort((a, b) => a.name.localeCompare(b.name));

const noTaxStates = stateEntries.filter((s) => NO_INCOME_TAX_STATES.includes(s.code));
const taxStates = stateEntries.filter((s) => !NO_INCOME_TAX_STATES.includes(s.code));

const faqs = [
  {
    question: 'Which states have no income tax?',
    answer: `Nine states have no state income tax on wages: Alaska, Florida, Nevada, New Hampshire, South Dakota, Tennessee, Texas, Washington, and Wyoming. Residents in these states keep more of their paycheck since only federal taxes and FICA apply.`,
  },
  {
    question: 'How does state tax affect my paycheck?',
    answer: `State income tax is deducted from your paycheck in addition to federal income tax and FICA. Rates vary widely — from 0% in no-tax states to over 13% in California's top bracket. Your filing status, income level, and state of residence all determine how much is withheld.`,
  },
  {
    question: 'Can I use this calculator if I work in a different state than I live?',
    answer: `This calculator estimates taxes based on your state of residence. If you work in a different state, you may owe taxes to both states, though most states offer credits for taxes paid to other states. Some states have reciprocity agreements that simplify this.`,
  },
  {
    question: `What are the ${TAX_YEAR} federal tax brackets?`,
    answer: `For ${TAX_YEAR}, the federal tax brackets for Single filers are: 10% up to $11,925; 12% up to $48,475; 22% up to $103,350; 24% up to $197,300; 32% up to $250,525; 35% up to $626,350; and 37% above $626,350. These apply to taxable income after the standard deduction.`,
  },
];
---

<Layout title={title} description={description}>
  <!-- Hero -->
  <section class="bg-gradient-to-b from-navy-50 to-white px-4 pb-8 pt-10 dark:from-slate-900 dark:to-slate-950 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl text-center">
      <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl dark:text-white">
        Paycheck Calculator by State {TAX_YEAR}
      </h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-600 dark:text-slate-400">
        Select your state to calculate your take-home pay after federal and state taxes, Social Security, Medicare, and deductions.
      </p>
    </div>
  </section>

  <!-- No income tax states -->
  <section class="px-4 py-12 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <h2 id="no-income-tax-states" class="mb-4 text-xl font-bold text-slate-900 dark:text-white">
        No Income Tax States
      </h2>
      <p class="mb-6 text-sm text-slate-600 dark:text-slate-400">
        These states don't levy a state income tax on wages, meaning higher take-home pay.
      </p>
      <div class="grid gap-3 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
        {noTaxStates.map((s) => (
          <a
            href={`/paycheck-calculator/${s.slug}/`}
            class="flex items-center justify-between rounded-lg border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm font-medium text-emerald-800 transition hover:border-emerald-400 hover:bg-emerald-100 dark:border-emerald-800 dark:bg-emerald-900/20 dark:text-emerald-300 dark:hover:border-emerald-600 dark:hover:bg-emerald-900/40"
          >
            {s.name}
            <span class="text-xs text-emerald-600 dark:text-emerald-400">0% state tax</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- All states grid -->
  <section class="px-4 py-12 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <h2 id="all-states" class="mb-4 text-xl font-bold text-slate-900 dark:text-white">
        All States &amp; DC
      </h2>
      <p class="mb-6 text-sm text-slate-600 dark:text-slate-400">
        Choose your state to see a detailed paycheck breakdown with federal and state tax withholdings.
      </p>
      <div class="grid gap-3 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
        {stateEntries.map((s) => (
          <a
            href={`/paycheck-calculator/${s.slug}/`}
            class="rounded-lg border border-slate-200 bg-white px-4 py-3 text-sm font-medium text-slate-700 transition hover:border-navy-300 hover:bg-navy-50 hover:text-navy-700 dark:border-slate-700 dark:bg-slate-800 dark:text-slate-300 dark:hover:border-navy-600 dark:hover:bg-slate-700 dark:hover:text-navy-400"
          >
            {s.name}
            {NO_INCOME_TAX_STATES.includes(s.code) && (
              <span class="ml-1 text-xs text-emerald-600 dark:text-emerald-400">(no state tax)</span>
            )}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Understanding Paycheck Calculations by State -->
  <section class="border-t border-slate-200 px-4 py-16 dark:border-slate-800 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl">
      <div class="prose prose-slate dark:prose-invert max-w-none text-slate-600 dark:text-slate-400">
        <h2 id="why-calculations-differ-by-state" class="text-2xl font-bold text-slate-900 dark:text-white">Why Paycheck Calculations Differ by State</h2>
        <p>
          The United States is unique among developed nations in the degree to which subnational tax policy shapes the financial lives of its residents. While every American worker faces the same federal income tax brackets and identical FICA obligations, the state-level layer of taxation introduces enormous variability into the take-home pay equation. This is not a minor footnote in personal finance. For a worker earning $85,000 per year, the difference between living in a high-tax state and a no-tax state can amount to $4,000, $5,000, or even $7,000 per year in additional take-home pay. Over the course of a career, that disparity compounds into six figures of accumulated wealth difference, making state tax policy one of the most consequential factors in long-term financial outcomes.
        </p>
        <p>
          Each state has its own department of revenue, its own set of brackets or flat rates, its own standard deductions and personal exemptions, and its own rules about what income qualifies for taxation. Some states conform closely to the federal tax code, using federal adjusted gross income as the starting point for state calculations. Others depart significantly, adding back certain federal deductions or offering unique credits that have no federal equivalent. This patchwork means that a <a href="/">paycheck calculator</a> must account for 50 distinct tax systems plus the District of Columbia, each with its own rules that change every year.
        </p>

        <h2 id="no-income-tax-states" class="text-2xl font-bold text-slate-900 dark:text-white">The Nine No-Income-Tax States and What They Trade For</h2>
        <p>
          Alaska, Florida, Nevada, New Hampshire, South Dakota, Tennessee, Texas, Washington, and Wyoming make up the exclusive club of states that impose no income tax on wages. For workers who relocate to or already reside in these states, the benefit is straightforward and immediate: every paycheck is larger because there is simply no state income tax line item to reduce it. A single filer earning $100,000 in Texas keeps roughly $4,000 to $5,000 more per year compared to the same worker in a state with moderate income tax rates like Virginia or Georgia.
        </p>
        <p>
          However, calling these states "tax-free" would be misleading. Governments need revenue to fund schools, roads, public safety, and infrastructure, and states without income taxes must generate that revenue through other mechanisms. Texas, for instance, relies heavily on property taxes and has some of the highest property tax rates in the nation, with effective rates often exceeding 2 percent of a home's assessed value. Washington state imposes a sales tax that can reach nearly 10.5 percent in some municipalities when local additions are included. Nevada funds its government through gaming taxes, sales taxes, and a commerce tax on businesses. Florida leans on tourism-related taxes and a 6 percent state sales tax. New Hampshire, while technically on the no-income-tax list for wages, does tax interest and dividend income at 3 percent (though this is being phased out) and has notably high property taxes.
        </p>
        <p>
          The question of whether a no-income-tax state truly saves you money depends on your individual circumstances. A high-earning renter in Texas will almost certainly pay less in total taxes than the same worker in California. But a homeowner in Texas with a $500,000 property might face $12,000 or more in annual property taxes, which can offset much or all of the income tax savings. Our <a href="/take-home-comparison/">state-by-state comparison tool</a> focuses on income and payroll taxes, but it is worth remembering that the full tax picture includes property, sales, and excise taxes as well.
        </p>

        <h3 id="flat-vs-progressive-state-taxes" class="text-xl font-bold text-slate-900 dark:text-white">How State Tax Structures Affect Workers Differently</h3>
        <p>
          Among the 41 states (plus DC) that do levy an income tax, the structural approach varies considerably. Thirteen states use a flat tax rate, meaning every dollar of taxable income is taxed at the same percentage regardless of how much you earn. Illinois charges a flat 4.95 percent, Pennsylvania imposes 3.07 percent, and Colorado applies 4.25 percent. Flat tax states offer simplicity and predictability: your marginal rate equals your effective rate, and calculating your state tax liability is straightforward.
        </p>
        <p>
          The remaining states with income taxes use progressive bracket systems, similar in concept to the federal system but with widely varying structures. Some states, like Hawaii, have as many as twelve brackets with a top rate of 11 percent. Others, like New Jersey, have a steep top bracket of 10.75 percent that kicks in at relatively modest income levels. California stands alone with its 13.3 percent top rate, the highest state income tax rate in the nation, which applies to income above $1 million. At the other end of the spectrum, states like North Dakota and Arizona have progressive systems with very low rates, maxing out at just 2.5 percent or less.
        </p>
        <p>
          The practical effect of these different structures is significant. In a flat-tax state, a worker earning $40,000 pays the same rate as a worker earning $400,000. In a progressive state, the higher earner faces a substantially higher marginal rate. This means flat-tax states tend to be relatively more favorable to high earners, while progressive states distribute the tax burden more heavily toward upper-income residents. For workers evaluating job offers across state lines, understanding whether a state uses a flat or progressive system is essential to estimating their true take-home pay. Each of our <a href="/paycheck-calculator/">state paycheck calculator pages</a> reflects the exact bracket structure and rates for that state, so you get a precise estimate rather than a rough approximation.
        </p>

        <h2 id="local-taxes-role" class="text-2xl font-bold text-slate-900 dark:text-white">The Role of Local Taxes in Some States</h2>
        <p>
          Adding another layer of complexity, some states allow cities and counties to impose their own income taxes on top of state taxes. New York City is the most prominent example, levying an additional income tax that ranges from 3.078 percent to 3.876 percent depending on income, which is on top of New York State's already substantial progressive tax that reaches 10.9 percent at the top. A high-earning New York City resident can face combined state and local income taxes exceeding 14 percent, plus the 3.8 percent Net Investment Income Tax on certain types of income, creating one of the heaviest tax burdens in the country.
        </p>
        <p>
          Ohio is another state with widespread municipal income taxes. Hundreds of Ohio cities levy their own income tax, typically ranging from 1 percent to 3 percent. Cleveland, Columbus, Cincinnati, and many smaller cities all have their own rates, and if you live in one city but work in another, you may owe taxes to both municipalities, though credit systems usually prevent true double taxation. Pennsylvania has a similar system of local earned income taxes that vary by municipality. Maryland imposes county-level income taxes that range from roughly 2.25 percent to 3.2 percent depending on which county you reside in, making your exact Maryland address a significant factor in your take-home pay calculation.
        </p>
        <p>
          For workers in states with local income taxes, the headline state rate tells only part of the story. A worker in Ohio might see a state income tax rate of 3.5 percent and assume that is their full state-level burden, only to discover that their city adds another 2.5 percent on top. When evaluating jobs or residences in these states, it is critical to research local tax obligations alongside state rates. Our state-specific calculators incorporate the most common local taxes where applicable, but workers in heavily localized tax states should verify their specific municipality's rate.
        </p>

        <h3 id="reading-your-pay-stub" class="text-xl font-bold text-slate-900 dark:text-white">How to Read and Understand Your Pay Stub</h3>
        <p>
          A pay stub is one of the most information-dense financial documents you receive on a regular basis, yet many workers give it nothing more than a cursory glance before checking their bank balance. Learning to read your pay stub properly equips you to catch errors, verify that your deductions are correct, and understand the true cost of your benefits. The typical pay stub is divided into sections covering gross pay, taxes withheld, pre-tax deductions, post-tax deductions, and net pay.
        </p>
        <p>
          The gross pay section shows your earnings before any deductions. For salaried employees, this is usually your annual salary divided by the number of pay periods (26 for bi-weekly, 24 for semi-monthly, 12 for monthly). For hourly employees, it reflects hours worked multiplied by your hourly rate, plus any overtime, shift differentials, or bonuses. The taxes section breaks down federal income tax withheld, state income tax withheld (if applicable), Social Security tax (listed as OASDI on some stubs), and Medicare tax. These amounts should align with what our <a href="/">paycheck calculator</a> estimates when you input the same salary, filing status, and state.
        </p>
        <p>
          Pre-tax deductions appear next and typically include 401(k) or 403(b) contributions, health insurance premiums, dental and vision insurance, HSA or FSA contributions, and commuter benefits. These amounts reduce your taxable income, which is why they are subtracted before taxes are calculated. Post-tax deductions, which come after taxes, include items like Roth 401(k) contributions, garnishments, union dues, after-tax life insurance, and any voluntary contributions that do not qualify for pre-tax treatment. The final line, net pay or take-home pay, is what actually gets deposited into your bank account. Comparing this number across pay periods helps you spot unexpected changes that might indicate an error or a mid-year adjustment.
        </p>

        <h2 id="common-paycheck-mistakes" class="text-2xl font-bold text-slate-900 dark:text-white">Common Paycheck Mistakes Employers Make</h2>
        <p>
          Payroll errors are more common than most workers realize. Studies have estimated that a meaningful percentage of paychecks contain some form of error, ranging from minor miscalculations to significant underpayments. The most frequent mistakes include incorrect overtime calculations, misclassification of exempt versus non-exempt status, failure to update withholding after an employee submits a new W-4, and errors in calculating benefits deductions after open enrollment changes. Small businesses that handle payroll manually or use outdated software are particularly prone to these mistakes.
        </p>
        <p>
          Workers should routinely verify their paychecks against their expected compensation. The simplest approach is to use a paycheck calculator to determine your expected net pay based on your known salary, filing status, state, and deductions, then compare that figure to what your employer actually deposited. If there is a discrepancy, review your pay stub line by line to identify which component differs from expectations. Common culprits include an outdated tax withholding table (which happens more often than it should), an incorrect benefit premium amount following a plan change, or a missing or duplicated retirement contribution.
        </p>
        <p>
          Another area where mistakes frequently occur is in the handling of supplemental wages, such as bonuses, commissions, and severance pay. The IRS allows employers to withhold federal income tax on supplemental wages using either the flat 22 percent rate or the aggregate method, which combines the supplemental pay with regular pay and withholds as if that combined amount were a single paycheck. The aggregate method often results in higher withholding than necessary, which is why many workers see dramatically smaller net amounts from their bonus checks than expected. While this over-withholding is typically corrected when you file your annual tax return, understanding the mechanism helps set expectations and prevents unnecessary anxiety. Our <a href="/bonus-tax-calculator/">bonus tax calculator</a> models both withholding methods so you can anticipate the impact.
        </p>

        <h3 id="pre-tax-vs-post-tax" class="text-xl font-bold text-slate-900 dark:text-white">Understanding Pre-Tax vs Post-Tax Deductions</h3>
        <p>
          The distinction between pre-tax and post-tax deductions has a material impact on your take-home pay, and choosing between them is one of the most consequential decisions you make during benefits enrollment. Pre-tax deductions, such as traditional 401(k) contributions, reduce your taxable income for the current year. If you earn $80,000 and contribute $8,000 to a traditional 401(k), your taxable income drops to $72,000 for federal and state income tax purposes. Depending on your marginal tax bracket, this could save you $1,760 to $2,960 in federal taxes alone, plus additional savings on state taxes. This is an immediate, tangible benefit that increases your current take-home pay relative to what it would be without the pre-tax contribution.
        </p>
        <p>
          Post-tax deductions, by contrast, do not reduce your current taxable income. A Roth 401(k) contribution of $8,000 comes out of your paycheck after taxes have already been calculated, so your taxable income remains $80,000. The trade-off is that Roth contributions grow tax-free and qualified withdrawals in retirement are completely tax-free, which can be enormously valuable if you expect to be in a higher tax bracket in the future or if tax rates rise generally. The decision between traditional and Roth contributions is one of the most debated topics in personal finance, and there is no universally correct answer. It depends on your current marginal rate, your expected retirement income, your state of residence now and in retirement, and your views on the direction of future tax policy.
        </p>
        <p>
          Some deductions have special tax treatment that falls between these two categories. Health Savings Account (HSA) contributions, for example, are exempt from both income taxes and FICA taxes, making them even more tax-efficient than traditional 401(k) contributions, which reduce income taxes but not FICA. This triple tax advantage (tax-free contributions, tax-free growth, and tax-free withdrawals for qualified medical expenses) makes HSAs one of the most powerful savings vehicles available to workers enrolled in high-deductible health plans. Our <a href="/salary-calculator/">salary calculator</a> and <a href="/401k-calculator/">401(k) calculator</a> can help you model the impact of different contribution levels on your take-home pay, so you can find the balance that works for your financial goals.
        </p>
      </div>
    </div>
  </section>

  <!-- FAQs -->
  <section class="px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl">
      <h2 id="faq" class="mb-8 text-center text-2xl font-bold text-slate-900 dark:text-white">
        Frequently Asked Questions
      </h2>
      <dl class="space-y-6">
        {faqs.map((faq) => (
          <div class="rounded-lg border border-slate-200 p-6 dark:border-slate-700">
            <dt class="text-lg font-semibold text-slate-900 dark:text-white">{faq.question}</dt>
            <dd class="mt-2 text-slate-600 dark:text-slate-400">{faq.answer}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>
</Layout>
