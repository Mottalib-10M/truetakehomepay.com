---
import Layout from '../layouts/Layout.astro';
import { SITE_NAME, SITE_URL } from '../lib/constants';

const title = 'Privacy Policy — Your Data Rights and Our Practices';
const description = `${SITE_NAME} privacy policy. Learn how we handle your data, CCPA rights, and our cookie-less analytics approach.`;
---

<Layout title={title} description={description} noIndex={true}>
  <section class="px-4 py-16 sm:px-6 lg:px-8">
    <div class="prose prose-slate dark:prose-invert mx-auto max-w-3xl">
      <h1>Privacy Policy</h1>
      <p><strong>Last updated:</strong> January 1, 2026</p>

      <h2>Overview</h2>
      <p>
        {SITE_NAME} ({SITE_URL}) is committed to protecting your privacy. This privacy policy explains how we collect, use, and protect your information when you use our website and calculators.
      </p>

      <h2>Information We Collect</h2>
      <h3>Calculator Inputs</h3>
      <p>
        All calculations are performed entirely in your browser. Your salary, tax, and financial information <strong>never leaves your device</strong>. We do not collect, store, or transmit any calculator inputs to our servers.
      </p>

      <h3>Analytics</h3>
      <p>
        We use Plausible Analytics, a privacy-focused, cookie-less analytics service. Plausible does not use cookies, does not collect personal data, and is fully compliant with GDPR, CCPA, and PECR. We collect only aggregate data such as page views, referral sources, and general geographic regions (country-level).
      </p>

      <h3>URL Parameters</h3>
      <p>
        When you use our calculators, your inputs may be encoded in the page URL (e.g., ?gross=60000&state=CA) to enable sharing. This data exists only in your browser's address bar and is not transmitted to or stored on our servers.
      </p>

      <h2>Cookies</h2>
      <p>
        {SITE_NAME} does not use tracking cookies. The only data stored in your browser is your dark mode preference (via localStorage), which is not transmitted to any server.
      </p>

      <h2>Third-Party Services</h2>
      <p>
        We may display advertisements through Google AdSense or similar providers. These services may use their own cookies and tracking technologies. We recommend reviewing their respective privacy policies.
      </p>

      <h2>Your Rights Under CCPA (California Residents)</h2>
      <p>If you are a California resident, you have the right to:</p>
      <ul>
        <li>Know what personal information we collect about you</li>
        <li>Request deletion of your personal information</li>
        <li>Opt out of the sale of your personal information</li>
        <li>Not be discriminated against for exercising your privacy rights</li>
      </ul>
      <p>Since we do not collect personal information through our calculators, these rights are effectively exercised by default.</p>

      <h2>State Privacy Laws</h2>
      <p>
        We comply with applicable state privacy laws including the California Consumer Privacy Act (CCPA), Virginia Consumer Data Protection Act (VCDPA), Colorado Privacy Act (CPA), Connecticut Data Privacy Act (CTDPA), and Utah Consumer Privacy Act (UCPA).
      </p>

      <h2>Children's Privacy</h2>
      <p>
        Our website is not directed to children under 13 and we do not knowingly collect personal information from children.
      </p>

      <h2>Changes to This Policy</h2>
      <p>
        We may update this privacy policy from time to time. Changes will be posted on this page with an updated revision date.
      </p>

      <h2>Contact</h2>
      <p>
        For privacy-related questions, contact us at privacy@uspaycheck.com.
      </p>
    </div>
  </section>
</Layout>
