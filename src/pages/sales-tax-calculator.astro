---
import Layout from '../layouts/Layout.astro';
import { TAX_YEAR } from '../lib/constants';
import { STATES, getAllStateSlugs, getStateBySlug } from '../data/state-meta';

const title = `Sales Tax Calculator ${TAX_YEAR}: State & Local Rates by State`;
const description = `Calculate ${TAX_YEAR} sales tax for any US state and city. See combined state and local tax rates, exemptions, and total purchase cost. Free sales tax estimator.`;

const faqs = [
  {
    question: 'How is sales tax calculated?',
    answer: `Sales tax is calculated by multiplying the purchase price by the combined tax rate (state + local). For example, a $100 purchase with a 7.25% combined rate would include $7.25 in sales tax for a total of $107.25. Some states exempt certain items like groceries or clothing.`,
  },
  {
    question: 'Which states have no sales tax?',
    answer: `Five states have no statewide sales tax: Alaska, Delaware, Montana, New Hampshire, and Oregon. However, Alaska allows local jurisdictions to impose their own sales taxes, so some areas in Alaska do collect local sales tax.`,
  },
  {
    question: 'What is the difference between state and local sales tax?',
    answer: `State sales tax is set by the state government and applies uniformly across the state. Local sales tax is additional tax imposed by counties, cities, or special districts. The combined rate (state + local) is what you actually pay at checkout and can vary significantly within a state.`,
  },
  {
    question: 'Are online purchases subject to sales tax?',
    answer: `Yes. Following the 2018 Supreme Court decision in South Dakota v. Wayfair, states can require online retailers to collect sales tax even if they have no physical presence in the state. Most states now require online sellers meeting certain revenue or transaction thresholds to collect and remit sales tax.`,
  },
];

const stateEntries = Object.entries(STATES)
  .map(([code, s]) => ({ code, ...s }))
  .sort((a, b) => a.name.localeCompare(b.name));
---

<Layout title={title} description={description}>
  <!-- Hero -->
  <section class="bg-gradient-to-b from-navy-50 to-white px-4 pb-8 pt-10 dark:from-slate-900 dark:to-slate-950 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl text-center">
      <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl dark:text-white">
        Sales Tax Calculator {TAX_YEAR}
      </h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-600 dark:text-slate-400">
        Calculate sales tax for any US state and city. See state, local, and combined rates for {TAX_YEAR}.
      </p>
    </div>
  </section>

  <!-- Placeholder calculator -->
  <section class="px-4 py-12 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl">
      <div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm dark:border-slate-700 dark:bg-slate-800">
        <h2 class="text-xl font-semibold text-slate-900 dark:text-white">Calculate Sales Tax</h2>
        <p class="mt-2 text-slate-600 dark:text-slate-400">
          Select your state below to see sales tax rates, local rate variations, and exemptions.
        </p>
      </div>
    </div>
  </section>

  <!-- State grid -->
  <section class="px-4 py-12 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <h2 class="mb-8 text-center text-2xl font-bold text-slate-900 dark:text-white">
        Sales Tax by State
      </h2>
      <div class="grid gap-3 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
        {stateEntries.map((s) => (
          <a
            href={`/sales-tax-calculator/${s.slug}/`}
            class="rounded-lg border border-slate-200 bg-white px-4 py-3 text-sm font-medium text-slate-700 transition hover:border-navy-300 hover:bg-navy-50 hover:text-navy-700 dark:border-slate-700 dark:bg-slate-800 dark:text-slate-300 dark:hover:border-navy-600 dark:hover:bg-slate-700 dark:hover:text-navy-400"
          >
            {s.name}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQs -->
  <section class="px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl">
      <h2 class="mb-8 text-center text-2xl font-bold text-slate-900 dark:text-white">
        Frequently Asked Questions
      </h2>
      <dl class="space-y-6">
        {faqs.map((faq) => (
          <div class="rounded-lg border border-slate-200 p-6 dark:border-slate-700">
            <dt class="text-lg font-semibold text-slate-900 dark:text-white">{faq.question}</dt>
            <dd class="mt-2 text-slate-600 dark:text-slate-400">{faq.answer}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>
</Layout>
