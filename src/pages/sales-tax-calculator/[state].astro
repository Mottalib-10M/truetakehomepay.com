  <!-- Back link -->
  <section class="px-4 pb-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <a href="/sales-tax-calculator/" class="text-sm font-medium text-navy-600 hover:text-navy-700 dark:text-navy-400 dark:hover:text-navy-300">
        &larr; View all state sales tax calculators
      </a>
    </div>
  </section>
  {!isNoSalesTax && salesTax && (
    <script>
      (function () {
        var input = document.getElementById('purchase-amount');
        var resultDiv = document.getElementById('st-result');
        if (!input || !resultDiv) return;
        var rate = parseFloat(resultDiv.getAttribute('data-rate') || '0');
        var taxEl = document.getElementById('st-tax');
        var totalEl = document.getElementById('st-total');
        var rateEl = document.getElementById('st-rate');

        function fmtCommas(n) {
          var parts = n.split('.');
          parts[0] = parts[0].replace(/\B(?=(\d{3})+(?!\d))/g, ',');
          return parts.join('.');
        }

        function fmt(n) {
          return '$' + fmtCommas(n.toFixed(2));
        }

        function calc() {
          var raw = input.value.replace(/[^0-9.]/g, '');
          var val = parseFloat(raw);
          if (isNaN(val) || val < 0) {
            if (taxEl) taxEl.textContent = '$0';
            if (totalEl) totalEl.textContent = '$0';
            return;
          }
          var tax = val * rate;
          var total = val + tax;
          if (taxEl) taxEl.textContent = fmt(tax);
          if (totalEl) totalEl.textContent = fmt(total);
          if (rateEl) rateEl.textContent = (rate * 100).toFixed(2) + '%';
        }

        input.addEventListener('input', function () {
          var raw = input.value.replace(/[^0-9.]/g, '');
          if (raw) {
            var parts = raw.split('.');
            parts[0] = parts[0].replace(/^0+(?=\d)/, '');
            parts[0] = (parts[0] || '0').replace(/\B(?=(\d{3})+(?!\d))/g, ',');
            input.value = parts.length > 1 ? parts[0] + '.' + parts[1] : parts[0];
          }
          calc();
        });
        calc();
      })();
    </script>
  )}
</Layout>
