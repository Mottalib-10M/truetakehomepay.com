---
import Layout from '../../layouts/Layout.astro';
import { TAX_YEAR } from '../../lib/constants';
import { getAllStateSlugs, getStateBySlug } from '../../data/state-meta';
import { getPropertyTaxConfig } from '../../data/property-tax-2026/index';
import { getSalesTaxConfig } from '../../data/sales-tax-2026/index';
import { getStateTaxConfig } from '../../data/income-tax-2026/index';
import { NO_INCOME_TAX_STATES } from '../../data/state-meta';
import { formatPercent, formatCurrencyRound } from '../../lib/format-us';

export function getStaticPaths() {
  return getAllStateSlugs().map((slug) => ({ params: { state: slug } }));
}

const { state: stateSlug } = Astro.params;
const stateData = getStateBySlug(stateSlug!);
if (!stateData) return Astro.redirect('/');

const { name } = stateData;
const { abbr: code } = stateData;
const propTax = getPropertyTaxConfig(code);
const salesTax = getSalesTaxConfig(code);
const stateConfig = getStateTaxConfig(code);
const isNoTax = NO_INCOME_TAX_STATES.includes(code);
const slug = stateData.slug;
const NO_SALES_TAX_STATES = ['AK', 'DE', 'MT', 'NH', 'OR'];
const isNoSalesTax = NO_SALES_TAX_STATES.includes(code);
// Title: 50-60 chars for all state names (4-20 chars)
const _tBase = `${name} Sales Tax Calculator ${TAX_YEAR}`;
const title = _tBase.length <= 33
  ? `${_tBase}: Rates, Exemptions & Lookup`
  : _tBase.length <= 43
    ? `${_tBase} — Rates & Exemptions`
    : `${_tBase} — Rates`;

// Description: 150-160 chars for all state names
const description = name.length <= 8
  ? `Calculate ${TAX_YEAR} sales tax in ${name}. See combined state and local rates, tax-exempt items, grocery and clothing exemptions, and how ${name} compares to other states.`
  : `Calculate ${TAX_YEAR} sales tax in ${name}. See combined state and local rates, tax-exempt items, grocery and clothing exemptions, and comparisons to other states.`;

const faqs = [
  {
    question: `What is the sales tax rate in ${name}?`,
    answer: `Sales tax rates in ${name} include a state-level rate plus any applicable local taxes from counties, cities, and special districts. Use our calculator above to find the combined rate for your specific location in ${name}.`,
  },
  {
    question: `What items are exempt from sales tax in ${name}?`,
    answer: `Common exemptions vary by state. ${name} may exempt groceries, prescription medications, clothing, or other essential items from sales tax. Check the exemptions table above for ${name}-specific details.`,
  },
  {
    question: `Does ${name} have local sales taxes?`,
    answer: `Many states allow local jurisdictions to add their own sales tax on top of the state rate. This means the total rate you pay in ${name} can vary depending on the city or county where you make a purchase.`,
  },
  {
    question: `Does ${name} have a sales tax holiday?`,
    answer: `Some states hold annual sales tax holidays — typically before the back-to-school season — where certain items can be purchased tax-free. Check your state's department of revenue for any upcoming tax-free periods in ${name}.`,
  },
];
---

<Layout title={title} description={description}>
  <!-- Hero -->
  <section class="bg-gradient-to-b from-navy-50 to-white px-4 pb-8 pt-10 dark:from-slate-900 dark:to-slate-950 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl text-center">
      <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl dark:text-white">
        {name} Sales Tax Calculator {TAX_YEAR}
      </h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-600 dark:text-slate-400">
        Calculate sales tax in {name}. See state and local rates, exemptions, and comparisons.
      </p>
    </div>
  </section>

  <!-- Sales Tax Calculator -->
  <section class="px-4 py-12 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl">
      <div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm dark:border-slate-700 dark:bg-slate-800">
        <h2 id="calculator" class="text-xl font-semibold text-slate-900 dark:text-white">Calculate {name} Sales Tax</h2>

        {isNoSalesTax && code !== 'AK' && (
          <div class="mt-6 flex items-start gap-3 rounded-lg border border-green-200 bg-green-50 p-5 dark:border-green-800 dark:bg-green-950">
            <span class="mt-0.5 text-2xl text-green-600 dark:text-green-400" aria-hidden="true">&#10003;</span>
            <div>
              <p class="text-lg font-semibold text-green-800 dark:text-green-200">{name} has no general sales tax</p>
              <p class="mt-1 text-sm text-green-700 dark:text-green-300">Purchases in {name} are not subject to a state or local sales tax. The price you see is the price you pay.</p>
            </div>
          </div>
        )}

        {isNoSalesTax && code === 'AK' && (
          <div class="mt-6 flex items-start gap-3 rounded-lg border border-green-200 bg-green-50 p-5 dark:border-green-800 dark:bg-green-950">
            <span class="mt-0.5 text-2xl text-green-600 dark:text-green-400" aria-hidden="true">&#10003;</span>
            <div>
              <p class="text-lg font-semibold text-green-800 dark:text-green-200">Alaska has no state sales tax</p>
              <p class="mt-1 text-sm text-green-700 dark:text-green-300">Alaska does not impose a state-level sales tax. However, some local jurisdictions in Alaska levy their own sales taxes, with rates up to {salesTax ? formatPercent(salesTax.maxLocalRate * 100) : '7.50%'}. Check with your local borough or city for applicable rates.</p>
            </div>
          </div>
        )}

        {!isNoSalesTax && salesTax && (
          <div class="mt-4">
            <p class="text-sm text-slate-500 dark:text-slate-400">Average combined rate (state + local) in {name}:</p>
            <p class="mt-1 text-3xl font-bold text-navy-700 dark:text-navy-300">{formatPercent(salesTax.avgCombinedRate * 100)}</p>
          </div>
        )}

        {!isNoSalesTax && salesTax && (
          <div class="mt-6">
            <label for="purchase-amount" class="block text-sm font-medium text-slate-700 dark:text-slate-300">
              Purchase Amount ($)
            </label>
            <div class="relative mt-1">
              <span class="pointer-events-none absolute left-3 top-1/2 -translate-y-1/2 text-sm font-medium text-slate-500 dark:text-slate-400">$</span>
              <input
                type="text"
                inputmode="decimal"
                id="purchase-amount"
                value="100"
                class="block w-full rounded-lg border border-slate-300 py-2 pl-7 pr-4 text-slate-900 shadow-sm focus:border-navy-500 focus:ring-navy-500 dark:border-slate-600 dark:bg-slate-700 dark:text-white sm:text-sm"
              />
            </div>
            <div id="st-result" data-rate={salesTax.avgCombinedRate} class="mt-5 rounded-lg border border-slate-100 bg-slate-50 p-5 dark:border-slate-700 dark:bg-slate-900">
              <div class="grid grid-cols-3 gap-4 text-center">
                <div>
                  <p class="text-xs font-medium uppercase tracking-wider text-slate-500 dark:text-slate-400">Sales Tax</p>
                  <p id="st-tax" class="mt-1 text-xl font-bold text-slate-900 dark:text-white">
                    {formatCurrencyRound(100 * salesTax.avgCombinedRate)}
                  </p>
                </div>
                <div>
                  <p class="text-xs font-medium uppercase tracking-wider text-slate-500 dark:text-slate-400">Total Cost</p>
                  <p id="st-total" class="mt-1 text-xl font-bold text-slate-900 dark:text-white">
                    {formatCurrencyRound(100 * (1 + salesTax.avgCombinedRate))}
                  </p>
                </div>
                <div>
                  <p class="text-xs font-medium uppercase tracking-wider text-slate-500 dark:text-slate-400">Effective Rate</p>
                  <p id="st-rate" class="mt-1 text-xl font-bold text-slate-900 dark:text-white">
                    {formatPercent(salesTax.avgCombinedRate * 100)}
                  </p>
                </div>
              </div>
            </div>
          </div>
        )}

        {!isNoSalesTax && !salesTax && (
          <p class="mt-4 text-sm text-slate-500 dark:text-slate-400">Sales tax data for {name} is currently unavailable.</p>
        )}
      </div>
    </div>
  </section>

  <!-- Sales Tax Rates -->
  <section class="px-4 py-12 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl">
      <h2 id="{slug}-sales-tax-rates" class="mb-4 text-xl font-bold text-slate-900 dark:text-white">{name} Sales Tax Rates</h2>

      {isNoSalesTax && !salesTax && (
        <div class="flex items-start gap-3 rounded-lg border border-green-200 bg-green-50 p-5 dark:border-green-800 dark:bg-green-950">
          <span class="mt-0.5 text-xl text-green-600 dark:text-green-400" aria-hidden="true">&#10003;</span>
          <p class="font-medium text-green-800 dark:text-green-200">No general sales tax in {name}.</p>
        </div>
      )}

      {isNoSalesTax && salesTax && code === 'AK' && (
        <div>
          <div class="flex items-start gap-3 rounded-lg border border-green-200 bg-green-50 p-5 dark:border-green-800 dark:bg-green-950">
            <span class="mt-0.5 text-xl text-green-600 dark:text-green-400" aria-hidden="true">&#10003;</span>
            <p class="font-medium text-green-800 dark:text-green-200">No state-level sales tax. Local taxes may apply.</p>
          </div>
          <div class="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-3">
            <div class="rounded-lg border border-slate-200 bg-white p-5 text-center dark:border-slate-700 dark:bg-slate-800">
              <p class="text-xs font-medium uppercase tracking-wider text-slate-500 dark:text-slate-400">State Rate</p>
              <p class="mt-2 text-2xl font-bold text-slate-900 dark:text-white">0.00%</p>
            </div>
            <div class="rounded-lg border border-slate-200 bg-white p-5 text-center dark:border-slate-700 dark:bg-slate-800">
              <p class="text-xs font-medium uppercase tracking-wider text-slate-500 dark:text-slate-400">Avg. Combined Rate</p>
              <p class="mt-2 text-2xl font-bold text-slate-900 dark:text-white">{formatPercent(salesTax.avgCombinedRate * 100)}</p>
            </div>
            <div class="rounded-lg border border-slate-200 bg-white p-5 text-center dark:border-slate-700 dark:bg-slate-800">
              <p class="text-xs font-medium uppercase tracking-wider text-slate-500 dark:text-slate-400">Max Local Rate</p>
              <p class="mt-2 text-2xl font-bold text-slate-900 dark:text-white">{formatPercent(salesTax.maxLocalRate * 100)}</p>
            </div>
          </div>
        </div>
      )}

      {isNoSalesTax && salesTax && code !== 'AK' && (
        <div class="flex items-start gap-3 rounded-lg border border-green-200 bg-green-50 p-5 dark:border-green-800 dark:bg-green-950">
          <span class="mt-0.5 text-xl text-green-600 dark:text-green-400" aria-hidden="true">&#10003;</span>
          <p class="font-medium text-green-800 dark:text-green-200">No general sales tax in {name}. {salesTax.notes ? salesTax.notes : ''}</p>
        </div>
      )}

      {!isNoSalesTax && salesTax && (
        <div>
          <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
            <div class="rounded-lg border border-slate-200 bg-white p-5 text-center dark:border-slate-700 dark:bg-slate-800">
              <p class="text-xs font-medium uppercase tracking-wider text-slate-500 dark:text-slate-400">State Rate</p>
              <p class="mt-2 text-2xl font-bold text-slate-900 dark:text-white">{formatPercent(salesTax.stateRate * 100)}</p>
            </div>
            <div class="rounded-lg border border-slate-200 bg-white p-5 text-center dark:border-slate-700 dark:bg-slate-800">
              <p class="text-xs font-medium uppercase tracking-wider text-slate-500 dark:text-slate-400">Avg. Combined Rate</p>
              <p class="mt-2 text-2xl font-bold text-navy-700 dark:text-navy-300">{formatPercent(salesTax.avgCombinedRate * 100)}</p>
            </div>
            <div class="rounded-lg border border-slate-200 bg-white p-5 text-center dark:border-slate-700 dark:bg-slate-800">
              <p class="text-xs font-medium uppercase tracking-wider text-slate-500 dark:text-slate-400">Max Local Rate</p>
              <p class="mt-2 text-2xl font-bold text-slate-900 dark:text-white">{formatPercent(salesTax.maxLocalRate * 100)}</p>
            </div>
          </div>
          {salesTax.notes && (
            <p class="mt-4 rounded-lg border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-800 dark:border-amber-800 dark:bg-amber-950 dark:text-amber-200">
              {salesTax.notes}
            </p>
          )}
        </div>
      )}

      {!isNoSalesTax && !salesTax && (
        <p class="text-sm text-slate-500 dark:text-slate-400">Sales tax rate data for {name} is currently unavailable.</p>
      )}
    </div>
  </section>

  <!-- Sales Tax Exemptions -->
  <section class="px-4 py-12 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl">
      <h2 id="{slug}-sales-tax-exemptions" class="mb-4 text-xl font-bold text-slate-900 dark:text-white">{name} Sales Tax Exemptions</h2>

      {isNoSalesTax && (
        <div class="flex items-start gap-3 rounded-lg border border-green-200 bg-green-50 p-5 dark:border-green-800 dark:bg-green-950">
          <span class="mt-0.5 text-xl text-green-600 dark:text-green-400" aria-hidden="true">&#10003;</span>
          <p class="font-medium text-green-800 dark:text-green-200">No sales tax applies to any purchases in {name}.</p>
        </div>
      )}

      {!isNoSalesTax && salesTax && (
        <div class="overflow-hidden rounded-lg border border-slate-200 dark:border-slate-700">
          <table class="min-w-full divide-y divide-slate-200 dark:divide-slate-700">
            <thead class="bg-slate-50 dark:bg-slate-800">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-slate-500 dark:text-slate-400">Category</th>
                <th class="px-6 py-3 text-center text-xs font-medium uppercase tracking-wider text-slate-500 dark:text-slate-400">Status</th>
                <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-slate-500 dark:text-slate-400">Details</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-200 bg-white dark:divide-slate-700 dark:bg-slate-900">
              <tr>
                <td class="px-6 py-4 text-sm font-medium text-slate-900 dark:text-white">Groceries</td>
                <td class="px-6 py-4 text-center text-sm">
                  {salesTax.groceryTax === 'exempt' && (
                    <span class="inline-flex items-center gap-1 rounded-full bg-green-100 px-2.5 py-0.5 text-xs font-semibold text-green-800 dark:bg-green-900 dark:text-green-200">
                      <span aria-hidden="true">&#10003;</span> Exempt
                    </span>
                  )}
                  {salesTax.groceryTax === 'reduced' && (
                    <span class="inline-flex items-center gap-1 rounded-full bg-amber-100 px-2.5 py-0.5 text-xs font-semibold text-amber-800 dark:bg-amber-900 dark:text-amber-200">
                      Reduced
                    </span>
                  )}
                  {salesTax.groceryTax === 'full' && (
                    <span class="inline-flex items-center gap-1 rounded-full bg-red-100 px-2.5 py-0.5 text-xs font-semibold text-red-800 dark:bg-red-900 dark:text-red-200">
                      <span aria-hidden="true">&#10007;</span> Taxable
                    </span>
                  )}
                </td>
                <td class="px-6 py-4 text-sm text-slate-600 dark:text-slate-400">
                  {salesTax.groceryTax === 'exempt' && 'Grocery food is exempt from sales tax.'}
                  {salesTax.groceryTax === 'reduced' && salesTax.groceryRate !== undefined && `Taxed at a reduced rate of ${formatPercent(salesTax.groceryRate * 100)}.`}
                  {salesTax.groceryTax === 'reduced' && salesTax.groceryRate === undefined && 'Taxed at a reduced rate.'}
                  {salesTax.groceryTax === 'full' && 'Grocery food is taxed at the full sales tax rate.'}
                </td>
              </tr>
              <tr>
                <td class="px-6 py-4 text-sm font-medium text-slate-900 dark:text-white">Clothing</td>
                <td class="px-6 py-4 text-center text-sm">
                  {salesTax.clothingExempt && (
                    <span class="inline-flex items-center gap-1 rounded-full bg-green-100 px-2.5 py-0.5 text-xs font-semibold text-green-800 dark:bg-green-900 dark:text-green-200">
                      <span aria-hidden="true">&#10003;</span> Exempt
                    </span>
                  )}
                  {!salesTax.clothingExempt && (
                    <span class="inline-flex items-center gap-1 rounded-full bg-red-100 px-2.5 py-0.5 text-xs font-semibold text-red-800 dark:bg-red-900 dark:text-red-200">
                      <span aria-hidden="true">&#10007;</span> Taxable
                    </span>
                  )}
                </td>
                <td class="px-6 py-4 text-sm text-slate-600 dark:text-slate-400">
                  {salesTax.clothingExempt ? 'Clothing and footwear are exempt from sales tax.' : 'Clothing is taxed at the standard sales tax rate.'}
                </td>
              </tr>
              <tr>
                <td class="px-6 py-4 text-sm font-medium text-slate-900 dark:text-white">Prescription Drugs</td>
                <td class="px-6 py-4 text-center text-sm">
                  {salesTax.prescriptionDrugExempt && (
                    <span class="inline-flex items-center gap-1 rounded-full bg-green-100 px-2.5 py-0.5 text-xs font-semibold text-green-800 dark:bg-green-900 dark:text-green-200">
                      <span aria-hidden="true">&#10003;</span> Exempt
                    </span>
                  )}
                  {!salesTax.prescriptionDrugExempt && (
                    <span class="inline-flex items-center gap-1 rounded-full bg-red-100 px-2.5 py-0.5 text-xs font-semibold text-red-800 dark:bg-red-900 dark:text-red-200">
                      <span aria-hidden="true">&#10007;</span> Taxable
                    </span>
                  )}
                </td>
                <td class="px-6 py-4 text-sm text-slate-600 dark:text-slate-400">
                  {salesTax.prescriptionDrugExempt ? 'Prescription medications are exempt from sales tax.' : 'Prescription drugs are subject to sales tax.'}
                </td>
              </tr>
              <tr>
                <td class="px-6 py-4 text-sm font-medium text-slate-900 dark:text-white">Sales Tax Holiday</td>
                <td class="px-6 py-4 text-center text-sm">
                  {salesTax.hasSalesTaxHoliday && (
                    <span class="inline-flex items-center gap-1 rounded-full bg-green-100 px-2.5 py-0.5 text-xs font-semibold text-green-800 dark:bg-green-900 dark:text-green-200">
                      <span aria-hidden="true">&#10003;</span> Available
                    </span>
                  )}
                  {!salesTax.hasSalesTaxHoliday && (
                    <span class="inline-flex items-center gap-1 rounded-full bg-slate-100 px-2.5 py-0.5 text-xs font-semibold text-slate-600 dark:bg-slate-700 dark:text-slate-300">
                      Not available
                    </span>
                  )}
                </td>
                <td class="px-6 py-4 text-sm text-slate-600 dark:text-slate-400">
                  {salesTax.hasSalesTaxHoliday && salesTax.salesTaxHolidayDesc ? salesTax.salesTaxHolidayDesc : ''}
                  {salesTax.hasSalesTaxHoliday && !salesTax.salesTaxHolidayDesc ? 'A sales tax holiday is available.' : ''}
                  {!salesTax.hasSalesTaxHoliday ? `${name} does not currently offer a sales tax holiday.` : ''}
                </td>
              </tr>
            </tbody>
          </table>
        </div>
      )}

      {!isNoSalesTax && !salesTax && (
        <p class="text-sm text-slate-500 dark:text-slate-400">Exemption data for {name} is currently unavailable.</p>
      )}
    </div>
  </section>

  <!-- SEO prose section -->
  <section class="px-4 py-16 sm:px-6 lg:px-8">
    <div class="prose prose-slate dark:prose-invert mx-auto max-w-3xl">

      {!isNoSalesTax && (
        <h2 id="how-sales-tax-works-in-{slug}">How Sales Tax Works in {name}</h2>
      )}

      {isNoSalesTax && (
        <h2 id="why-{slug}-has-no-sales-tax">Why {name} Has No Sales Tax</h2>
      )}

      {salesTax && !isNoSalesTax && (
        <p>
          Sales tax in {name} is a consumption-based tax collected at the point of sale on most tangible personal property and certain services. The state-level sales tax rate in {name} is {formatPercent(salesTax.stateRate * 100)}, which serves as the base rate that applies uniformly across the entire state. However, the total sales tax that consumers actually pay at the register is often higher than the state rate alone, because many cities, counties, and special taxing districts within {name} are authorized to levy additional local sales taxes on top of the state rate. When these local additions are factored in, the average combined sales tax rate across {name} rises to {formatPercent(salesTax.avgCombinedRate * 100)}, and the maximum local tax rate that any jurisdiction within the state may impose is {formatPercent(salesTax.maxLocalRate * 100)}.
        </p>
      )}

      {salesTax && !isNoSalesTax && (
        <p>
          The mechanics of sales tax collection in {name} place the compliance burden primarily on retailers and service providers, who are responsible for collecting the correct amount of tax from customers at the time of purchase and remitting those funds to the state department of revenue on a regular schedule. For consumers, the sales tax is simply added to the listed price of goods and services at checkout, which means that the sticker price you see on a product in {name} does not include sales tax. This system differs from countries that use value-added taxes, where the tax is typically included in the displayed price. Understanding that the final cost of any purchase in {name} will be higher than the shelf price by the applicable sales tax percentage is important for accurate budgeting and financial planning.
        </p>
      )}

      {salesTax && isNoSalesTax && code === 'AK' && (
        <p>
          Alaska stands out as one of only five states in the nation that does not impose a state-level sales tax. This distinction has deep roots in the state's unique fiscal structure, which relies heavily on revenue from oil production and the Alaska Permanent Fund. Because the state derives substantial income from natural resource extraction taxes, severance taxes, and investment returns on the Permanent Fund, it has historically not needed to levy a broad-based sales tax on its residents. However, Alaska is unique among the no-sales-tax states in that it allows local jurisdictions to impose their own sales taxes. Some Alaska municipalities levy local sales taxes as high as {formatPercent(salesTax.maxLocalRate * 100)}, and the average combined local rate across the state is approximately {formatPercent(salesTax.avgCombinedRate * 100)}. This means that while there is no statewide sales tax, shoppers in certain Alaska cities and boroughs will still pay sales tax on their purchases.
        </p>
      )}

      {salesTax && isNoSalesTax && code === 'DE' && (
        <p>
          Delaware is one of only five states in the nation that imposes no state or local sales tax of any kind, making it a popular shopping destination for residents of neighboring states like Pennsylvania, Maryland, and New Jersey. The absence of a sales tax in Delaware is a deliberate policy choice that dates back decades and reflects the state's alternative approach to generating revenue. Instead of taxing consumer purchases, Delaware relies on a gross receipts tax imposed on businesses, which functions as a tax on the total revenue that businesses earn from selling goods and providing services within the state. This business-level tax, combined with a state income tax and various corporate franchise fees that attract thousands of businesses to incorporate in Delaware, allows the state to fund government services without placing a direct sales tax burden on consumers.
        </p>
      )}

      {salesTax && isNoSalesTax && code === 'MT' && (
        <p>
          Montana is one of only five states that does not levy a state-level general sales tax, a policy that reflects the state's independent spirit and its reliance on alternative revenue sources. The absence of a sales tax in Montana means that consumers can purchase goods and services without paying any additional tax at the register, whether they are shopping in Billings, Missoula, Great Falls, or any other community in the state. Montana funds its government services primarily through income taxes, property taxes, and various excise taxes on specific products such as gasoline, tobacco, and alcohol. {salesTax.notes} While this resort tax applies only to specific resort communities and is limited in scope, it is worth noting for visitors and residents of those areas.
        </p>
      )}

      {salesTax && isNoSalesTax && code === 'NH' && (
        <p>
          New Hampshire proudly maintains its status as one of only five states with no general sales tax, a policy that aligns with the state's famously low-tax philosophy encapsulated in its motto, "Live Free or Die." The absence of a sales tax in New Hampshire makes the state an attractive shopping destination for residents of neighboring high-tax states like Massachusetts, Vermont, and Maine, who often cross the border to make major purchases without paying sales tax. To replace the revenue that a sales tax would generate, New Hampshire relies on property taxes, which are among the highest in the nation, as well as a meals and rooms tax of 9% that applies to restaurant meals and hotel accommodations. {salesTax.notes} The state also generates significant revenue from business taxes, tobacco taxes, and the state-run liquor store system.
        </p>
      )}

      {salesTax && isNoSalesTax && code === 'OR' && (
        <p>
          Oregon is one of only five states in the nation that does not impose a general sales tax, and unlike some of its no-sales-tax peers, Oregon's prohibition on sales tax is deeply embedded in the state's legal and political culture. {salesTax.notes} Attempts to introduce a sales tax in Oregon have been rejected by voters on multiple occasions, reflecting strong public opposition to this form of taxation. To compensate for the absence of sales tax revenue, Oregon relies more heavily on its state income tax, which features relatively high marginal rates, as well as property taxes and various business taxes. The result is a tax system that shifts the burden away from consumption and toward income, which proponents argue is more progressive because it taxes residents based on their ability to pay rather than on how much they spend.
        </p>
      )}

      {isNoSalesTax && (
        <h2 id="alternative-revenue-sources-in-{slug}">Alternative Revenue Sources in {name}</h2>
