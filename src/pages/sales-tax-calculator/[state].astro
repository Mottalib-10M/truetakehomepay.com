---
import Layout from '../../layouts/Layout.astro';
import { TAX_YEAR } from '../../lib/constants';
import { getAllStateSlugs, getStateBySlug } from '../../data/state-meta';

export function getStaticPaths() {
  return getAllStateSlugs().map((slug) => ({ params: { state: slug } }));
}

const { state: stateSlug } = Astro.params;
const stateData = getStateBySlug(stateSlug!);
if (!stateData) return Astro.redirect('/');

const { name } = stateData;
const title = `${name} Sales Tax Calculator ${TAX_YEAR}: Rates & Exemptions`;
const description = `Calculate sales tax in ${name} for ${TAX_YEAR}. See state and local rates, exemptions, and how ${name} compares to other states.`;

const faqs = [
  {
    question: `What is the sales tax rate in ${name}?`,
    answer: `Sales tax rates in ${name} include a state-level rate plus any applicable local taxes from counties, cities, and special districts. Use our calculator above to find the combined rate for your specific location in ${name}.`,
  },
  {
    question: `What items are exempt from sales tax in ${name}?`,
    answer: `Common exemptions vary by state. ${name} may exempt groceries, prescription medications, clothing, or other essential items from sales tax. Check the exemptions table above for ${name}-specific details.`,
  },
  {
    question: `Does ${name} have local sales taxes?`,
    answer: `Many states allow local jurisdictions to add their own sales tax on top of the state rate. This means the total rate you pay in ${name} can vary depending on the city or county where you make a purchase.`,
  },
  {
    question: `Does ${name} have a sales tax holiday?`,
    answer: `Some states hold annual sales tax holidays — typically before the back-to-school season — where certain items can be purchased tax-free. Check your state's department of revenue for any upcoming tax-free periods in ${name}.`,
  },
];
---

<Layout title={title} description={description}>
  <!-- Hero -->
  <section class="bg-gradient-to-b from-navy-50 to-white px-4 pb-8 pt-10 dark:from-slate-900 dark:to-slate-950 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl text-center">
      <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl dark:text-white">
        {name} Sales Tax Calculator {TAX_YEAR}
      </h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-600 dark:text-slate-400">
        Calculate sales tax in {name}. See state and local rates, exemptions, and comparisons.
      </p>
    </div>
  </section>

  <!-- Placeholder calculator input -->
  <section class="px-4 py-12 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl">
      <div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm dark:border-slate-700 dark:bg-slate-800">
        <h2 class="text-xl font-semibold text-slate-900 dark:text-white">Calculate {name} Sales Tax</h2>
        <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">Enter your purchase amount to calculate sales tax.</p>
        <div class="mt-6">
          <label for="purchase-amount" class="block text-sm font-medium text-slate-700 dark:text-slate-300">
            Purchase Amount ($)
          </label>
          <input
            type="text"
            id="purchase-amount"
            placeholder="100.00"
            class="mt-1 block w-full rounded-lg border border-slate-300 px-4 py-2 text-slate-900 shadow-sm focus:border-navy-500 focus:ring-navy-500 dark:border-slate-600 dark:bg-slate-700 dark:text-white sm:text-sm"
          />
        </div>
        <p class="mt-4 text-slate-600 dark:text-slate-400">
          Full sales tax calculator with local rate lookup coming soon.
        </p>
      </div>
    </div>
  </section>

  <!-- State + local rate display placeholder -->
  <section class="px-4 py-12 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl">
      <h2 class="mb-4 text-xl font-bold text-slate-900 dark:text-white">{name} Sales Tax Rates</h2>
      <div class="overflow-hidden rounded-lg border border-slate-200 dark:border-slate-700">
        <table class="min-w-full divide-y divide-slate-200 dark:divide-slate-700">
          <thead class="bg-slate-50 dark:bg-slate-800">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-slate-500 dark:text-slate-400">Rate Type</th>
              <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-slate-500 dark:text-slate-400">Rate</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-200 bg-white dark:divide-slate-700 dark:bg-slate-900">
            <tr>
              <td class="px-6 py-4 text-sm text-slate-600 dark:text-slate-400" colspan="2">
                Sales tax rate data for {name} coming soon.
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Exemptions table placeholder -->
  <section class="px-4 py-12 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl">
      <h2 class="mb-4 text-xl font-bold text-slate-900 dark:text-white">{name} Sales Tax Exemptions</h2>
      <div class="overflow-hidden rounded-lg border border-slate-200 dark:border-slate-700">
        <table class="min-w-full divide-y divide-slate-200 dark:divide-slate-700">
          <thead class="bg-slate-50 dark:bg-slate-800">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-slate-500 dark:text-slate-400">Category</th>
              <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-slate-500 dark:text-slate-400">Exempt?</th>
              <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-slate-500 dark:text-slate-400">Notes</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-200 bg-white dark:divide-slate-700 dark:bg-slate-900">
            <tr>
              <td class="px-6 py-4 text-sm text-slate-600 dark:text-slate-400" colspan="3">
                Exemption data for {name} coming soon.
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- FAQs -->
  <section class="px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl">
      <h2 class="mb-8 text-center text-2xl font-bold text-slate-900 dark:text-white">
        {name} Sales Tax FAQ
      </h2>
      <dl class="space-y-6">
        {faqs.map((faq) => (
          <div class="rounded-lg border border-slate-200 p-6 dark:border-slate-700">
            <dt class="text-lg font-semibold text-slate-900 dark:text-white">{faq.question}</dt>
            <dd class="mt-2 text-slate-600 dark:text-slate-400">{faq.answer}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- Back link -->
  <section class="px-4 pb-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <a href="/sales-tax-calculator" class="text-sm font-medium text-navy-600 hover:text-navy-700 dark:text-navy-400 dark:hover:text-navy-300">
        &larr; View all state sales tax calculators
      </a>
    </div>
  </section>
</Layout>
