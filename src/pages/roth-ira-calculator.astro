---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import RothIRACalculator from '../components/calculators/RothIRACalculator';
import { TAX_YEAR } from '../lib/constants';

const title = `Roth IRA Calculator ${TAX_YEAR}: Tax-Free Retirement Growth`;
const description = `Calculate your Roth IRA growth potential for ${TAX_YEAR}. See contribution limits, income phase-outs, tax-free compounding, and how much you could save by retirement.`;

const faqs = [
  {
    question: `What is the Roth IRA contribution limit for ${TAX_YEAR}?`,
    answer: `The ${TAX_YEAR} Roth IRA contribution limit is $7,000 ($8,000 if you're age 50 or older). However, your ability to contribute phases out at higher incomes: $150,000-$165,000 MAGI for single filers and $236,000-$246,000 for married filing jointly.`,
  },
  {
    question: 'What are the benefits of a Roth IRA?',
    answer: `Roth IRA benefits include: tax-free growth and qualified withdrawals in retirement, no required minimum distributions (RMDs) during your lifetime, ability to withdraw contributions (not earnings) penalty-free at any time, and no age limit for contributions as long as you have earned income.`,
  },
  {
    question: 'What is a Backdoor Roth IRA?',
    answer: `A Backdoor Roth IRA is a strategy for high earners who exceed Roth IRA income limits. You contribute to a Traditional IRA (non-deductible) and then convert it to a Roth IRA. There's no income limit on Roth conversions. Be aware of the pro-rata rule if you have existing pre-tax IRA balances.`,
  },
  {
    question: 'Roth IRA vs Traditional IRA — which should I choose?',
    answer: `Choose Roth if you expect higher taxes in retirement, want tax-free withdrawals, or value flexibility (no RMDs). Choose Traditional if you need the tax deduction now, expect lower taxes in retirement, or earn too much for a deductible Traditional IRA. Many people benefit from having both for tax diversification.`,
  },
];

const relatedCalculators = [
  { title: 'Traditional IRA', href: '/traditional-ira-calculator/', desc: 'Tax-deferred IRA growth' },
  { title: '401(k) Calculator', href: '/401k-calculator/', desc: 'Employer retirement plan' },
  { title: 'Compound Interest', href: '/compound-interest-calculator/', desc: 'Investment growth projections' },
  { title: 'Income Tax Calculator', href: '/income-tax-calculator/', desc: 'Check Roth income limits' },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: `Roth IRA Calculator ${TAX_YEAR}`,
  description,
  url: 'https://truetakehomepay.com/roth-ira-calculator',
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'Any',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  inLanguage: 'en-US',
};
---

<CalculatorLayout
  title={title}
  description={description}
  h1={`Roth IRA Calculator ${TAX_YEAR}`}
  intro={`Project your Roth IRA tax-free growth for ${TAX_YEAR}. Enter your contributions, expected return rate, and time horizon to see how much your retirement savings could grow without owing taxes on withdrawals.`}
  faqs={faqs}
  relatedCalculators={relatedCalculators}
  schema={schema}
  sources={`IRS Publication 590-A and 590-B (IRA contributions and distributions), IRS Rev. Proc. 2025-11 (${TAX_YEAR} contribution limits and phase-outs). Last updated for tax year ${TAX_YEAR}.`}
>
  <RothIRACalculator client:load />
</CalculatorLayout>
