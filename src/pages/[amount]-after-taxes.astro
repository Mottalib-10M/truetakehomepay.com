---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import PaycheckCalculator from '../components/calculators/PaycheckCalculator';
import { TAX_YEAR, SITE_URL } from '../lib/constants';
import { SALARY_AMOUNTS, TOP_10_STATES, STATES } from '../data/state-meta';
import { formatCurrencyRound } from '../lib/format-us';

export function getStaticPaths() {
  return SALARY_AMOUNTS.map((amount) => ({
    params: { amount: amount.toString() },
    props: { amount },
  }));
}

const { amount } = Astro.props;
const formatted = formatCurrencyRound(amount);

// ─── Title & Meta (50-60 chars title, 150-160 chars description) ────
const title = `${formatted} Salary After Taxes: ${TAX_YEAR} Take-Home Pay Calculator`;
const description = `How much is ${formatted} after taxes in ${TAX_YEAR}? Calculate your take-home pay on a ${formatted} salary with federal and state income tax breakdown for all 50 US states.`;

// ─── Income-range contextual content ─────────────────────────────────
type IncomeRange = 'low' | 'mid' | 'upper' | 'high';
function getIncomeRange(amt: number): IncomeRange {
  if (amt <= 50000) return 'low';
  if (amt <= 100000) return 'mid';
  if (amt <= 200000) return 'upper';
  return 'high';
}

const range = getIncomeRange(amount);

const rangeContent: Record<IncomeRange, { heading: string; body: string }> = {
  low: {
    heading: `Living on a ${formatted} Salary`,
    body: `A ${formatted} salary places you below the US median household income. At this income level, federal taxes are relatively modest — you'll fall primarily in the 10% and 12% brackets. Choosing a state with no income tax (like Texas or Florida) can make a meaningful difference in your monthly budget. Maximizing your standard deduction and any available credits (like the Earned Income Tax Credit) is especially important at this income level.`,
  },
  mid: {
    heading: `What ${formatted} Looks Like After Taxes`,
    body: `A ${formatted} salary is near or above the US median household income. At this level, you'll primarily fall in the 12% and 22% federal tax brackets. State taxes become a significant factor — the difference between a no-tax state like Florida and a high-tax state like California can be several thousand dollars per year. Contributing to a traditional 401(k) is one of the most effective ways to reduce your tax burden and increase take-home pay.`,
  },
  upper: {
    heading: `Tax Planning on a ${formatted} Salary`,
    body: `Earning ${formatted} places you in the 24% or 32% federal tax bracket for most of your income. At this level, state income tax can cost you $5,000-$15,000+ annually depending on where you live. Tax-advantaged accounts like 401(k), HSA, and FSA become powerful tools — maxing out your 401(k) at $23,500 can save you $5,000+ in federal taxes alone. Consider working with a tax professional to optimize deductions.`,
  },
  high: {
    heading: `Tax Impact on a ${formatted} Salary`,
    body: `At ${formatted}, you're in the top federal tax brackets (35%-37%). Your effective federal tax rate is significantly higher than median earners, and state taxes can add 5%-13% more in high-tax states. The Additional Medicare Tax (0.9%) kicks in above $200,000 for single filers. Strategies like maximizing retirement contributions, utilizing HSAs, and considering the timing of income recognition become critical at this income level. The difference in take-home pay between states can exceed $20,000 annually.`,
  },
};

const content = rangeContent[range];

// ─── Related salary amounts ──────────────────────────────────────────
function getRelatedAmounts(amt: number): number[] {
  const step = amt <= 100000 ? 10000 : 25000;
  const related: number[] = [];
  const lower = amt - step;
  const higher = amt + step;
  if (SALARY_AMOUNTS.includes(lower)) related.push(lower);
  if (SALARY_AMOUNTS.includes(higher)) related.push(higher);
  // Add a few more from the full list
  for (const s of SALARY_AMOUNTS) {
    if (s !== amt && !related.includes(s) && related.length < 4) {
      if (Math.abs(s - amt) <= step * 3) related.push(s);
    }
  }
  return related.slice(0, 4);
}

const relatedAmounts = getRelatedAmounts(amount);

// ─── Popular state versions ──────────────────────────────────────────
const popularStates = ['CA', 'TX', 'FL', 'NY'].map((code) => ({
  code,
  name: STATES[code].name,
  slug: STATES[code].slug,
}));

// ─── FAQs ────────────────────────────────────────────────────────────
const faqs = [
  {
    question: `How much is ${formatted} a year after taxes?`,
    answer: `On a ${formatted} salary, a single filer with no state income tax takes home approximately ${formatCurrencyRound(amount * (range === 'low' ? 0.82 : range === 'mid' ? 0.77 : range === 'upper' ? 0.73 : 0.68))} to ${formatCurrencyRound(amount * (range === 'low' ? 0.85 : range === 'mid' ? 0.80 : range === 'upper' ? 0.76 : 0.71))} after federal taxes and FICA. In states with income tax, take-home pay is lower — typically ${formatCurrencyRound(amount * (range === 'low' ? 0.78 : range === 'mid' ? 0.72 : range === 'upper' ? 0.66 : 0.60))} to ${formatCurrencyRound(amount * (range === 'low' ? 0.82 : range === 'mid' ? 0.77 : range === 'upper' ? 0.73 : 0.68))} depending on the state. Use our calculator above for your exact take-home pay.`,
  },
  {
    question: `How much is ${formatted} a year per paycheck?`,
    answer: `Before taxes, a ${formatted} salary equals ${formatCurrencyRound(amount / 26)} per bi-weekly paycheck (26 paychecks per year), ${formatCurrencyRound(amount / 24)} semi-monthly (24 paychecks), ${formatCurrencyRound(amount / 12)} monthly, or ${formatCurrencyRound(amount / 52)} weekly. After taxes, each paycheck will be reduced by federal income tax, FICA (7.65%), and any state/local taxes.`,
  },
  {
    question: `What is the federal tax on a ${formatted} salary?`,
    answer: `Federal income tax on ${formatted} for a single filer in ${TAX_YEAR} uses progressive brackets: 10% on the first $11,925, 12% on income up to $48,475, 22% up to $103,350, and higher rates above that — all after the $15,700 standard deduction. Your effective federal income tax rate on ${formatted} is approximately ${range === 'low' ? '8%-10%' : range === 'mid' ? '10%-14%' : range === 'upper' ? '14%-19%' : '20%-27%'}, depending on filing status and deductions.`,
  },
  {
    question: `Which state has the lowest taxes on a ${formatted} salary?`,
    answer: `The nine states with no income tax — Alaska, Florida, Nevada, New Hampshire, South Dakota, Tennessee, Texas, Washington, and Wyoming — offer the highest take-home pay on a ${formatted} salary. Among states with income tax, states with low flat rates like Pennsylvania (3.07%) and Indiana (3.05%) are also favorable. California and New York tend to have the highest state tax burden${amount >= 100000 ? ', especially at this income level where top marginal rates apply' : ''}.`,
  },
];

// ─── Related Calculators ─────────────────────────────────────────────
const relatedCalculators = [
  ...relatedAmounts.slice(0, 2).map((amt) => ({
    title: `${formatCurrencyRound(amt)} After Taxes`,
    href: `/${amt}-after-taxes/`,
    desc: `${TAX_YEAR} take-home pay`,
  })),
  ...popularStates.slice(0, 2).map((s) => ({
    title: `${formatted} in ${s.name}`,
    href: `/${s.slug}/${amount}-after-taxes/`,
    desc: `${s.name} take-home pay`,
  })),
];

// ─── Schema.org ──────────────────────────────────────────────────────
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
};

const webAppSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: `${formatted} After Taxes Calculator ${TAX_YEAR}`,
  description,
  url: `${SITE_URL}/${amount}-after-taxes`,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'Any',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  inLanguage: 'en-US',
};

const schema = [faqSchema, webAppSchema];

// ─── Intro text ──────────────────────────────────────────────────────
const intro = `How much is ${formatted} after taxes in ${TAX_YEAR}? Use our free calculator to find your exact take-home pay after federal income tax, state tax, FICA, and deductions — for any US state.`;
---

<CalculatorLayout
  title={title}
  description={description}
  h1={`${formatted} a Year After Taxes in ${TAX_YEAR}`}
  intro={intro}
  faqs={faqs}
  relatedCalculators={relatedCalculators}
  schema={schema}
  sources={`IRS Rev. Proc. 2025-11 (federal brackets), SSA.gov (Social Security wage base ${TAX_YEAR}), individual state revenue departments. Last updated for tax year ${TAX_YEAR}.`}
  canonical={`${SITE_URL}/${amount}-after-taxes`}
>
  <PaycheckCalculator
    client:load
    defaultGross={amount}
  />

  <Fragment slot="content">
    <!-- Income-range contextual content -->
    <section class="border-t border-slate-200 px-4 py-16 dark:border-slate-800 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <h2 class="mb-4 text-2xl font-bold text-slate-900 dark:text-white">
          {content.heading}
        </h2>
        <div class="prose prose-slate dark:prose-invert max-w-none">
          <p>{content.body}</p>

          <h2 id="federal-tax-breakdown" class="text-2xl font-bold text-slate-900 dark:text-white">
            Federal Income Tax on a {formatted} Salary in {TAX_YEAR}
          </h2>

          <p>
            The federal income tax system in the United States operates on a progressive bracket structure, where different slices of your income are taxed at increasing rates. For a single filer earning {formatted} in {TAX_YEAR}, the first step is subtracting the standard deduction of $15,700, which brings your federal taxable income to approximately {formatCurrencyRound(Math.max(amount - 15700, 0))}. This taxable income then flows through the brackets: 10 percent on the first $11,925, 12 percent on income from $11,925 to $48,475, 22 percent on income from $48,475 to $103,350, 24 percent on income from $103,350 to $197,300, 32 percent on income from $197,300 to $250,525, and 35 percent on income from $250,525 to $626,350. Only the income within each bracket is taxed at that bracket's rate, which is why your effective tax rate is always lower than your marginal rate.
          </p>

          {range === 'low' && (
            <p>
              At {formatted}, your federal taxable income of approximately {formatCurrencyRound(Math.max(amount - 15700, 0))} falls primarily within the 10 percent and 12 percent brackets. The 10 percent bracket covers the first $11,925 of taxable income, producing approximately {formatCurrencyRound(Math.min(Math.max(amount - 15700, 0), 11925) * 0.10)} in federal tax. Any remaining taxable income falls in the 12 percent bracket. Your total estimated federal income tax is roughly {formatCurrencyRound(amount * 0.09)} to {formatCurrencyRound(amount * 0.11)}, resulting in an effective federal tax rate of approximately 9 to 11 percent. This is a relatively modest federal burden, and it means that for every dollar you earn, you keep roughly 89 to 91 cents before state taxes and FICA are considered. At this income level, claiming all eligible credits such as the Earned Income Tax Credit or the Saver's Credit can further reduce your federal liability, sometimes to zero or even into negative territory where you receive a refund exceeding what was withheld.
            </p>
          )}

          {range === 'mid' && (
            <p>
              With a {formatted} salary, your federal taxable income of approximately {formatCurrencyRound(Math.max(amount - 15700, 0))} moves through the 10 percent and 12 percent brackets and into the 22 percent bracket. You pay approximately {formatCurrencyRound(11925 * 0.10)} on the first $11,925, roughly {formatCurrencyRound((48475 - 11925) * 0.12)} on income from $11,925 to $48,475, and 22 percent on the remainder up to your taxable income ceiling. Your total estimated federal income tax falls in the range of {formatCurrencyRound(amount * 0.12)} to {formatCurrencyRound(amount * 0.15)}, yielding an effective federal tax rate between 12 and 15 percent. The 22 percent bracket is where many middle-income earners experience the strongest incentive to use pre-tax deductions, because every dollar you contribute to a traditional 401(k) or similar plan saves you 22 cents in federal tax immediately, on top of any state tax savings. This bracket is often referred to as the "sweet spot" for tax-deferred retirement saving.
            </p>
          )}

          {range === 'upper' && (
            <p>
              At {formatted}, your federal taxable income of approximately {formatCurrencyRound(Math.max(amount - 15700, 0))} extends through the 10, 12, and 22 percent brackets and into the 24 percent bracket, and {amount > 213000 ? 'potentially into the 32 percent bracket' : 'approaching the boundary of higher brackets'}. Your estimated federal income tax is approximately {formatCurrencyRound(amount * 0.17)} to {formatCurrencyRound(amount * 0.22)}, with an effective rate between 17 and 22 percent. At this level, the gap between your marginal rate and your effective rate becomes more pronounced. While your last dollar of taxable income may be taxed at 24 or even 32 percent, the blending of lower rates on earlier dollars keeps your overall rate significantly lower. Strategic planning at this income level can produce meaningful savings: contributing the maximum $23,500 to a traditional 401(k) reduces your taxable income and can shift a portion of your earnings out of a higher bracket, saving you {formatCurrencyRound(23500 * 0.24)} or more in federal taxes alone.
            </p>
          )}

          {range === 'high' && (
            <p>
              Earning {formatted} places your federal taxable income of approximately {formatCurrencyRound(Math.max(amount - 15700, 0))} well into the higher federal brackets. Your income passes through every bracket from 10 percent through at least 32 percent, and {amount > 266225 ? `into the 35 percent bracket for income above $250,525` : 'you approach the threshold for the 35 percent bracket'}. {amount > 642050 ? 'A portion of your income is also taxed at the top marginal rate of 37 percent.' : ''} Your estimated federal income tax is approximately {formatCurrencyRound(amount * 0.24)} to {formatCurrencyRound(amount * 0.30)}, resulting in an effective rate between 24 and 30 percent. The distinction between marginal and effective rates is especially important at this level, as it determines the true cost of additional income from bonuses, stock vesting, or side work. Federal tax planning at this income level often involves maximizing all available deductions, timing income recognition, and potentially itemizing deductions if your mortgage interest, state and local taxes (capped at $10,000), and charitable contributions exceed the standard deduction.
            </p>
          )}

          <h2 id="fica-taxes-explained" class="text-2xl font-bold text-slate-900 dark:text-white">
            FICA Taxes on {formatted}
          </h2>

          <p>
            Every W-2 employee in the United States pays FICA taxes, which consist of Social Security tax at 6.2 percent and Medicare tax at 1.45 percent. These payroll taxes are calculated on your gross wages, not on your taxable income, which means that the standard deduction and itemized deductions do not reduce your FICA obligation. On a {formatted} salary, your total FICA contribution is {amount <= 176100 ? `approximately ${formatCurrencyRound(amount * 0.0765)}, broken down as ${formatCurrencyRound(amount * 0.062)} for Social Security and ${formatCurrencyRound(amount * 0.0145)} for Medicare` : `approximately ${formatCurrencyRound(176100 * 0.062 + amount * 0.0145)}, consisting of ${formatCurrencyRound(176100 * 0.062)} for Social Security (which is capped at the wage base of $176,100 in ${TAX_YEAR}) and ${formatCurrencyRound(amount * 0.0145)} for Medicare, which has no wage base limit`}. Your employer matches your FICA contributions dollar for dollar, meaning the total Social Security and Medicare funding generated by your employment is double what appears on your pay stub.
          </p>

          {amount > 200000 && (
            <p>
              Because your {formatted} salary exceeds $200,000 for a single filer, you are subject to the Additional Medicare Tax of 0.9 percent on all wages above that threshold. This adds an extra {formatCurrencyRound((amount - 200000) * 0.009)} to your annual Medicare tax, bringing your total Medicare contribution to {formatCurrencyRound(amount * 0.0145 + (amount - 200000) * 0.009)}. Unlike the standard FICA taxes, the Additional Medicare Tax is not matched by your employer. This surtax is withheld automatically from your paychecks once your cumulative year-to-date wages surpass $200,000, which for a {formatted} earner typically occurs around {amount <= 300000 ? 'late in the year' : amount <= 400000 ? 'the middle of the year' : 'early in the year'}.
            </p>
          )}

          <p>
            FICA taxes represent a significant and often underappreciated component of the total tax burden on employment income. On your {formatted} salary, the {amount <= 176100 ? formatCurrencyRound(amount * 0.0765) : formatCurrencyRound(176100 * 0.062 + amount * 0.0145 + (amount > 200000 ? (amount - 200000) * 0.009 : 0))} in FICA taxes is spread across every paycheck throughout the year, reducing each biweekly payment by approximately {amount <= 176100 ? formatCurrencyRound(amount * 0.0765 / 26) : formatCurrencyRound((176100 * 0.062 + amount * 0.0145 + (amount > 200000 ? (amount - 200000) * 0.009 : 0)) / 26)}. While there is no way to reduce the standard FICA tax rate through deductions or credits, certain employer-provided benefits like health insurance premiums paid through a Section 125 cafeteria plan are exempt from FICA, which can provide a small but meaningful reduction in your total payroll tax.
          </p>

          <h2 id="state-tax-variation" class="text-2xl font-bold text-slate-900 dark:text-white">
            How State Taxes Vary on a {formatted} Salary
          </h2>

          <p>
            One of the largest variables in determining your take-home pay on a {formatted} salary is where you live. Nine states impose no income tax on wages: Alaska, Florida, Nevada, New Hampshire, South Dakota, Tennessee, Texas, Washington, and Wyoming. In these states, your only paycheck deductions are federal income tax and FICA, which means a single filer earning {formatted} typically takes home approximately {formatCurrencyRound(amount * (range === 'low' ? 0.82 : range === 'mid' ? 0.78 : range === 'upper' ? 0.74 : 0.70))} to {formatCurrencyRound(amount * (range === 'low' ? 0.86 : range === 'mid' ? 0.82 : range === 'upper' ? 0.78 : 0.73))} per year after all federal deductions. That same {formatted} salary in a high-tax state like California could produce take-home pay closer to {formatCurrencyRound(amount * (range === 'low' ? 0.77 : range === 'mid' ? 0.72 : range === 'upper' ? 0.66 : 0.61))} to {formatCurrencyRound(amount * (range === 'low' ? 0.81 : range === 'mid' ? 0.76 : range === 'upper' ? 0.71 : 0.67))}, a difference of roughly {formatCurrencyRound(amount * 0.06)} to {formatCurrencyRound(amount * 0.10)} per year. This annual difference translates to {formatCurrencyRound(amount * 0.06 / 12)} to {formatCurrencyRound(amount * 0.10 / 12)} per month in additional spending or saving capacity.
          </p>

          <p>
            Among states that do levy an income tax, the structures vary considerably. Some states like Illinois, Pennsylvania, and Indiana use a flat tax rate, meaning every dollar of taxable income is taxed at the same percentage regardless of the total amount. Other states like California, New York, and Oregon use progressive brackets similar to the federal system, where higher income is taxed at higher marginal rates. For a {formatted} earner, the difference between a flat 3 percent state tax and a progressive system where your top marginal rate reaches 10 percent or higher can amount to several thousand dollars per year. Understanding which type of system your state uses, and how your specific income level interacts with that system, is essential for accurately projecting your take-home pay and making informed financial plans.
          </p>

          <h2 id="pre-tax-deductions" class="text-2xl font-bold text-slate-900 dark:text-white">
            The Importance of Pre-Tax Deductions at the {formatted} Income Level
          </h2>

          {range === 'low' && (
            <p>
              At {formatted}, pre-tax deductions are a powerful tool for simultaneously reducing your tax burden and building financial security. Contributing to a traditional 401(k) reduces your federal taxable income dollar for dollar. Even a modest contribution of 5 percent of your salary, or {formatCurrencyRound(amount * 0.05)} per year, saves you approximately {formatCurrencyRound(amount * 0.05 * 0.12)} in federal income tax if most of your income falls in the 12 percent bracket. If your employer offers a matching contribution, failing to contribute at least enough to capture the full match is essentially leaving free money on the table. A Health Savings Account is equally valuable if you have a qualifying high-deductible health plan, since contributions reduce both your federal and state taxable income while growing tax-free for future medical expenses. At this income level, every dollar saved in taxes directly improves your monthly cash flow and accelerates your path to financial stability.
            </p>
          )}

          {range === 'mid' && (
            <p>
              For someone earning {formatted}, pre-tax deductions become one of the most effective financial strategies available. Contributing to a traditional 401(k) at the maximum of $23,500 in {TAX_YEAR} would reduce your federal taxable income significantly, saving you approximately {formatCurrencyRound(23500 * 0.22)} in federal income tax alone since most of the reduction comes from the 22 percent bracket. If your state also taxes income, the state savings add further value. A Health Savings Account contribution of up to $4,300 for individual coverage adds another layer of tax reduction. Combined, these two accounts could reduce your taxable income by {formatCurrencyRound(23500 + 4300)}, saving you roughly {formatCurrencyRound((23500 + 4300) * 0.22)} in federal tax plus any applicable state tax savings. Flexible Spending Accounts for healthcare and dependent care offer additional pre-tax savings, though these are "use it or lose it" accounts that require careful planning to avoid forfeiture.
            </p>
          )}

          {range === 'upper' && (
            <p>
              At the {formatted} income level, pre-tax deductions become critically important for managing your overall tax burden. Maxing out your traditional 401(k) at $23,500 saves you {formatCurrencyRound(23500 * 0.24)} or more in federal taxes because the deduction comes off the top of your income, reducing dollars that would otherwise be taxed at 24 percent or higher. Adding a maximum HSA contribution of $4,300 for individual coverage or $8,550 for family coverage provides additional savings. If you are over 50, catch-up contributions allow you to put an additional $7,500 into your 401(k) for a total of $31,000 in pre-tax retirement savings. At your marginal rate, the tax savings from these combined contributions can exceed {formatCurrencyRound(31000 * 0.24)}, translating to hundreds of additional dollars in each paycheck throughout the year. Beyond these standard accounts, you might also explore whether a backdoor Roth IRA conversion makes sense for your long-term retirement planning, as direct Roth IRA contributions are phased out at higher income levels.
            </p>
          )}

          {range === 'high' && (
            <p>
              Earning {formatted} puts you at an income level where tax optimization through pre-tax deductions can produce the most substantial absolute savings. Maxing out your 401(k) at $23,500 saves you at minimum {formatCurrencyRound(23500 * 0.32)} in federal taxes since your marginal rate is at least 32 percent. Adding maximum HSA contributions, FSA contributions for dependent care (up to $5,000), and healthcare FSA contributions (up to $3,300) further reduces your taxable income. At this level, you should also consider whether a mega backdoor Roth strategy is available through your employer's plan, which can allow after-tax contributions up to the total 415(c) limit of $70,000 for {TAX_YEAR}. The combined effect of all available pre-tax deductions at a {formatted} salary can reduce your annual tax bill by {formatCurrencyRound(amount * 0.03)} to {formatCurrencyRound(amount * 0.06)}, making aggressive use of these accounts one of the highest-return financial decisions you can make each year.
            </p>
          )}

          <h2 id="paycheck-frequency" class="text-2xl font-bold text-slate-900 dark:text-white">
            How {formatted} Breaks Down by Pay Period After Taxes
          </h2>

          <p>
            How your {formatted} salary translates to actual deposits in your bank account depends on how frequently your employer pays you. The most common pay schedules in the United States are biweekly (every two weeks, resulting in 26 paychecks per year), semi-monthly (twice per month, resulting in 24 paychecks), monthly (12 paychecks), and weekly (52 paychecks). Before any deductions, a {formatted} salary breaks down to {formatCurrencyRound(amount / 12)} per month, {formatCurrencyRound(amount / 24)} per semi-monthly period, {formatCurrencyRound(amount / 26)} per biweekly paycheck, or {formatCurrencyRound(amount / 52)} per week. After federal income tax, FICA, and an average state income tax, your actual take-home pay per paycheck is substantially lower than these gross figures.
          </p>

          <p>
            For a single filer earning {formatted} with a typical deduction profile, estimated after-tax take-home pay is approximately {formatCurrencyRound(amount * (range === 'low' ? 0.80 : range === 'mid' ? 0.75 : range === 'upper' ? 0.71 : 0.67) / 12)} per month, {formatCurrencyRound(amount * (range === 'low' ? 0.80 : range === 'mid' ? 0.75 : range === 'upper' ? 0.71 : 0.67) / 24)} per semi-monthly paycheck, {formatCurrencyRound(amount * (range === 'low' ? 0.80 : range === 'mid' ? 0.75 : range === 'upper' ? 0.71 : 0.67) / 26)} per biweekly paycheck, or {formatCurrencyRound(amount * (range === 'low' ? 0.80 : range === 'mid' ? 0.75 : range === 'upper' ? 0.71 : 0.67) / 52)} per week. These figures assume a moderate state income tax rate; your actual take-home will be higher in no-tax states and lower in high-tax states. Biweekly pay schedules deserve special attention because two months each year contain three paychecks instead of the usual two, which can be a helpful budgeting opportunity for building savings or paying down debt. Planning your budget around the two-paycheck months and treating the third paycheck as a bonus can accelerate your financial goals significantly.
          </p>

          <h2 id="reading-pay-stub" class="text-2xl font-bold text-slate-900 dark:text-white">
            How to Read Your Pay Stub on a {formatted} Salary
          </h2>

          <p>
            Understanding your pay stub is essential for verifying that your employer is withholding the correct amounts and that your take-home pay matches expectations. A typical pay stub for a {formatted} earner shows several key sections. The gross pay section displays your earnings for the period, which on a biweekly schedule would be {formatCurrencyRound(amount / 26)} per paycheck. Below that, you will see deductions separated into pre-tax and post-tax categories. Pre-tax deductions include contributions to a traditional 401(k), health insurance premiums, HSA or FSA contributions, and any other Section 125 cafeteria plan deductions. These amounts are subtracted from your gross pay before taxes are calculated, reducing your taxable income.
          </p>

          <p>
            The tax withholding section of your pay stub breaks down the federal income tax, Social Security tax, Medicare tax, and any state and local taxes withheld from your paycheck. For a {formatted} salary on a biweekly schedule, you can expect to see approximately {formatCurrencyRound(amount * 0.062 / 26)} withheld for Social Security and {formatCurrencyRound(amount * 0.0145 / 26)} for Medicare on each paycheck{amount > 200000 ? `, with an additional Medicare surtax appearing once your year-to-date earnings exceed $200,000` : ''}. Federal income tax withholding varies based on your W-4 elections, but a single filer with no adjustments earning {formatted} typically sees approximately {formatCurrencyRound(amount * (range === 'low' ? 0.09 : range === 'mid' ? 0.13 : range === 'upper' ? 0.18 : 0.25) / 26)} withheld per biweekly paycheck for federal taxes. The year-to-date totals column on your pay stub is particularly important for tracking whether you are on pace to have the correct total withholding for the year, which helps you avoid both a large tax bill and an excessively large refund when you file your return.
          </p>

          {range === 'low' && (
            <p>
              At the {formatted} income level, it is especially important to review your W-4 withholding elections carefully. Many lower-income and moderate-income earners have too much withheld from each paycheck, resulting in a large refund at tax time. While a refund might feel like a windfall, it actually represents an interest-free loan to the government throughout the year. By adjusting your W-4 to more accurately reflect your expected tax liability, you can increase each paycheck by a small but meaningful amount, improving your monthly cash flow. The IRS Tax Withholding Estimator is a free online tool that can help you determine the optimal W-4 settings for your {formatted} salary and personal situation.
            </p>
          )}

          {range === 'mid' && (
            <p>
              For earners at the {formatted} level, the net pay section at the bottom of your pay stub represents the amount actually deposited into your bank account. Comparing this figure to your gross pay reveals your total deduction rate, which for a single filer at this income typically ranges from 25 to 32 percent of gross earnings depending on your state, pre-tax deductions, and W-4 elections. If you notice a significant discrepancy between your expected and actual net pay, review each line item on your pay stub for errors. Common issues include incorrect filing status on your W-4, failure to update withholding after a life change like marriage or the birth of a child, or miscalculated pre-tax deduction amounts.
            </p>
          )}

          {range === 'upper' && (
            <p>
              At the {formatted} income level, your pay stub becomes increasingly complex as more deductions and potentially multiple income types appear. If you receive restricted stock units, bonuses, or commissions in addition to your base salary, these may be taxed at different withholding rates than your regular pay. Supplemental income is often withheld at a flat 22 percent federal rate, which may be lower than your actual marginal rate, potentially leading to a balance due at tax time. Reviewing your year-to-date totals regularly, especially after receiving supplemental income, helps ensure your total withholding is on track and prevents unpleasant surprises when filing your annual return.
            </p>
          )}

          {range === 'high' && (
            <p>
              High earners at {formatted} should pay particular attention to the year-to-date sections of their pay stubs, especially the Social Security withholding line. Because Social Security tax only applies to the first $176,100 of wages in {TAX_YEAR}, your Social Security withholding should stop after you have earned that amount, which for a {formatted} salary occurs around {amount <= 300000 ? 'late in the year' : amount <= 500000 ? 'the middle of the year' : 'earlier in the year'}. Once Social Security withholding stops, you should see a noticeable increase in your net pay for the remaining paychecks of the year. Verify that your employer correctly stops withholding Social Security at the wage base, as errors in this area can lead to overpayment that must be reclaimed when filing your tax return. Additionally, monitor the Additional Medicare Tax withholding that begins once your cumulative wages exceed $200,000 to ensure it is being applied correctly.
            </p>
          )}

        </div>
      </div>
    </section>

    <!-- Paycheck breakdown table -->
    <section class="border-t border-slate-200 bg-slate-50 px-4 py-12 dark:border-slate-800 dark:bg-slate-900 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <h2 class="mb-6 text-xl font-bold text-slate-900 dark:text-white">
          {formatted} Salary: Per-Paycheck Breakdown (Before Tax)
        </h2>
        <div class="overflow-hidden rounded-xl border border-slate-200 dark:border-slate-700">
          <table class="tabular-nums w-full text-sm">
            <thead>
              <tr class="border-b border-slate-200 bg-slate-50 dark:border-slate-700 dark:bg-slate-800/50">
                <th class="px-4 py-3 text-left font-medium text-slate-600 dark:text-slate-400">Pay Period</th>
                <th class="px-4 py-3 text-right font-medium text-slate-600 dark:text-slate-400">Gross Pay</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
              <tr>
                <td class="px-4 py-2.5 text-slate-700 dark:text-slate-300">Annual</td>
                <td class="px-4 py-2.5 text-right font-medium text-slate-900 dark:text-white">{formatted}</td>
              </tr>
              <tr>
                <td class="px-4 py-2.5 text-slate-700 dark:text-slate-300">Monthly</td>
                <td class="px-4 py-2.5 text-right font-medium text-slate-900 dark:text-white">{formatCurrencyRound(amount / 12)}</td>
              </tr>
              <tr>
                <td class="px-4 py-2.5 text-slate-700 dark:text-slate-300">Semi-Monthly</td>
                <td class="px-4 py-2.5 text-right font-medium text-slate-900 dark:text-white">{formatCurrencyRound(amount / 24)}</td>
              </tr>
              <tr>
                <td class="px-4 py-2.5 text-slate-700 dark:text-slate-300">Bi-Weekly</td>
                <td class="px-4 py-2.5 text-right font-medium text-slate-900 dark:text-white">{formatCurrencyRound(amount / 26)}</td>
              </tr>
              <tr>
                <td class="px-4 py-2.5 text-slate-700 dark:text-slate-300">Weekly</td>
                <td class="px-4 py-2.5 text-right font-medium text-slate-900 dark:text-white">{formatCurrencyRound(amount / 52)}</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- State-specific links for this amount -->
    <section class="border-t border-slate-200 px-4 py-12 dark:border-slate-800 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <h2 class="mb-6 text-xl font-bold text-slate-900 dark:text-white">
          {formatted} After Taxes by State
        </h2>
        <p class="mb-6 text-sm text-slate-600 dark:text-slate-400">
          See how much {formatted} takes home in the most populated states:
        </p>
        <div class="grid grid-cols-2 gap-2 sm:grid-cols-3 md:grid-cols-5">
          {TOP_10_STATES.map((code) => (
            <a
              href={`/${STATES[code].slug}/${amount}-after-taxes/`}
              class="rounded-lg border border-slate-200 bg-white px-3 py-2 text-center text-sm transition-colors hover:border-navy-300 dark:border-slate-700 dark:bg-slate-800 dark:hover:border-navy-600"
            >
              <span class="font-semibold text-navy-700 dark:text-navy-400">{STATES[code].name}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Related salary amounts -->
    <section class="border-t border-slate-200 bg-slate-50 px-4 py-12 dark:border-slate-800 dark:bg-slate-900 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <h2 class="mb-6 text-xl font-bold text-slate-900 dark:text-white">
          Other Salary Amounts
        </h2>
        <div class="grid grid-cols-3 gap-2 sm:grid-cols-5">
          {SALARY_AMOUNTS.filter((s) => s !== amount).map((s) => (
            <a
              href={`/${s}-after-taxes/`}
              class="rounded-lg border border-slate-200 bg-white px-3 py-2 text-center text-sm transition-colors hover:border-navy-300 dark:border-slate-700 dark:bg-slate-800 dark:hover:border-navy-600"
            >
              <span class="tabular-nums font-semibold text-navy-700 dark:text-navy-400">
                {formatCurrencyRound(s)}
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>
  </Fragment>
</CalculatorLayout>
