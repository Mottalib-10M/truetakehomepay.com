---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import PaycheckCalculator from '../components/calculators/PaycheckCalculator';
import { TAX_YEAR, SITE_URL, AUTHOR_NAME, AUTHOR_CREDENTIALS } from '../lib/constants';
import { SALARY_AMOUNTS, TOP_10_STATES, STATES } from '../data/state-meta';
import { formatCurrencyRound, formatPercent } from '../lib/format-us';
import {
  computeForState,
  buildStateComparisons,
  getBandContext,
  buildFaqs,
  getBudgetBreakdown,
  getCareerInfo,
  getTaxOptimizationTips,
  getAuthorSchema,
  getSalaryBand,
  getFederalBracketWalkthrough,
  getSalarySpecificContext,
} from '../lib/salary-content';

export function getStaticPaths() {
  return SALARY_AMOUNTS.map((amount) => ({
    params: { amount: amount.toString() },
    props: { amount },
  }));
}

const { amount } = Astro.props;
const formatted = formatCurrencyRound(amount);

// ─── Tax engine calculations ────────────────────────────────────────
const txResult = computeForState(amount, 'TX'); // No-tax state baseline
const caResult = computeForState(amount, 'CA'); // High-tax comparison
const nyResult = computeForState(amount, 'NY'); // Another comparison
const band = getSalaryBand(amount);

// Derived values
const totalFica = txResult.socialSecurity + txResult.medicare + txResult.additionalMedicare;
const netMonthly = txResult.netAnnual / 12;
const netBiweekly = txResult.netAnnual / 26;
const hourlyGross = amount / 2080;
const hourlyNet = txResult.netAnnual / 2080;

// ─── Content generation ─────────────────────────────────────────────
const stateComparisons = buildStateComparisons(amount);
const bandContext = getBandContext(amount, txResult);
const faqs = buildFaqs(amount, txResult);
const budgetRows = getBudgetBreakdown(txResult.netAnnual);
const careerInfo = getCareerInfo(amount);
const taxTips = getTaxOptimizationTips(amount, txResult);
const bracketWalkthrough = getFederalBracketWalkthrough(amount, txResult);
const salaryContext = getSalarySpecificContext(amount, txResult);

// ─── Title & Meta ───────────────────────────────────────────────────
const title = `${formatted} Salary After Taxes: ${TAX_YEAR} Take-Home Pay Calculator`;
const description = `How much is ${formatted} after taxes in ${TAX_YEAR}? Calculate your take-home pay on a ${formatted} salary with federal and state income tax breakdown for all 50 US states.`;

// ─── Related salary amounts ─────────────────────────────────────────
function getRelatedAmounts(amt: number): number[] {
  const step = amt <= 100000 ? 10000 : 25000;
  const related: number[] = [];
  const lower = amt - step;
  const higher = amt + step;
  if (SALARY_AMOUNTS.includes(lower)) related.push(lower);
  if (SALARY_AMOUNTS.includes(higher)) related.push(higher);
  for (const s of SALARY_AMOUNTS) {
    if (s !== amt && !related.includes(s) && related.length < 4) {
      if (Math.abs(s - amt) <= step * 3) related.push(s);
    }
  }
  return related.slice(0, 4);
}

const relatedAmounts = getRelatedAmounts(amount);

// ─── Popular state versions ─────────────────────────────────────────
const popularStates = ['CA', 'TX', 'FL', 'NY'].map((code) => ({
  code,
  name: STATES[code].name,
  slug: STATES[code].slug,
}));

// ─── Related Calculators ────────────────────────────────────────────
const relatedCalculators = [
  ...relatedAmounts.slice(0, 2).map((amt) => ({
    title: `${formatCurrencyRound(amt)} After Taxes`,
    href: `/${amt}-after-taxes/`,
    desc: `${TAX_YEAR} take-home pay`,
  })),
  ...popularStates.slice(0, 2).map((s) => ({
    title: `${formatted} in ${s.name}`,
    href: `/${s.slug}/${amount}-after-taxes/`,
    desc: `${s.name} take-home pay`,
  })),
];

// ─── Schema.org ─────────────────────────────────────────────────────
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
};

const webAppSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: `${formatted} After Taxes Calculator ${TAX_YEAR}`,
  description,
  url: `${SITE_URL}/${amount}-after-taxes/`,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'Any',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  inLanguage: 'en-US',
};

const authorSchema = getAuthorSchema(`${SITE_URL}/${amount}-after-taxes/`);

const schema = [webAppSchema, authorSchema];

// ─── Income-range contextual content (kept for existing sections) ───
type IncomeRange = 'low' | 'mid' | 'upper' | 'high';
function getIncomeRange(amt: number): IncomeRange {
  if (amt <= 50000) return 'low';
  if (amt <= 100000) return 'mid';
  if (amt <= 200000) return 'upper';
  return 'high';
}
const range = getIncomeRange(amount);

// ─── Intro text ─────────────────────────────────────────────────────
const intro = `How much is ${formatted} after taxes in ${TAX_YEAR}? Use our free calculator to find your exact take-home pay after federal income tax, state tax, FICA, and deductions — for any US state.`;
---

<CalculatorLayout
  title={title}
  description={description}
  h1={`${formatted} a Year After Taxes in ${TAX_YEAR}`}
  intro={intro}
  faqs={faqs}
  relatedCalculators={relatedCalculators}
  schema={schema}
  sources={`IRS Rev. Proc. 2025-11 (federal brackets), SSA.gov (Social Security wage base ${TAX_YEAR}), individual state revenue departments. Analysis by <strong>${AUTHOR_NAME}</strong>, ${AUTHOR_CREDENTIALS}. Last updated for tax year ${TAX_YEAR}.`}
  canonical={`${SITE_URL}/${amount}-after-taxes/`}
>
  <PaycheckCalculator
    client:idle
    defaultGross={amount}
  />

  <Fragment slot="content">
    <!-- ═══════ STAT CARDS ═══════ -->
    <section class="border-t border-slate-200 px-4 py-12 dark:border-slate-800 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-4xl">
        <h2 class="mb-6 text-2xl font-bold text-slate-900 dark:text-white">
          {formatted} Salary: Snapshot for {TAX_YEAR} (Single Filer, No State Tax)
        </h2>
        <div class="grid grid-cols-2 gap-4 sm:grid-cols-4">
          <div class="rounded-xl border border-green-200 bg-green-50 p-4 text-center dark:border-green-800 dark:bg-green-900/20">
            <p class="text-xs font-medium uppercase tracking-wide text-green-700 dark:text-green-400">Net Take-Home</p>
            <p class="mt-1 text-2xl font-bold text-green-800 dark:text-green-300">{formatCurrencyRound(txResult.netAnnual)}</p>
            <p class="mt-0.5 text-xs text-green-600 dark:text-green-500">{formatCurrencyRound(netMonthly)}/mo</p>
          </div>
          <div class="rounded-xl border border-blue-200 bg-blue-50 p-4 text-center dark:border-blue-800 dark:bg-blue-900/20">
            <p class="text-xs font-medium uppercase tracking-wide text-blue-700 dark:text-blue-400">Federal Tax</p>
            <p class="mt-1 text-2xl font-bold text-blue-800 dark:text-blue-300">{formatCurrencyRound(txResult.federalTax)}</p>
            <p class="mt-0.5 text-xs text-blue-600 dark:text-blue-500">Eff. {formatPercent(txResult.effectiveFederalRate * 100, 1)}</p>
          </div>
          <div class="rounded-xl border border-amber-200 bg-amber-50 p-4 text-center dark:border-amber-800 dark:bg-amber-900/20">
            <p class="text-xs font-medium uppercase tracking-wide text-amber-700 dark:text-amber-400">FICA (SS + Med)</p>
            <p class="mt-1 text-2xl font-bold text-amber-800 dark:text-amber-300">{formatCurrencyRound(totalFica)}</p>
            <p class="mt-0.5 text-xs text-amber-600 dark:text-amber-500">{formatPercent((totalFica / amount) * 100, 1)} of gross</p>
          </div>
          <div class="rounded-xl border border-purple-200 bg-purple-50 p-4 text-center dark:border-purple-800 dark:bg-purple-900/20">
            <p class="text-xs font-medium uppercase tracking-wide text-purple-700 dark:text-purple-400">Marginal Rate</p>
            <p class="mt-1 text-2xl font-bold text-purple-800 dark:text-purple-300">{formatPercent(txResult.marginalFederalRate * 100, 0)}</p>
            <p class="mt-0.5 text-xs text-purple-600 dark:text-purple-500">Federal bracket</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════ BAND CONTEXT (unique per salary level) ═══════ -->
    <section class="border-t border-slate-200 px-4 py-16 dark:border-slate-800 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <h2 class="mb-4 text-2xl font-bold text-slate-900 dark:text-white">
          Understanding a {formatted} Salary in the United States
        </h2>
        <div class="prose prose-slate dark:prose-invert max-w-none">
          <p>{bandContext}</p>
          <p>{salaryContext.medianComparison}</p>
          <p>{salaryContext.purchasingPower}</p>
        </div>
      </div>
    </section>

    <!-- ═══════ SALARY-SPECIFIC ANALYSIS (unique per exact amount) ═══════ -->
    <section class="border-t border-slate-200 bg-slate-50 px-4 py-12 dark:border-slate-800 dark:bg-slate-900 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <h2 class="mb-4 text-2xl font-bold text-slate-900 dark:text-white">
          {formatted} Salary: Raise and Comparison Analysis
        </h2>
        <div class="prose prose-slate dark:prose-invert max-w-none">
          <p>{salaryContext.adjacentComparison}</p>
          <p>{salaryContext.raiseAnalysis}</p>
        </div>
      </div>
    </section>

    <!-- ═══════ MULTI-STATE COMPARISON TABLE ═══════ -->
    <section class="border-t border-slate-200 bg-slate-50 px-4 py-12 dark:border-slate-800 dark:bg-slate-900 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-4xl">
        <h2 class="mb-2 text-2xl font-bold text-slate-900 dark:text-white">
          {formatted} Take-Home Pay Across 12 US States
        </h2>
        <p class="mb-6 text-sm text-slate-600 dark:text-slate-400">
          Side-by-side comparison for a single filer with no pre-tax deductions in {TAX_YEAR}. All figures are annual amounts.
        </p>
        <div class="overflow-x-auto rounded-xl border border-slate-200 dark:border-slate-700">
          <table class="tabular-nums w-full text-sm">
            <thead>
              <tr class="border-b border-slate-200 bg-slate-100 dark:border-slate-700 dark:bg-slate-800/70">
                <th class="px-3 py-3 text-left font-medium text-slate-600 dark:text-slate-400">State</th>
                <th class="px-3 py-3 text-right font-medium text-slate-600 dark:text-slate-400">Federal Tax</th>
                <th class="px-3 py-3 text-right font-medium text-slate-600 dark:text-slate-400">State Tax</th>
                <th class="px-3 py-3 text-right font-medium text-slate-600 dark:text-slate-400">FICA</th>
                <th class="px-3 py-3 text-right font-medium text-slate-600 dark:text-slate-400">Net Pay</th>
                <th class="px-3 py-3 text-right font-medium text-slate-600 dark:text-slate-400">Eff. Rate</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
              {stateComparisons.map((sc) => (
                <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/30">
                  <td class="px-3 py-2.5">
                    <a href={`/${sc.slug}/${amount}-after-taxes/`} class="font-medium text-navy-700 hover:underline dark:text-navy-400">
                      {sc.name}
                    </a>
                  </td>
                  <td class="px-3 py-2.5 text-right text-slate-700 dark:text-slate-300">{formatCurrencyRound(sc.federalTax)}</td>
                  <td class="px-3 py-2.5 text-right text-slate-700 dark:text-slate-300">{formatCurrencyRound(sc.stateTax)}</td>
                  <td class="px-3 py-2.5 text-right text-slate-700 dark:text-slate-300">{formatCurrencyRound(sc.fica)}</td>
                  <td class="px-3 py-2.5 text-right font-semibold text-green-700 dark:text-green-400">{formatCurrencyRound(sc.netAnnual)}</td>
                  <td class="px-3 py-2.5 text-right text-slate-700 dark:text-slate-300">{formatPercent(sc.effectiveRate, 1)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <p class="mt-3 text-xs text-slate-500 dark:text-slate-400">
          Calculated using {TAX_YEAR} federal brackets, state tax rates, FICA (6.2% SS + 1.45% Medicare), and applicable state disability/PFL contributions. Single filer, standard deduction, no dependents.
        </p>
      </div>
    </section>

    <!-- ═══════ FEDERAL TAX MECHANICS ═══════ -->
    <section class="border-t border-slate-200 px-4 py-16 dark:border-slate-800 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <div class="prose prose-slate dark:prose-invert max-w-none">
          <h2 id="how-federal-taxes-apply" class="text-2xl font-bold text-slate-900 dark:text-white">
            How Federal Taxes Apply to Your {formatted} Salary
          </h2>

          <p>
            When you earn {formatted} as a single filer in {TAX_YEAR}, the IRS first subtracts the standard deduction of {formatCurrencyRound(txResult.standardDeduction)}, reducing your federal taxable income to {formatCurrencyRound(txResult.taxableIncome)}. This {formatCurrencyRound(txResult.taxableIncome)} then flows through the progressive bracket structure where each slice of income is taxed at its own rate. Of your total {formatted} gross salary, the government keeps {formatCurrencyRound(txResult.federalTax)} in federal income tax and {formatCurrencyRound(totalFica)} in FICA, leaving you with {formatCurrencyRound(txResult.netAnnual)} — meaning you retain {formatPercent((txResult.netAnnual / amount) * 100, 1)} of every dollar earned.
          </p>

          <p>
            The bracket-by-bracket breakdown for your {formatted} salary is: {bracketWalkthrough}. These add up to {formatCurrencyRound(txResult.federalTax)} in total federal income tax, giving you an effective federal rate of {formatPercent(txResult.effectiveFederalRate * 100, 1)} — significantly below your {formatPercent(txResult.marginalFederalRate * 100, 0)} marginal bracket. The practical impact: if you receive a $1,000 bonus, only {formatCurrencyRound(1000 * txResult.marginalFederalRate)} goes to federal income tax (at your marginal rate), not {formatCurrencyRound(1000 * txResult.effectiveFederalRate)} (your effective rate). A $5,000 raise from {formatted} to {formatCurrencyRound(amount + 5000)} would yield approximately {formatCurrencyRound(5000 * (1 - txResult.marginalFederalRate - 0.0765))} in additional after-tax income.
          </p>

          <h2 id="fica-payroll-taxes" class="text-2xl font-bold text-slate-900 dark:text-white">
            Payroll Taxes (FICA) on {formatted}
          </h2>

          <p>
            On your {formatted} salary, FICA payroll taxes claim {formatCurrencyRound(totalFica)} annually — split between Social Security at {formatCurrencyRound(txResult.socialSecurity)} (6.2% of gross wages) and Medicare at {formatCurrencyRound(txResult.medicare)} (1.45% of gross wages).{amount > 176100 ? ` Because your salary exceeds the $176,100 Social Security wage base in ${TAX_YEAR}, your Social Security contribution is capped at ${formatCurrencyRound(176100 * 0.062)}, and only your first $176,100 is subject to the 6.2% rate.` : ` With ${formatted} fully below the $176,100 Social Security wage base in ${TAX_YEAR}, every dollar of your salary is subject to the 6.2% rate, resulting in the full ${formatCurrencyRound(txResult.socialSecurity)} contribution.`}{amount > 200000 ? ` The Additional Medicare Tax of 0.9% applies to your wages above $200,000, adding ${formatCurrencyRound(txResult.additionalMedicare)} beyond the standard Medicare contribution.` : ''} Per biweekly paycheck, FICA deducts {formatCurrencyRound(totalFica / 26)} — that is {formatCurrencyRound(txResult.socialSecurity / 26)} for Social Security and {formatCurrencyRound(txResult.medicare / 26)} for Medicare.
          </p>

          <p>
            Your employer pays an identical {formatCurrencyRound(totalFica)} in matching FICA contributions on your {formatted} salary, meaning the total payroll tax generated by your employment is {formatCurrencyRound(totalFica * 2)} per year. Unlike federal income tax, FICA cannot be reduced through the standard deduction or itemized deductions. However, pre-tax benefits like health insurance premiums paid through a Section 125 cafeteria plan are exempt from FICA, which at {formatted} could save you up to {formatCurrencyRound(Math.min(amount * 0.03, 3000) * 0.0765)} if you contribute {formatCurrencyRound(Math.min(amount * 0.03, 3000))} in eligible premiums.
          </p>

          <h2 id="state-tax-geography" class="text-2xl font-bold text-slate-900 dark:text-white">
            The Geographic Tax Divide on a {formatted} Salary
          </h2>

          <p>
            One of the largest variables in determining your take-home pay on a {formatted} salary is where you live. In Texas or Florida (no income tax), your take-home pay is {formatCurrencyRound(txResult.netAnnual)} per year. That same salary in California produces take-home pay of {formatCurrencyRound(caResult.netAnnual)}, a reduction of {formatCurrencyRound(txResult.netAnnual - caResult.netAnnual)} per year or {formatCurrencyRound((txResult.netAnnual - caResult.netAnnual) / 12)} per month solely from state income tax of {formatCurrencyRound(caResult.stateTax)}. In New York, the take-home drops to {formatCurrencyRound(nyResult.netAnnual)}, with state tax of {formatCurrencyRound(nyResult.stateTax)}.
          </p>

          <p>
            For a {formatted} earner specifically, the state tax landscape creates measurable differences. In flat-tax states like Illinois (4.95%), your state tax would be {formatCurrencyRound(amount * 0.0495)}. In Pennsylvania (3.07%), it would be only {formatCurrencyRound(amount * 0.0307)} — a savings of {formatCurrencyRound(amount * 0.0495 - amount * 0.0307)} over Illinois. In progressive-bracket states, your {formatted} salary lands at a marginal state rate of {amount >= 100000 ? '9 to 13 percent in California or New York' : '6 to 9 percent in California'}, making the total state tax burden {formatCurrencyRound(caResult.stateTax)} in California versus zero in Texas. The annual difference of {formatCurrencyRound(caResult.stateTax)} between California and Texas translates to {formatCurrencyRound(caResult.stateTax / 12)} per month in additional spending power — {amount <= 80000 ? 'enough to cover a car payment and insurance in most markets' : amount <= 150000 ? 'enough to cover rent in many mid-sized cities' : 'a significant sum that compounds substantially when invested over a career'}.
          </p>

          <h2 id="pre-tax-strategies" class="text-2xl font-bold text-slate-900 dark:text-white">
            Pre-Tax Deduction Strategies for the {formatted} Earner
          </h2>

          {range === 'low' && (
            <p>
              At {formatted}, pre-tax deductions are a powerful tool for simultaneously reducing your tax burden and building financial security. Contributing to a traditional 401(k) reduces your federal taxable income dollar for dollar. Even a modest contribution of 5 percent of your salary, or {formatCurrencyRound(amount * 0.05)} per year, saves you approximately {formatCurrencyRound(amount * 0.05 * txResult.marginalFederalRate)} in federal income tax because that money comes off the top of your income at the {formatPercent(txResult.marginalFederalRate * 100, 0)} marginal rate. If your employer offers a matching contribution, failing to contribute at least enough to capture the full match is essentially leaving free money on the table. A Health Savings Account is equally valuable if you have a qualifying high-deductible health plan, since contributions reduce both your federal and state taxable income while growing tax-free for future medical expenses.
            </p>
          )}

          {range === 'mid' && (
            <p>
              For someone earning {formatted}, pre-tax deductions become one of the most effective financial strategies available. Contributing to a traditional 401(k) at the maximum of $23,500 in {TAX_YEAR} would reduce your federal taxable income significantly, saving you approximately {formatCurrencyRound(23500 * txResult.marginalFederalRate)} in federal income tax alone since most of the reduction comes from the {formatPercent(txResult.marginalFederalRate * 100, 0)} bracket. If your state also taxes income, the state savings add further value. A Health Savings Account contribution of up to $4,300 for individual coverage adds another layer of tax reduction. Combined, these two accounts could reduce your taxable income by {formatCurrencyRound(23500 + 4300)}, saving you roughly {formatCurrencyRound((23500 + 4300) * txResult.marginalFederalRate)} in federal tax plus any applicable state tax savings.
            </p>
          )}

          {range === 'upper' && (
            <p>
              At the {formatted} income level, pre-tax deductions become critically important for managing your overall tax burden. Maxing out your traditional 401(k) at $23,500 saves you {formatCurrencyRound(23500 * txResult.marginalFederalRate)} in federal taxes because the deduction comes off the top of your income, reducing dollars that would otherwise be taxed at {formatPercent(txResult.marginalFederalRate * 100, 0)}. Adding a maximum HSA contribution of $4,300 for individual coverage or $8,550 for family coverage provides additional savings. If you are over 50, catch-up contributions allow you to put an additional $7,500 into your 401(k) for a total of $31,000 in pre-tax retirement savings. At your marginal rate, the tax savings from these combined contributions can exceed {formatCurrencyRound(31000 * txResult.marginalFederalRate)}, translating to hundreds of additional dollars in each paycheck.
            </p>
          )}

          {range === 'high' && (
            <p>
              Earning {formatted} puts you at an income level where tax optimization through pre-tax deductions can produce the most substantial absolute savings. Maxing out your 401(k) at $23,500 saves you {formatCurrencyRound(23500 * txResult.marginalFederalRate)} in federal taxes since your marginal rate is {formatPercent(txResult.marginalFederalRate * 100, 0)}. Adding maximum HSA contributions, FSA contributions for dependent care (up to $5,000), and healthcare FSA contributions (up to $3,300) further reduces your taxable income. At this level, you should also consider whether a mega backdoor Roth strategy is available through your employer's plan, which can allow after-tax contributions up to the total 415(c) limit of $70,000 for {TAX_YEAR}. The combined effect of all available pre-tax deductions at a {formatted} salary can reduce your annual tax bill by {formatCurrencyRound(amount * 0.03)} to {formatCurrencyRound(amount * 0.06)}.
            </p>
          )}

          <h2 id="paycheck-frequency" class="text-2xl font-bold text-slate-900 dark:text-white">
            How {formatted} Breaks Down by Pay Period After Taxes
          </h2>

          <p>
            How your {formatted} salary translates to actual deposits in your bank account depends on how frequently your employer pays you. Before any deductions, a {formatted} salary breaks down to {formatCurrencyRound(amount / 12)} per month, {formatCurrencyRound(amount / 24)} per semi-monthly period, {formatCurrencyRound(amount / 26)} per biweekly paycheck, or {formatCurrencyRound(amount / 52)} per week. After federal income tax, FICA, and state taxes, the after-tax figures in a no-income-tax state are approximately {formatCurrencyRound(txResult.netAnnual / 12)} per month, {formatCurrencyRound(txResult.netAnnual / 24)} semi-monthly, {formatCurrencyRound(netBiweekly)} biweekly, or {formatCurrencyRound(txResult.netAnnual / 52)} weekly.
          </p>

          <p>
            Your {formatted} salary divided across 2,080 working hours equals a gross hourly rate of {formatCurrencyRound(hourlyGross)}. After federal taxes and FICA, the effective after-tax hourly wage is {formatCurrencyRound(hourlyNet)} in a no-tax state and {formatCurrencyRound(caResult.netAnnual / 2080)} in California. That means taxes reduce your effective hourly pay by {formatCurrencyRound(hourlyGross - hourlyNet)} per hour ({formatPercent(((hourlyGross - hourlyNet) / hourlyGross) * 100, 1)} of your gross rate). For a {formatted} earner considering side work, any freelance opportunity must pay above {formatCurrencyRound(hourlyNet * 1.3)} per hour to account for self-employment tax and make the effort worthwhile relative to your primary compensation.
          </p>

          <h2 id="understanding-pay-stub" class="text-2xl font-bold text-slate-900 dark:text-white">
            Decoding Your Pay Stub on a {formatted} Salary
          </h2>

          <p>
            On a {formatted} salary paid biweekly, each pay stub shows gross pay of {formatCurrencyRound(amount / 26)}. The deductions that follow include: federal income tax withholding of approximately {formatCurrencyRound(txResult.federalTax / 26)}, Social Security of {formatCurrencyRound(txResult.socialSecurity / 26)}, and Medicare of {formatCurrencyRound(txResult.medicare / 26)} — totaling {formatCurrencyRound((txResult.federalTax + totalFica) / 26)} in mandatory deductions per paycheck. After these withholdings, your net deposit per pay period is approximately {formatCurrencyRound(txResult.netAnnual / 26)} in a no-tax state. If you contribute to a 401(k), those pre-tax deductions appear before the federal tax line, reducing your taxable wages and lowering the {formatCurrencyRound(txResult.federalTax / 26)} federal withholding accordingly.
          </p>

          {range === 'low' && (
            <p>
              At the {formatted} income level, it is especially important to review your W-4 withholding elections carefully. Many lower-income and moderate-income earners have too much withheld from each paycheck, resulting in a large refund at tax time. While a refund might feel like a windfall, it actually represents an interest-free loan to the government throughout the year. By adjusting your W-4 to more accurately reflect your expected tax liability, you can increase each paycheck by a meaningful amount, improving your monthly cash flow. The IRS Tax Withholding Estimator at irs.gov is a free online tool that can help you determine the optimal W-4 settings for your {formatted} salary.
            </p>
          )}

          {range === 'mid' && (
            <p>
              At {formatted}, your total deduction rate (everything subtracted from gross) should be approximately {formatPercent(((amount - txResult.netAnnual) / amount) * 100, 1)} in a no-tax state or {formatPercent(((amount - caResult.netAnnual) / amount) * 100, 1)} in California. On each biweekly paycheck of {formatCurrencyRound(amount / 26)} gross, expect to see roughly {formatCurrencyRound((amount - txResult.netAnnual) / 26)} in total deductions, leaving {formatCurrencyRound(txResult.netAnnual / 26)} deposited. If your actual net differs significantly from this amount, check your W-4 elections — at {formatted}, having one too many or too few allowances can swing each paycheck by {formatCurrencyRound(amount * 0.02 / 26)} to {formatCurrencyRound(amount * 0.04 / 26)}.
            </p>
          )}

          {range === 'upper' && (
            <p>
              At the {formatted} income level, your pay stub becomes increasingly complex as more deductions and potentially multiple income types appear. If you receive restricted stock units, bonuses, or commissions in addition to your base salary, these may be withheld at the flat 22 percent federal supplemental rate, which may be lower than your actual marginal rate of {formatPercent(txResult.marginalFederalRate * 100, 0)}, potentially leading to a balance due at tax time. Reviewing your year-to-date totals regularly helps ensure your total withholding is on track.
            </p>
          )}

          {range === 'high' && (
            <p>
              High earners at {formatted} should pay particular attention to the year-to-date sections of their pay stubs. Because Social Security tax only applies to the first $176,100 of wages in {TAX_YEAR}, your Social Security withholding should stop after you have earned that amount, which for a {formatted} salary occurs around {300000 >= amount ? 'late in the year' : 500000 >= amount ? 'the middle of the year' : 'earlier in the year'}. Once Social Security withholding stops, you should see a noticeable increase in your net pay for the remaining paychecks of the year. Additionally, monitor the Additional Medicare Tax withholding of {formatCurrencyRound(txResult.additionalMedicare)} that begins once your cumulative wages exceed $200,000.
            </p>
          )}
        </div>
      </div>
    </section>

    <!-- ═══════ PAYCHECK BREAKDOWN TABLE ═══════ -->
    <section class="border-t border-slate-200 bg-slate-50 px-4 py-12 dark:border-slate-800 dark:bg-slate-900 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <h2 class="mb-6 text-xl font-bold text-slate-900 dark:text-white">
          {formatted} Salary: Per-Paycheck Breakdown (Before Tax)
        </h2>
        <div class="overflow-hidden rounded-xl border border-slate-200 dark:border-slate-700">
          <table class="tabular-nums w-full text-sm">
            <thead>
              <tr class="border-b border-slate-200 bg-slate-50 dark:border-slate-700 dark:bg-slate-800/50">
                <th class="px-4 py-3 text-left font-medium text-slate-600 dark:text-slate-400">Pay Period</th>
                <th class="px-4 py-3 text-right font-medium text-slate-600 dark:text-slate-400">Gross Pay</th>
                <th class="px-4 py-3 text-right font-medium text-slate-600 dark:text-slate-400">Net Pay (est.)</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
              <tr>
                <td class="px-4 py-2.5 text-slate-700 dark:text-slate-300">Annual</td>
                <td class="px-4 py-2.5 text-right font-medium text-slate-900 dark:text-white">{formatted}</td>
                <td class="px-4 py-2.5 text-right font-medium text-green-700 dark:text-green-400">{formatCurrencyRound(txResult.netAnnual)}</td>
              </tr>
              <tr>
                <td class="px-4 py-2.5 text-slate-700 dark:text-slate-300">Monthly</td>
                <td class="px-4 py-2.5 text-right font-medium text-slate-900 dark:text-white">{formatCurrencyRound(amount / 12)}</td>
                <td class="px-4 py-2.5 text-right font-medium text-green-700 dark:text-green-400">{formatCurrencyRound(txResult.netAnnual / 12)}</td>
              </tr>
              <tr>
                <td class="px-4 py-2.5 text-slate-700 dark:text-slate-300">Semi-Monthly</td>
                <td class="px-4 py-2.5 text-right font-medium text-slate-900 dark:text-white">{formatCurrencyRound(amount / 24)}</td>
                <td class="px-4 py-2.5 text-right font-medium text-green-700 dark:text-green-400">{formatCurrencyRound(txResult.netAnnual / 24)}</td>
              </tr>
              <tr>
                <td class="px-4 py-2.5 text-slate-700 dark:text-slate-300">Bi-Weekly</td>
                <td class="px-4 py-2.5 text-right font-medium text-slate-900 dark:text-white">{formatCurrencyRound(amount / 26)}</td>
                <td class="px-4 py-2.5 text-right font-medium text-green-700 dark:text-green-400">{formatCurrencyRound(txResult.netAnnual / 26)}</td>
              </tr>
              <tr>
                <td class="px-4 py-2.5 text-slate-700 dark:text-slate-300">Weekly</td>
                <td class="px-4 py-2.5 text-right font-medium text-slate-900 dark:text-white">{formatCurrencyRound(amount / 52)}</td>
                <td class="px-4 py-2.5 text-right font-medium text-green-700 dark:text-green-400">{formatCurrencyRound(txResult.netAnnual / 52)}</td>
              </tr>
              <tr>
                <td class="px-4 py-2.5 text-slate-700 dark:text-slate-300">Hourly (2,080 hrs)</td>
                <td class="px-4 py-2.5 text-right font-medium text-slate-900 dark:text-white">{formatCurrencyRound(hourlyGross)}</td>
                <td class="px-4 py-2.5 text-right font-medium text-green-700 dark:text-green-400">{formatCurrencyRound(hourlyNet)}</td>
              </tr>
            </tbody>
          </table>
        </div>
        <p class="mt-2 text-xs text-slate-500 dark:text-slate-400">
          Net pay estimates assume single filer in a no-income-tax state with standard deduction and no pre-tax contributions.
        </p>
      </div>
    </section>

    <!-- ═══════ MONTHLY BUDGET TABLE ═══════ -->
    <section class="border-t border-slate-200 px-4 py-12 dark:border-slate-800 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <h2 class="mb-2 text-2xl font-bold text-slate-900 dark:text-white">
          Suggested Monthly Budget on {formatCurrencyRound(netMonthly)} Take-Home
        </h2>
        <p class="mb-6 text-sm text-slate-600 dark:text-slate-400">
          Based on your estimated {formatCurrencyRound(netMonthly)} monthly take-home pay in a no-income-tax state, here is a guideline allocation following the balanced budget framework.
        </p>
        <div class="overflow-hidden rounded-xl border border-slate-200 dark:border-slate-700">
          <table class="tabular-nums w-full text-sm">
            <thead>
              <tr class="border-b border-slate-200 bg-slate-50 dark:border-slate-700 dark:bg-slate-800/50">
                <th class="px-4 py-3 text-left font-medium text-slate-600 dark:text-slate-400">Category</th>
                <th class="px-4 py-3 text-right font-medium text-slate-600 dark:text-slate-400">%</th>
                <th class="px-4 py-3 text-right font-medium text-slate-600 dark:text-slate-400">Monthly</th>
                <th class="px-4 py-3 text-right font-medium text-slate-600 dark:text-slate-400">Annual</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
              {budgetRows.map((row) => (
                <tr>
                  <td class="px-4 py-2.5 text-slate-700 dark:text-slate-300">{row.category}</td>
                  <td class="px-4 py-2.5 text-right text-slate-600 dark:text-slate-400">{row.percent}%</td>
                  <td class="px-4 py-2.5 text-right font-medium text-slate-900 dark:text-white">{formatCurrencyRound(row.monthly)}</td>
                  <td class="px-4 py-2.5 text-right font-medium text-slate-900 dark:text-white">{formatCurrencyRound(row.annual)}</td>
                </tr>
              ))}
            </tbody>
            <tfoot>
              <tr class="border-t border-slate-200 bg-slate-50 dark:border-slate-700 dark:bg-slate-800/50">
                <td class="px-4 py-2.5 font-semibold text-slate-900 dark:text-white">Total</td>
                <td class="px-4 py-2.5 text-right font-semibold text-slate-900 dark:text-white">100%</td>
                <td class="px-4 py-2.5 text-right font-semibold text-slate-900 dark:text-white">{formatCurrencyRound(Math.round(netMonthly))}</td>
                <td class="px-4 py-2.5 text-right font-semibold text-slate-900 dark:text-white">{formatCurrencyRound(txResult.netAnnual)}</td>
              </tr>
            </tfoot>
          </table>
        </div>
      </div>
    </section>

    <!-- ═══════ CAREER INFORMATION ═══════ -->
    <section class="border-t border-slate-200 bg-slate-50 px-4 py-12 dark:border-slate-800 dark:bg-slate-900 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <h2 class="mb-4 text-2xl font-bold text-slate-900 dark:text-white">
          {careerInfo.title}
        </h2>
        <div class="prose prose-slate dark:prose-invert max-w-none">
          <p>{careerInfo.description}</p>
          <p class="font-medium">Common roles at this salary level include:</p>
          <ul>
            {careerInfo.roles.map((role) => (
              <li>{role}</li>
            ))}
          </ul>
          <p>{careerInfo.advancement}</p>
        </div>
      </div>
    </section>

    <!-- ═══════ TAX OPTIMIZATION TIPS ═══════ -->
    <section class="border-t border-slate-200 px-4 py-12 dark:border-slate-800 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <h2 class="mb-4 text-2xl font-bold text-slate-900 dark:text-white">
          Tax-Saving Strategies for {formatted} Earners in {TAX_YEAR}
        </h2>
        <p class="mb-6 text-sm text-slate-600 dark:text-slate-400">
          Practical steps to reduce your tax burden at the {formatPercent(txResult.marginalFederalRate * 100, 0)} marginal rate. Analysis by {AUTHOR_NAME}, {AUTHOR_CREDENTIALS}.
        </p>
        <div class="space-y-4">
          {taxTips.map((tip, i) => (
            <div class="flex gap-3 rounded-lg border border-slate-200 bg-white p-4 dark:border-slate-700 dark:bg-slate-800">
              <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-navy-100 text-xs font-bold text-navy-700 dark:bg-navy-900 dark:text-navy-300">
                {i + 1}
              </span>
              <p class="text-sm leading-relaxed text-slate-700 dark:text-slate-300">{tip}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════ STATE-SPECIFIC LINKS ═══════ -->
    <section class="border-t border-slate-200 bg-slate-50 px-4 py-12 dark:border-slate-800 dark:bg-slate-900 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <h2 class="mb-6 text-xl font-bold text-slate-900 dark:text-white">
          {formatted} After Taxes by State
        </h2>
        <p class="mb-6 text-sm text-slate-600 dark:text-slate-400">
          See how much {formatted} takes home in the most populated states:
        </p>
        <div class="grid grid-cols-2 gap-2 sm:grid-cols-3 md:grid-cols-5">
          {TOP_10_STATES.map((code) => (
            <a
              href={`/${STATES[code].slug}/${amount}-after-taxes/`}
              class="rounded-lg border border-slate-200 bg-white px-3 py-2 text-center text-sm transition-colors hover:border-navy-300 dark:border-slate-700 dark:bg-slate-800 dark:hover:border-navy-600"
            >
              <span class="font-semibold text-navy-700 dark:text-navy-400">{STATES[code].name}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════ RELATED SALARY AMOUNTS (cross-links) ═══════ -->
    <section class="border-t border-slate-200 px-4 py-12 dark:border-slate-800 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <h2 class="mb-6 text-xl font-bold text-slate-900 dark:text-white">
          Compare Other Salary Amounts
        </h2>
        <div class="grid grid-cols-3 gap-2 sm:grid-cols-5">
          {SALARY_AMOUNTS.filter((s) => s !== amount).map((s) => (
            <a
              href={`/${s}-after-taxes/`}
              class="rounded-lg border border-slate-200 bg-white px-3 py-2 text-center text-sm transition-colors hover:border-navy-300 dark:border-slate-700 dark:bg-slate-800 dark:hover:border-navy-600"
            >
              <span class="tabular-nums font-semibold text-navy-700 dark:text-navy-400">
                {formatCurrencyRound(s)}
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>
  </Fragment>
</CalculatorLayout>
