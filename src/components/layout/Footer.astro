---
import { DISCLAIMER, TAX_YEAR, SITE_NAME } from '../../lib/constants';

const footerSections = [
  {
    title: 'Calculators',
    links: [
      { label: 'Paycheck Calculator', href: '/' },
      { label: 'Salary Calculator', href: '/salary-calculator/' },
      { label: 'Hourly Pay Calculator', href: '/hourly-paycheck-calculator/' },
      { label: 'Income Tax Calculator', href: '/income-tax-calculator/' },
      { label: 'Self-Employment Tax', href: '/self-employment-tax-calculator/' },
      { label: 'Bonus Tax Calculator', href: '/bonus-tax-calculator/' },
    ],
  },
  {
    title: 'Financial Tools',
    links: [
      { label: '401(k) Calculator', href: '/401k-calculator/' },
      { label: 'Roth IRA Calculator', href: '/roth-ira-calculator/' },
      { label: 'Mortgage Calculator', href: '/mortgage-calculator/' },
      { label: 'Loan Calculator', href: '/loan-calculator/' },
      { label: 'Property Tax Calculator', href: '/property-tax-calculator/' },
      { label: 'Sales Tax Calculator', href: '/sales-tax-calculator/' },
    ],
  },
  {
    title: 'Popular States',
    links: [
      { label: 'California', href: '/paycheck-calculator/california/' },
      { label: 'Texas', href: '/paycheck-calculator/texas/' },
      { label: 'Florida', href: '/paycheck-calculator/florida/' },
      { label: 'New York', href: '/paycheck-calculator/new-york/' },
      { label: 'Pennsylvania', href: '/paycheck-calculator/pennsylvania/' },
      { label: 'All States →', href: '/paycheck-calculator/' },
    ],
  },
  {
    title: 'Resources',
    links: [
      { label: 'Guides', href: '/guides/' },
      { label: 'Glossary', href: '/glossary/' },
      { label: 'About', href: '/about/' },
      { label: 'Contact', href: '/contact/' },
      { label: 'Widget', href: '/widget/' },
      { label: 'Privacy Policy', href: '/privacy-policy/' },
      { label: 'Terms of Service', href: '/terms-of-service/' },
      { label: 'Disclaimer', href: '/disclaimer/' },
      { label: 'Legal Notice', href: '/legal/' },
    ],
  },
];
---

<footer class="border-t border-slate-200 bg-slate-50 dark:border-slate-700 dark:bg-slate-900">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <!-- Footer grid -->
    <div class="grid grid-cols-2 gap-8 md:grid-cols-4">
      {footerSections.map((section) => (
        <div>
          <h3 class="text-sm font-semibold uppercase tracking-wider text-slate-900 dark:text-white">
            {section.title}
          </h3>
          <ul class="mt-4 space-y-2">
            {section.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-slate-600 hover:text-navy-700 dark:text-slate-400 dark:hover:text-navy-400"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Disclaimer -->
    <div class="mt-10 rounded-lg border border-amber-200 bg-amber-50 p-4 dark:border-amber-800/50 dark:bg-amber-900/20">
      <p class="text-xs leading-relaxed text-amber-800 dark:text-amber-200">
        <strong>Disclaimer:</strong> {DISCLAIMER}
      </p>
    </div>

    <!-- Bottom bar -->
    <div class="mt-8 flex flex-col items-center justify-between gap-4 border-t border-slate-200 pt-8 sm:flex-row dark:border-slate-700">
      <div class="flex items-center gap-2">
        <img src="/favicon.svg" alt="" width="24" height="24" class="h-6 w-6" />
        <span class="text-sm font-semibold text-slate-700 dark:text-slate-300">
          {SITE_NAME}
        </span>
      </div>
      <p class="text-sm text-slate-500 dark:text-slate-400">
        &copy; {new Date().getFullYear()} {SITE_NAME}. Updated for tax year {TAX_YEAR}.
      </p>
    </div>
  </div>
</footer>
